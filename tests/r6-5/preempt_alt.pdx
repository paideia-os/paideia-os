// tests/r6-5/preempt_alt.pdx — R6.5-007 preemptive multitasking fixture
// Issue: R6.5-007 (#258) — R6.5 closure + reactivation-sweep closure marker
//
// Per .plans §2.6 R6.5-007:
//   2 TCBs, NO explicit yield — both run tight loops printing to UART.
//   Timer-driven preemption alternates them. UART log shows interleaved output
//   proving timer preemption.
//
// HONEST SCOPE (paideia-as 0.6.0): the fixture models timer-driven preemption
// as a tick loop: each timer tick drives the running TCB's budget toward zero;
// on depletion the scheduler preempts and the other TCB runs. The interleaving
// (neither TCB yields voluntarily) is checkable here. Real per-loop UART
// emission + real context switch on the timer IRQ are gated on the
// uart/iretq/mem-operand encoders.

module PreemptAlt = structure {
  let TCB_A : u64 = 1
  let TCB_B : u64 = 2

  // Small budget so preemption happens quickly within the fixture.
  let SLICE : u64 = 3
  // Number of timer ticks to simulate.
  let TICKS : u64 = 18

  let mut active : u64 = 1
  let mut budget : u64 = 3
  let mut runs_a : u64 = 0
  let mut runs_b : u64 = 0

  // One timer tick: the active TCB consumes a slice unit; on depletion the
  // scheduler preempts to the other TCB and resets the slice. Neither TCB
  // yields — preemption is entirely timer-driven.
  let on_tick : () -> u64 = fn () -> {
    if budget == 0 {
      // Preempt: switch active TCB, reset slice.
      if active == TCB_A {
        active = TCB_B;
        runs_b = runs_b + 1
      } else {
        active = TCB_A;
        runs_a = runs_a + 1
      };
      budget = SLICE;
      1
    } else {
      budget = budget - 1;
      0
    }
  }

  // Drive TICKS timer ticks. Returns the number of preemptions observed.
  let run_preempt_alt : () -> u64 = fn () -> {
    runs_a = 1;       // TCB-A starts running
    active = TCB_A;
    budget = SLICE;
    let mut i : u64 = 0;
    let mut preemptions : u64 = 0;
    while i < TICKS {
      let p : u64 = on_tick();
      preemptions = preemptions + p;
      i = i + 1
    };
    preemptions
  }

  // True (1) iff both TCBs ran at least twice (proof of alternation).
  let preempt_alt_ok : () -> u64 = fn () -> {
    if runs_a >= 2 {
      if runs_b >= 2 {
        1
      } else {
        0
      }
    } else {
      0
    }
  }
}
