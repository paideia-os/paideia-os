// tests/d7/virtio_probe.pdx — D7-006 virtio-net probe fixture
// Issue: D7-006 (#264)
//
// Per .plans §3 D7-006:
//   On QEMU with -device virtio-net, the driver's probe runs, prints the
//   discovery line, exits cleanly.
//
// HONEST SCOPE (paideia-as 0.6.0): the live config read + UART emit are gated;
// this fixture feeds the probe the config word QEMU would return for a
// virtio-net device (vendor 0x1AF4 | device 0x1041 << 16) and a sample BAR0,
// and asserts the probe matches + derives the right BAR0 base.

module VirtioProbeTest = structure {
  let VIRTIO_VENDOR : u64 = 0x1AF4
  let VIRTIO_NET_DEVICE : u64 = 0x1041
  // Config register-0 word QEMU returns for virtio-net.
  let CFG_WORD : u64 = 0x10411AF4   // vendor 0x1AF4 | device 0x1041 << 16
  // Sample BAR0 (MMIO, 64-bit type bits in low nibble).
  let BAR0_WORD : u64 = 0xFEBF0004
  let EXPECTED_BAR0 : u64 = 0xFEBF0000

  let PROBE_FOUND : u64 = 1

  // Mirror of VirtioNetProbe.is_virtio_net.
  let is_virtio_net : (u64) -> u64 = fn (w: u64) -> {
    let vendor : u64 = w & 0xFFFF;
    let device : u64 = (w >> 16) & 0xFFFF;
    if vendor == VIRTIO_VENDOR {
      if device == VIRTIO_NET_DEVICE {
        1
      } else {
        0
      }
    } else {
      0
    }
  }

  let bar0_base : (u64) -> u64 = fn (b: u64) -> b & 0xFFFFFFF0

  // 1 iff the probe matches virtio-net AND derives the expected BAR0 base.
  let probe_ok : () -> u64 = fn () -> {
    if is_virtio_net(CFG_WORD) == PROBE_FOUND {
      if bar0_base(BAR0_WORD) == EXPECTED_BAR0 {
        1
      } else {
        0
      }
    } else {
      0
    }
  }
}
