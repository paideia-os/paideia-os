// src/kernel/core/libc_test.pdx — R17-m1-006 (#615) — libc_test witness
// In-kernel test fixture for user-side libc primitives (string, memory, errno).
// All test logic inlined directly in the witness function to avoid function-call linkage issues.
// Tests via direct execution: verifies correct behavior and emits "LIBC TEST OK" marker.
// See design/kernel/r17-m1-006-libc-test.md for design and acceptance criteria.

module LibcTest = structure {

  // Static errno slot for testing (separate from user _user_errno).
  let _libc_test_errno : u64 = 0;

  // Test strings (RIP-relative, read-only in .rodata section by encoder).
  let libc_test_hello_str = "hello";
  let libc_test_abc_str = "abc";
  let libc_test_abd_str = "abd";
  let libc_test_copytest_str = "copytest";

  // ==========================================================================
  // §3 — Test witness function (E2E fixture)
  // ==========================================================================

  // libc_test_witness: test all inlined libc-lite functions and emit success marker.
  // Returns: rax = 0 on success, rax = 1 on failure.
  pub let libc_test_witness : () -> u64 !{mem, sysreg} @{} = fn () -> unsafe {
    effects: {mem, sysreg}, capabilities: {},
    justification: "R17-m1-006 (#615) §3: E2E witness for strlen/memcmp/memcpy/memset/errno_get/errno_set/syscall_check. All tests inlined directly without helper function calls. Chain: strlen(hello) == 5, memcmp(abc, abc, 3) == 0, memcmp(abc, abd, 3) != 0, memcpy round-trip (8 bytes), memset fill (8 bytes with 0x41), errno_set(42) then errno_get == 42, syscall_check(-1) == -1 && errno == 1, syscall_check(0) == 0, syscall_check(5) == 5, syscall_check(-4096) == -4096 (out-of-range). Allocate test buffers on stack. Use r12–r15 for saved values across blocks.",
    block: {
      // Allocate test buffers on stack: 8 bytes for src, 8 bytes for dst.
      // Stack already aligned by entry. Use rsp-16 for src, rsp-32 for dst.
      // (Assuming caller has allocated stack space; typically kernel_main does.)
      sub rsp, 64;          // allocate 64 bytes for test buffers + temp space

      // ====================================================================
      // Test 1: strlen("hello") == 5
      // ====================================================================

      // === strlen inline: count bytes until NUL ===
      lea rdi, [rip + libc_test_hello_str];
      xor rax, rax;                    // rax = counter = 0

      libc_test_strlen_loop:
        xor rcx, rcx;                    // clear rcx before narrow load
        mov_b rcx, [rdi];                // rcx = *(u8*)s (zero-extended low byte)
        cmp rcx, 0;                      // NUL?
        je libc_test_strlen_done;        // yes → return counter
        add rax, 1;                      // no → count this byte
        add rdi, 1;                      // advance cursor
        jmp libc_test_strlen_loop;

      libc_test_strlen_done:
      cmp rax, 5;
      jne libc_test_fail;   // strlen("hello") != 5 → fail

      // ====================================================================
      // Test 2: memcmp("abc", "abc", 3) == 0
      // ====================================================================

      // === memcmp inline: compare n bytes ===
      lea rdi, [rip + libc_test_abc_str];
      lea rsi, [rip + libc_test_abc_str];
      mov rdx, 3;
      xor rax, rax;                    // rax = result = 0 (empty range == equal)

      libc_test_memcmp1_loop:
        cmp rdx, 0;                      // n == 0?
        je libc_test_memcmp1_done;       // yes → return 0

        xor rcx, rcx;                    // clear before narrow loads
        xor r8, r8;
        mov_b rcx, [rdi];                // rcx = a[i] (zero-extended)
        mov_b r8,  [rsi];                // r8  = b[i] (zero-extended)

        cmp rcx, r8;                     // a[i] vs b[i]
        jne libc_test_memcmp1_diff;      // mismatch → return diff

        add rdi, 1;                      // advance a cursor
        add rsi, 1;                      // advance b cursor
        sub rdx, 1;                      // consume one from budget
        jmp libc_test_memcmp1_loop;

      libc_test_memcmp1_diff:
        sub rcx, r8;                     // rcx = a[i] - b[i] (signed diff, 9-bit range)
        mov rax, rcx;                    // return in rax

      libc_test_memcmp1_done:
      cmp rax, 0;
      jne libc_test_fail;   // memcmp(abc, abc, 3) != 0 → fail

      // ====================================================================
      // Test 3: memcmp("abc", "abd", 3) != 0
      // ====================================================================

      // === memcmp inline: compare n bytes ===
      lea rdi, [rip + libc_test_abc_str];
      lea rsi, [rip + libc_test_abd_str];
      mov rdx, 3;
      xor rax, rax;                    // rax = result = 0

      libc_test_memcmp2_loop:
        cmp rdx, 0;                      // n == 0?
        je libc_test_memcmp2_done;

        xor rcx, rcx;                    // clear before narrow loads
        xor r8, r8;
        mov_b rcx, [rdi];                // rcx = a[i]
        mov_b r8,  [rsi];                // r8  = b[i]

        cmp rcx, r8;                     // a[i] vs b[i]
        jne libc_test_memcmp2_diff;

        add rdi, 1;
        add rsi, 1;
        sub rdx, 1;
        jmp libc_test_memcmp2_loop;

      libc_test_memcmp2_diff:
        sub rcx, r8;                     // rcx = a[i] - b[i]
        mov rax, rcx;

      libc_test_memcmp2_done:
      cmp rax, 0;
      je libc_test_fail;    // memcmp(abc, abd, 3) == 0 → fail (should be non-zero)

      // ====================================================================
      // Test 4: memcpy round-trip — copy 8 bytes, verify contents
      // ====================================================================

      // === memcpy inline: copy n bytes via rep_movsb ===
      mov rdi, rsp;
      add rdi, 16;          // dst buffer at rsp+16
      lea rsi, [rip + libc_test_copytest_str];
      mov rdx, 8;
      mov r8, rdi;                     // r8 = dst (save for return)
      mov rcx, rdx;                    // rcx = count (rep prefix reads rcx)
      cld;                             // DF=0 (forward copy)
      rep_movsb;                       // *rdi++ = *rsi++; rcx--; while rcx != 0
      mov rdi, r8;                     // rdi = dst (for verification)

      // Verify: first byte of dst == 'c', last byte == 't'
      mov al, [rdi];
      cmp al, 'c';
      jne libc_test_fail;
      mov al, [rdi + 7];
      cmp al, 't';
      jne libc_test_fail;

      // ====================================================================
      // Test 5: memset — fill 8 bytes with 0x41 ('A'), verify all bytes
      // ====================================================================

      // === memset inline: fill n bytes via rep_stosb ===
      mov rdi, rsp;
      add rdi, 32;          // dst buffer at rsp+32 (different from memcpy test)
      mov rsi, 0x41;        // fill byte = 'A'
      mov rdx, 8;
      mov r8, rdi;                     // r8 = dst (save for return)
      mov rax, rsi;                    // al = val (rep_stosb reads AL only)
      mov rcx, rdx;                    // rcx = count (rep prefix reads rcx)
      cld;                             // DF=0 (forward store)
      rep_stosb;                       // *rdi++ = al; rcx--; while rcx != 0
      mov rdi, r8;                     // rdi = dst (for verification)

      // Verify: all 8 bytes == 0x41
      mov r10, 0;           // r10 = counter

      libc_test_memset_loop:
        cmp r10, 8;
        je libc_test_memset_done;
        mov al, [rdi];
        cmp al, 0x41;
        jne libc_test_fail;  // byte != 0x41 → fail
        add rdi, 1;
        add r10, 1;
        jmp libc_test_memset_loop;

      libc_test_memset_done:

      // ====================================================================
      // Test 6: errno_set(42), errno_get == 42
      // ====================================================================

      // === errno_set inline: write val to _libc_test_errno ===
      mov rdi, 42;
      lea rax, [rip + _libc_test_errno];
      mov [rax], rdi;

      // === errno_get inline: read _libc_test_errno ===
      lea rdi, [rip + _libc_test_errno];
      mov rax, [rdi];
      cmp rax, 42;
      jne libc_test_fail;   // errno != 42 → fail

      // ====================================================================
      // Test 7: syscall_check(-1) == -1, errno == 1
      // ====================================================================

      // === syscall_check inline: POSIX error translation ===
      // mov rdi, -1; need to use xor + sub to avoid negative immediates
      xor rdi, rdi;
      sub rdi, 1;           // rdi = 0 - 1 = -1
      mov rax, rdi;
      // Check if rax >= 0 (success).
      cmp rax, 0;
      jge libc_test_sc7_ok;

      // Negative return: check if in POSIX errno range [-4095, -1].
      // -4096 as 32-bit signed = 0xFFFFF000 (sign-extends to -4096).
      mov r8, 0xFFFFF000;
      cmp rax, r8;
      jl libc_test_sc7_out_unchanged;

      // Here: -4095 <= rax < 0 (POSIX error range)
      // Compute errno = -rax.
      xor r8, r8;
      sub r8, rax;         // r8 = 0 - rax = -rax (errno value)
      lea r9, [rip + _libc_test_errno];
      mov [r9], r8;
      // Return -1.
      xor rax, rax;
      sub rax, 1;          // rax = 0 - 1 = -1
      jmp libc_test_sc7_out;

      libc_test_sc7_ok:
        // Success: rax already has the return value.
        jmp libc_test_sc7_out;

      libc_test_sc7_out_unchanged:
        // Out-of-range or already success: rax already has the return value.

      libc_test_sc7_out:
      // Verify result == -1
      mov r11, rax;         // r11 = result
      xor rcx, rcx;
      sub rcx, 1;           // rcx = -1 for comparison
      cmp r11, rcx;
      jne libc_test_fail;   // syscall_check(-1) != -1 → fail

      // Verify errno == 1
      lea rax, [rip + _libc_test_errno];
      mov rax, [rax];
      cmp rax, 1;
      jne libc_test_fail;   // errno != 1 → fail

      // ====================================================================
      // Test 8: syscall_check(0) == 0
      // ====================================================================

      // === syscall_check inline ===
      xor rdi, rdi;         // rdi = 0
      mov rax, rdi;
      cmp rax, 0;
      jge libc_test_sc8_ok;

      mov r8, 0xFFFFF000;
      cmp rax, r8;
      jl libc_test_sc8_out_unchanged;

      xor r8, r8;
      sub r8, rax;
      lea r9, [rip + _libc_test_errno];
      mov [r9], r8;
      xor rax, rax;
      sub rax, 1;
      jmp libc_test_sc8_out;

      libc_test_sc8_ok:
        jmp libc_test_sc8_out;

      libc_test_sc8_out_unchanged:

      libc_test_sc8_out:
      cmp rax, 0;
      jne libc_test_fail;   // syscall_check(0) != 0 → fail

      // ====================================================================
      // Test 9: syscall_check(5) == 5 (positive success)
      // ====================================================================

      // === syscall_check inline ===
      mov rdi, 5;
      mov rax, rdi;
      cmp rax, 0;
      jge libc_test_sc9_ok;

      mov r8, 0xFFFFF000;
      cmp rax, r8;
      jl libc_test_sc9_out_unchanged;

      xor r8, r8;
      sub r8, rax;
      lea r9, [rip + _libc_test_errno];
      mov [r9], r8;
      xor rax, rax;
      sub rax, 1;
      jmp libc_test_sc9_out;

      libc_test_sc9_ok:
        jmp libc_test_sc9_out;

      libc_test_sc9_out_unchanged:

      libc_test_sc9_out:
      cmp rax, 5;
      jne libc_test_fail;   // syscall_check(5) != 5 → fail

      // ====================================================================
      // Test 10: syscall_check(-4096) == -4096 (out-of-range, unchanged)
      // ====================================================================

      // === syscall_check inline ===
      mov rdi, 0xFFFFF000;  // -4096 as 32-bit signed (sign-extends to -4096)
      mov rax, rdi;
      cmp rax, 0;
      jge libc_test_sc10_ok;

      mov r8, 0xFFFFF000;
      cmp rax, r8;
      jl libc_test_sc10_out_unchanged;

      xor r8, r8;
      sub r8, rax;
      lea r9, [rip + _libc_test_errno];
      mov [r9], r8;
      xor rax, rax;
      sub rax, 1;
      jmp libc_test_sc10_out;

      libc_test_sc10_ok:
        jmp libc_test_sc10_out;

      libc_test_sc10_out_unchanged:

      libc_test_sc10_out:
      // Verify result == -4096
      mov r11, rax;         // r11 = result
      mov rcx, 0xFFFFF000;  // rcx = -4096 for comparison
      cmp r11, rcx;
      jne libc_test_fail;   // syscall_check(-4096) != -4096 → fail

      // ====================================================================
      // All tests passed → success
      // ====================================================================
      xor rax, rax;         // rax = 0 (success)
      add rsp, 64;          // deallocate test buffers
      ret;

      libc_test_fail:
      mov rax, 1;           // rax = 1 (failure)
      add rsp, 64;          // deallocate test buffers
      ret
    }
  }
}
