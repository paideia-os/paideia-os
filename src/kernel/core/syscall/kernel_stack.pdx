// src/kernel/core/syscall/kernel_stack.pdx — R13-m5-002 (#428) — SYSCALL kernel stack
// 16 KiB per-BSP kernel stack + saved-rsp slot.
// SINGLE-CPU ONLY. R13-m6 must convert to per-CPU (via [gs:KSTACK_SLOT]).
// Multi-CPU boot with this file unchanged = data race on rsp switch = crash.

module KernelStack = structure {
  pub let SYSCALL_STACK_QWORDS : u64 = 2048
  pub let SYSCALL_STACK_BYTES : u64 = 16384

  pub let mut _syscall_kernel_stack : [u64; 2048] = uninit @align(16)
}
