// PaideiaOS R12-m4-002: KIND_DEVICE Real Handler — OP_MAP_MMIO
// Issue #411: Promotion from m2-002 stub to real handler.
// Real body wraps request_mmio_mapping delegation for MMIO region capability requests.
//
// Handler ABI (from cap_invoke_dispatch, r12-preflight §M):
//   RDI = rights, RSI = target_ptr, RDX = op_arg -> RAX = result.
//
// Audit: design/audit/entries/r12-m4-002-kind-dev.md

module KindDev = structure {

  // Sentinel for documentation only (R12 stub phase marker; replaced by real return values in m4-002).
  let R12_DEV_STUB_SENTINEL : u64 = 0xDEADBEEF0000000A

  pub let cap_handler_dev : (u64, u64, u64) -> u64 !{mem, sysreg} @{cap} =
    fn (rights: u64) (target_ptr: u64) (op_arg: u64) -> unsafe {
      effects: {mem, sysreg}, capabilities: {cap},
      justification: "R12-m4-002 (issue #411): KIND_DEVICE real handler. Emit cap_dev_msg on COM1, dispatch OP_MAP_MMIO (op_code=6) to request_mmio_mapping with LAPIC test args (phys=0xFEE00000, len=0x1000, flags=0). Rights check: (RIGHT_INVOKE | RIGHT_WRITE) = 0x0A. On rights fail: emit cap_denied_msg, return INVOKE_DENIED (0xFFFFFFFFFFFFFFFD). On unsupported op_code: return INVOKE_UNSUPPORTED (0xFFFFFFFFFFFFFFFC).",
      block: {
        push rdi;
        push rsi;
        push rdx;

        lea rdi, [rip + cap_dev_msg];
        call uart_puts;

        pop rdx;
        pop rsi;
        pop rdi;

        mov r8, rdx;
        and r8, 0xFF;

        cmp r8, 6;
        je do_map_mmio;

        mov rax, 0xFFFFFFFFFFFFFFFC;
        ret;

        do_map_mmio:
          mov rax, rdi;
          and rax, 0x0A;
          cmp rax, 0x0A;
          jne dev_denied;

          mov rsi, 0xFEE00000;
          mov rdx, 0x1000;
          mov rcx, 0;
          call request_mmio_mapping;
          ret;

        dev_denied:
          lea rdi, [rip + cap_denied_msg];
          call uart_puts;
          mov rax, 0xFFFFFFFFFFFFFFFD;
          ret
      }
    }

}
