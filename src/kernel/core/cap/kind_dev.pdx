// PaideiaOS R12-m2-002 device handler stub
// Real body lands in m4-002 (issue #411): OP_MAP_MMIO wrapping request_mmio_mapping.
// This stub emits the "cap_dev_msg" tag on COM1 and returns a kind-specific
// sentinel so a caller can distinguish "handler reached" from "dispatcher
// fallthrough".
//
// Handler ABI (from cap_invoke_dispatch, r12-preflight §M):
//   RDI = rights, RSI = target_ptr, RDX = op_arg -> RAX = result.
//
// Audit: AUDIT/r12-m2-002-stub-handlers.

module KindDev = structure {

  let R12_DEV_STUB_SENTINEL : u64 = 0xDEADBEEF0000000A

  pub let cap_handler_dev : (u64, u64, u64) -> u64 !{mem, sysreg} @{cap} =
    fn (rights: u64) (target_ptr: u64) (op_arg: u64) -> unsafe {
      effects: {mem, sysreg}, capabilities: {cap},
      justification: "R12-m2-002: device stub. Emit cap_dev_msg on COM1, return sentinel 0xDEADBEEF0000000A. Real dispatch lands in m4-002 (issue #411).",
      block: {
        lea rdi, [rip + cap_dev_msg];
        call uart_puts;
        mov rax, 0xDEADBEEF0000000A;
        ret
      }
    }

}
