// PaideiaOS Phase-1 Capability Descriptor
// P2-001: phase1_capability struct (24 bytes, fixed layout)
//
// Per design/capabilities/phase1-api.md Section 1:
// Fields: kind (u32), rights (u32), target_ptr (u64), generation (u32), flags (u32)
// Total: 24 bytes. Fixed-size slab allocator.

module Descriptor = structure {

  struct Capability {
    kind: u64,
    rights: u64,
    target_ptr: u64,
    generation: u64,
    flags: u32
  }

}
