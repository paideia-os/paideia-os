// src/kernel/core/mm/phys_alloc.pdx — Phase 5 P5-005
//
// Physical memory allocation API — p1_phys_alloc stub.
//
// Allocates physical memory pages (rounded to 4 KiB). Returns a physical
// address on success, or a special constant on out-of-memory. Phase 1
// uses NUMA hints but does not enforce affinity.

module PhysAlloc = structure {
  let PHYS_ALLOC_OK   : i64 = 0
  let PHYS_ALLOC_OOM  : i64 = -1
}
