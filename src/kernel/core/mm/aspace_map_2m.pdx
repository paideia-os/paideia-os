// src/kernel/core/mm/aspace_map_2m.pdx — Phase 5 P5-014
//
// 2 MiB mapping — p1_aspace_map 2-MiB variant.
//
// Maps large (2 MiB) pages into an address space. Uses the PDPT→PD
// page-table level to create a single huge-page entry, reducing memory
// usage and TLB pressure for large contiguous regions (e.g., framebuffer,
// large buffers). Supports the same overlap validation as 4K mapping.

module AspaceMap2m = structure {
  let MAP_2M_OK : i64 = 0
}
