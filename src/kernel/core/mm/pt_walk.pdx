// src/kernel/core/mm/pt_walk.pdx — Phase 5 P5-012
//
// Page-table walk helper — locates or creates page-table entries.
//
// Walks the x86_64 page-table hierarchy (PML4 → PDPT → PD → PT)
// to find an existing entry or allocate intermediate pages as needed.
// Returns status codes: found, not-found, or created.

module PtWalk = structure {
  let PT_WALK_FOUND    : i64 = 1
  let PT_WALK_NOT_FOUND : i64 = 0
  let PT_WALK_CREATED  : i64 = 2
}
