// src/kernel/core/mm/magazine.pdx — Phase 5 P5-004
//
// Per-CPU magazine (cache) size — fast allocation path.
//
// Each CPU maintains a small cache (magazine) of pre-allocated pages
// to reduce contention on the global buddy allocator. MAGAZINE_SIZE
// sets the maximum number of cached 4 KiB pages per CPU.

module Magazine = structure {
  let MAGAZINE_SIZE : u64 = 16
}
