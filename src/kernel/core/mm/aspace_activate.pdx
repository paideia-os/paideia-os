// src/kernel/core/mm/aspace_activate.pdx — Phase 5 P5-010
// Address space activation — audit entry aspace_activate-001.
//
// Switches the CPU to use a different address space by writing
// the AS's PML4 physical address (and PCID) to CR3. This is an
// unsafe privileged operation; the unsafe block performs the CR3 write.

module AspaceActivate = structure {
  let ASPACE_ACTIVATE_OK : i64 = 0
}
