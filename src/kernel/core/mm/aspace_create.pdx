// src/kernel/core/mm/aspace_create.pdx — Phase 5 P5-008
//
// Address space creation API — p1_aspace_create stub.
//
// Allocates and initializes a new address space, allocating pages
// for the PML4 and initial page-table structure. Returns an AS handle
// (or error code on out-of-memory).

module AspaceCreate = structure {
  let ASPACE_CREATE_OK   : i64 = 0
  let ASPACE_CREATE_OOM  : i64 = -1
}
