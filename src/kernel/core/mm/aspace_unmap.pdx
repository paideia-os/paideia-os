// src/kernel/core/mm/aspace_unmap.pdx — Phase 5 P5-015
//
// Page unmapping — p1_aspace_unmap stub.
//
// Removes mappings from an address space. Clears page-table entries
// and (optionally) reclaims empty page-table pages. Does NOT zero
// the unmapped memory; physical pages remain the caller's responsibility
// if they should be freed (see p1_phys_free).

module AspaceUnmap = structure {
  let UNMAP_OK : i64 = 0
}
