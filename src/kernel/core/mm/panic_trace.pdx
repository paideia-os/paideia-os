// src/kernel/core/mm/panic_trace.pdx — Phase 5 P5-019
//
// Panic trace ring buffer — diagnostics support.
//
// Circular buffer for recording memory-related fault events (page faults,
// allocation failures, etc.) that led to a panic. Helps debugging kernel
// memory management issues. PANIC_TRACE_SIZE sets the ring buffer capacity
// in bytes; typical value 4096 bytes.

module PanicTrace = structure {
  let PANIC_TRACE_SIZE : u64 = 4096
}
