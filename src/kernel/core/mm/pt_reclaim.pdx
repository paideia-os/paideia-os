// src/kernel/core/mm/pt_reclaim.pdx — Phase 5 P5-016
//
// Page-table reclamation — cleanup after unmapping.
//
// After an unmap operation, some page-table pages may become empty
// (all entries cleared). pt_reclaim scans the hierarchy and frees
// empty PT/PD/PDPT pages back to the physical allocator, reducing
// memory fragmentation.

module PtReclaim = structure {
  let PT_RECLAIM_OK : i64 = 0
}
