// src/kernel/core/mm/pf_handler.pdx — Phase 5 P5-018
// Page fault handler — audit entry pf_handler-001.
//
// Handles #PF (page fault) exceptions. Decodes the faulting address
// from CR2, looks up the AS, and attempts to resolve the fault by
// mapping missing pages or validating access permissions. Returns
// error codes for invalid faults (e.g., write to read-only page).

module PfHandler = structure {
  let PF_HANDLE_OK   : i64 = 0
  let PF_HANDLE_KILL : i64 = 1
}
