// src/kernel/core/mm/numa_free.pdx — Phase 5 P5-020
//
// Per-NUMA domain free lists — Phase-2 preparation.
//
// Phase 1 uses a single global buddy allocator. Phase 2 will split
// per NUMA domain to reduce cross-domain memory traffic and improve
// affinity. NUMA_MAX_DOMAINS caps the number of domains supported.

module NumaFree = structure {
  let NUMA_MAX_DOMAINS : u64 = 8
}
