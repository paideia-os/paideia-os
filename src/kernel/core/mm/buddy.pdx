// src/kernel/core/mm/buddy.pdx — Phase 5 P5-003
//
// Buddy allocator constants — 4 KiB to 2 MiB range.
//
// Defines the buddy allocator's order range. Each order k allocates 2^k bytes.
// BUDDY_MIN_ORDER = 12 → 4 KiB (2^12 bytes)
// BUDDY_MAX_ORDER = 21 → 2 MiB (2^21 bytes)
// BUDDY_FREE_LIST_COUNT tracks free lists across all orders.

module Buddy = structure {
  let BUDDY_MIN_ORDER        : u64 = 12
  let BUDDY_MAX_ORDER        : u64 = 21
  let BUDDY_FREE_LIST_COUNT  : u64 = 10
}
