// src/kernel/core/mm/phys_free.pdx — Phase 5 P5-006
//
// Physical memory freeing API — p1_phys_free stub.
//
// Returns allocated physical memory pages back to the buddy allocator.
// Validates that the freed address and size match a previous allocation;
// returns an error if the address is invalid or doubly freed.

module PhysFree = structure {
  let PHYS_FREE_OK       : i64 = 0
  let PHYS_FREE_INVALID  : i64 = -1
}
