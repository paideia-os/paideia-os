// src/kernel/core/mm/pcid.pdx — Phase 5 P5-009
//
// PCID (Process-Context Identifier) allocator constants.
//
// x86_64 supports 12-bit PCIDs (4096 values). Used to tag AS instances
// so the CPU's TLB can hold multiple AS entries simultaneously without
// flushing on context switch. PCID 0 is reserved for kernel.

module Pcid = structure {
  let PCID_MAX : u64 = 4096
}
