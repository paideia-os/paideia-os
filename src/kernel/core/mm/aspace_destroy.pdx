// src/kernel/core/mm/aspace_destroy.pdx — Phase 5 P5-011
//
// Address space destruction API — p1_aspace_destroy stub.
//
// Tears down an address space: reclaims all page tables, unmaps
// all mappings, and frees the PCID. After this call, the AS handle
// is invalid and must not be reused.

module AspaceDestroy = structure {
  let ASPACE_DESTROY_OK : i64 = 0
}
