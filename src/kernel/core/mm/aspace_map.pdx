// src/kernel/core/mm/aspace_map.pdx — Phase 5 P5-013
//
// 4 KiB page mapping — p1_aspace_map stub.
//
// Maps a physical page (or range of 4 KiB pages) into an address space
// at a given virtual address. Validates that the region does not overlap
// with existing mappings. Allocates page-table pages as needed via pt_walk.

module AspaceMap = structure {
  let MAP_OK       : i64 = 0
  let MAP_OVERLAP  : i64 = -1
}
