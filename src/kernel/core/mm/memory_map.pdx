// src/kernel/core/mm/memory_map.pdx — Phase 5 P5-001
//
// E820 memory map parser — audit entry memory_map-001.
//
// Audits the entry-by-entry bootloader memory map (BIOS-provided E820 output)
// to identify usable vs. reserved regions. Each entry carries a type code
// (MEM_MAP_TYPE_USABLE or MEM_MAP_TYPE_RESERVED).

module MemoryMap = structure {
  // Memory map entry type constants
  let MEM_MAP_TYPE_USABLE    : u64 = 1
  let MEM_MAP_TYPE_RESERVED  : u64 = 2
}
