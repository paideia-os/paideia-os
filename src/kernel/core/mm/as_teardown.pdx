// src/kernel/core/mm/as_teardown.pdx — Phase 5 P5-017
//
// Address space complete teardown — cleanup helper.
//
// Helper routine that unamps all mappings in an AS and reclaims all
// page-table pages. Called by p1_aspace_destroy to fully deallocate
// an AS. This is the Phase-1 version; Phase 2+ may support CoW-aware
// teardown with reference counting.

module AsTeardown = structure {
  let TEARDOWN_OK : i64 = 0
}
