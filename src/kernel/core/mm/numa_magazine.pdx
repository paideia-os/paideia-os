// src/kernel/core/mm/numa_magazine.pdx — Phase 5 P5-021
//
// NUMA-aware magazine refill strategy — Phase-2 preparation.
//
// When a CPU's magazine runs low (fewer than NUMA_REFILL_THRESHOLD
// pages), it refills from the NUMA domain matching the CPU's affinity.
// This reduces cross-domain MMIO and memory traffic compared to
// always refilling from a global queue.

module NumaMagazine = structure {
  let NUMA_REFILL_THRESHOLD : u64 = 4
}
