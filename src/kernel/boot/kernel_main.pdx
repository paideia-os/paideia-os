// src/kernel/boot/kernel_main.pdx — Phase 1 R1.5-001 (PA7 surface: call + loop)
//
// kernel_main_64: the 64-bit-mode entry point invoked after the long-mode
// transition. Orchestrates uart initialization → output → halt (infinite loop).
//
// R1.5-001 implementation note (Honest Scope):
// PA7-001 (multi-statement) and PA7-008 (loop) are fully functional.
// PA7-002 (inter-function calls) works in unsafe blocks, but cross-module call
// resolution with fully-qualified names is not yet supported in unsafe blocks.
// The current implementation consolidates uart stubs into this module to demonstrate
// all three PA7 features together:
//   - PA7-001: Three top-level statements in unsafe block body
//   - PA7-002: Inter-function calls (uart_init, uart_puts)
//   - PA7-008: Infinite loop with hlt instruction
//
// uart_init and uart_puts are local stubs (Phase 1); full UART driver in uart.pdx.
// banner_chunk_0 and banner_len are defined in banner.pdx and linked at runtime.

module KernelMain = structure {
  // kernel_main_64: the 64-bit entry point after long-mode transition.
  //
  // B3-004: Full implementation with cross-module calls to real uart_init and
  // uart_puts from the Uart module. Loads banner_msg address into RDI and passes
  // it to uart_puts for banner output.
  //
  // B5-005: Added cap_smoke call to exercise capability system (mint/verify/invoke).
  //
  // B6-004: Added ipc_smoke call to exercise IPC system (enqueue/dequeue).
  //
  // R12-m5-001: Added cap_dispatch_smoke call to exercise capability dispatch (mint/invoke on all four kinds).
  //
  // R9-m1-002: Added idt_install call to load the IDT and set up interrupt handling.
  //
  // R9-m2-001..004: Added apic_enable, lapic_timer_init, sti for timer interrupts.
  // R10-m2-002: Fixed QEMU CPU to expose TSC-DEADLINE; removed polling workaround.
  // R10-m2-003: Timer IRQ now fires autonomously (real delivery via vec 32).
  // R11-m1-002: Added apic_svr_enable to globally enable LAPIC (R11 issue #389).
  //             Fixed sti order: now called AFTER _current_tcb is set, preventing
  //             interrupt handlers from seeing uninitialized TCB pointers.
  // R11-m1-003: Added pic_mask_all to prevent PIC spurious IRQs during LAPIC delivery.
  //
  // Implementation:
  // 1. call uart_init — Initialize COM1 16550 UART (Uart module)
  // 2. lea rdi, [rip + banner_msg] — Load banner address (relative to IP)
  // 3. call uart_puts — Output boot banner (Uart module, takes string addr in RDI)
  // 4. call cap_smoke — Exercise cap_mint + cap_verify + cap_invoke (CapSmoke module)
  // 5. call ipc_smoke — Exercise ipc_enqueue + ipc_dequeue (IpcSmoke module)
  // 6. call cap_dispatch_smoke — Exercise cap_dispatch on all four kinds (DispatchSmoke module, R12-m5-001)
  // 7. call gdt_install — Install real 8-entry GDT with code64 at 0x08 (Gdt module, R13-m4-001)
  // 8. call idt_install — Install IDT and load IDTR (Idt module, R9-m1-002)
  // 9. call tss_install — Populate TSS, install descriptor in GDT, load task register (Tss module, R13-m4-002)
  // 10. call smep_enable — Set CR4.SMEP (bit 20) to trap ring-0 fetches from user pages (Smep module, R13-m3-003)
  // 11. call smap_enable — Set CR4.SMAP (bit 21) to trap ring-0 memory access to user pages (Smap module, R13-m3-004)
  // 12. call nx_enable — Set IA32_EFER.NXE (bit 11) to enable NX flag (XD) in page-table entries (Nx module, R13-m3-005)
  // 13. call apic_enable — Verify LAPIC global enable bit (ApicEnable module, R9-m2-001)
  // 14. call apic_svr_enable — Globally enable LAPIC SVR (LapicTimer module, R11-m1-002)
  // 15. call pic_mask_all — Mask all 8259 PIC IRQs (PicMask module, R11-m1-003)
  // 16. call lapic_timer_init — Program LAPIC timer for periodic mode + vector 32 (LapicTimer module, R9-m2-002)
  // 17. call sched_init_runqueue_r10 — Initialize scheduler and TCBs (Sched module, R10-m5-001)
  // 18. Set _current_tcb = &_task_a_tcb (kernel_main, R10-m5-001)
  // 19. sti — Enable interrupts AFTER _current_tcb is set (R11-m1-002 fix: prevents interrupt handlers from seeing null TCB)
  // 20. Bootstrap Task A and call task_a_entry (kernel_main)
  // 19. Unreachable hlt loop (Task A loops forever yielding to Task B)
  pub let kernel_main_64 : () -> () !{sysreg} @{} = fn () -> unsafe {
    effects: { sysreg },
    capabilities: { boot },
    justification: "B3-004: real uart_init + uart_puts(banner_msg). Call Uart module uart_init to initialize UART (all 7 port writes). Load banner_msg address into RDI via lea [rip+banner_msg], then call Uart module uart_puts to output the banner. Cross-module STB_GLOBAL linkage now supported via pub keyword (paideia-as v0.11.0+). B5-005: Call CapSmoke module cap_smoke to exercise capability mint/verify/invoke. B6-004: Call IpcSmoke module ipc_smoke to exercise IPC enqueue/dequeue. R12-m5-001: Call DispatchSmoke module cap_dispatch_smoke to exercise capability dispatch on all four kinds (PAGE, IPC_ENDPOINT, SCHED_CTX, DEVICE) with rights enforcement and denial witness. R13-m4-001: Call Gdt module gdt_install to load real 8-entry GDT with code64 at 0x08 (fixes boot_stub code32 latent bug); must precede idt_install. R9-m1-002: Call Idt module idt_install to populate and load the IDT. R13-m4-002 (#424): Call Tss module tss_install to populate TSS with RSP0 and IST fields, install TSS descriptor in GDT slots 6+7, and load task register via ltr. R13-m3-003: Call Smep module smep_enable to set CR4.SMEP (bit 20) preventing ring-0 code execution from user pages. R13-m3-004: Call Smap module smap_enable to set CR4.SMAP (bit 21) preventing ring-0 memory access to user pages. R13-m3-005: Call Nx module nx_enable to set IA32_EFER.NXE (bit 11) enabling data-execution prevention via page-table XD flag. R9-m2-001..004: Call ApicEnable apic_enable, LapicTimer lapic_timer_init to enable timer interrupts. R10-m2-002: QEMU now has -cpu max, exposing TSC-DEADLINE (CPUID.01H:ECX[24]). Timer IRQ fires autonomously. R10-m2-003: Removed polling workaround; replaced with hlt loop. Timer fires vec 32 → trampoline_vec32 → handle_timer. R11-m1-002: Call apic_svr_enable to globally enable LAPIC (R11 issue #389). Fix sti order: moved AFTER _current_tcb is set to prevent interrupt handlers from seeing uninitialized TCB pointers. R11-m1-003: Call pic_mask_all to prevent 8259 PIC spurious IRQs. R14.M4-004 (#500): populate _kernel_pml4_pa at boot for future kpti_switch_to_kernel; today VA(pml4)==PA(pml4) since pml4 is in low identity .bss.boot. R14b-m5-002 (#507): GS_BASE setup for gs-relative per-CPU access; wrmsr 0xC0000101 with &_cpu_locals[0] address; must precede any [gs:off] load; APs deferred to AP-startup.",
    block: {
      mov rax, [rip + _pml4_addr];
      mov [rip + _kernel_pml4_pa], rax;
      call uart_init;
      lea rdi, [rip + hi_va_msg];   // R14B-M3-008 (#496): witness high-VA execution
      call uart_puts;
      lea rdi, [rip + banner_msg];
      call uart_puts;
      call cap_smoke;
      call ipc_smoke;
      call cap_dispatch_smoke;
      call gdt_install;
      call idt_install;
      lea rdi, [rip + idt_ok_msg];
      call uart_puts;
      call tss_install;
      lea rdi, [rip + tss_ok_msg];
      call uart_puts;
      call smep_enable;
      call smap_enable;
      call nx_enable;

      // R14b-m5-008 (#660 Phase A): witness that CR0.WP is enabled at boot.
      // Ring-0 respects R-only PTEs — required substrate for CoW split (#553).
      lea rdi, [rip + cr0_wp_ok_msg];
      call uart_puts;

      // ============================================================
      // R15-M1-010 (#649): phys_free bitmap release witness.
      // ============================================================

      // 1. Snapshot initial free count.
      call phys_alloc_free_count;
      mov r12, rax;                       // r12 = initial free

      // 2. Allocate 4 pages.
      mov rdi, 0; call phys_alloc; mov r13, rax; cmp rax, 0; je pfr_fail;
      mov rdi, 0; call phys_alloc; mov r14, rax; cmp rax, 0; je pfr_fail;
      mov rdi, 0; call phys_alloc; mov r15, rax; cmp rax, 0; je pfr_fail;
      mov rdi, 0; call phys_alloc; mov rbx, rax; cmp rax, 0; je pfr_fail;

      // 3. Check free went down by 4.
      call phys_alloc_free_count;
      mov rcx, r12;
      sub rcx, 4;
      cmp rax, rcx;
      jne pfr_fail;

      // 4. Free all 4, in reverse order.
      mov rdi, rbx; xor rsi, rsi; call phys_free;
      mov rdi, r15; xor rsi, rsi; call phys_free;
      mov rdi, r14; xor rsi, rsi; call phys_free;
      mov rdi, r13; xor rsi, rsi; call phys_free;

      // 5. Free count must return to initial.
      call phys_alloc_free_count;
      cmp rax, r12;
      jne pfr_fail;

      // 6. Emit marker.
      lea rdi, [rip + phys_free_ok_msg];
      call uart_puts;
      jmp pfr_done;

      pfr_fail:
      lea rdi, [rip + phys_free_fail_msg];
      call uart_puts;

      pfr_done:

      // ============================================================
      // R15-M6-008 (#559): frame_meta refcount witness.
      // ============================================================

      // Check 1: Snapshot initial free count.
      call phys_alloc_free_count;
      mov r12, rax;                       // r12 = initial free count

      // Check 2: Alloc a frame, verify refcount == 1 and free count -= 1.
      mov rdi, 0; call phys_alloc;
      mov r13, rax;                       // r13 = frame VA
      cmp rax, 0;
      je fm_fail;

      mov rdi, r13; call frame_meta_get;
      cmp rax, 1;                         // refcount must be exactly 1
      jne fm_fail;

      call phys_alloc_free_count;
      mov rcx, r12;
      sub rcx, 1;
      cmp rax, rcx;                       // free count decreased by exactly 1
      jne fm_fail;

      // Check 3: Incref, verify refcount == 2, free count unchanged.
      mov rdi, r13; call frame_meta_incref;
      cmp rax, 2;                         // incref returns new count = 2
      jne fm_fail;

      mov rdi, r13; call frame_meta_get;
      cmp rax, 2;
      jne fm_fail;

      call phys_alloc_free_count;
      mov rcx, r12;
      sub rcx, 1;
      cmp rax, rcx;                       // still down by only 1 (bit not cleared)
      jne fm_fail;

      // Check 4: First phys_free — refcount drops to 1, frame STAYS allocated.
      mov rdi, r13; xor rsi, rsi; call phys_free;
      cmp rax, 0;                         // PHYS_FREE_OK
      jne fm_fail;

      mov rdi, r13; call frame_meta_get;
      cmp rax, 1;                         // refcount now 1
      jne fm_fail;

      call phys_alloc_free_count;
      mov rcx, r12;
      sub rcx, 1;
      cmp rax, rcx;                       // free count STILL down by 1 (bit stayed set)
      jne fm_fail;

      // Check 5: Second phys_free — refcount hits 0, frame RETURNS to pool.
      mov rdi, r13; xor rsi, rsi; call phys_free;
      cmp rax, 0;                         // PHYS_FREE_OK
      jne fm_fail;

      mov rdi, r13; call frame_meta_get;
      cmp rax, 0;                         // refcount now 0
      jne fm_fail;

      call phys_alloc_free_count;
      cmp rax, r12;                       // free count restored to initial
      jne fm_fail;

      // All checks green.
      lea rdi, [rip + frame_meta_ok_msg];
      call uart_puts;
      jmp fm_done;

      fm_fail:
      lea rdi, [rip + frame_meta_fail_msg];
      call uart_puts;

      fm_done:

      // ============================================================
      // R15-M6-001 (#552): aspace_clone_cow witness (3 phases).
      // ============================================================
      //
      // Phase 1: empty src (baseline control flow)
      // Phase 2: src with 1 mapped page (single-leaf shape check)
      // Phase 3: src with 5 mapped pages across distinct levels (tree navigation)
      //
      // Each phase creates fresh src/dst aspaces and verifies post-clone state.
      // Phases are independent; failure in one skips remaining phases.

      // === PHASE 1: Empty src ===
      call phys_alloc_free_count;
      mov r12, rax;                       // r12 = initial free count

      call aspace_create_user;
      mov rcx, 0xFFFFFFFF;
      cmp rax, rcx;
      je clone_phase1_fail;
      mov r13, rax;                       // r13 = src_pml4_va

      call aspace_create_user;
      cmp rax, rcx;
      je clone_phase1_fail;
      mov r14, rax;                       // r14 = dst_pml4_va

      // Act: clone empty src into dst
      mov rdi, r13;
      mov rsi, r14;
      call aspace_clone_cow;

      // Assert: rax == ASPACE_CLONE_OK (0)
      cmp rax, 0;
      jne clone_phase1_fail;

      // Assert: dst PML4[0..255] are all zero (walker touched nothing)
      xor r15, r15;
      clone_p1_check_loop:
        cmp r15, 256;
        jge clone_p1_check_done;
        mov rax, [r14 + r15*8];
        cmp rax, 0;
        jne clone_phase1_fail;
        add r15, 1;
        jmp clone_p1_check_loop;

      clone_p1_check_done:
      lea rdi, [rip + clone_cow_empty_ok_msg];
      call uart_puts;
      jmp clone_phase2_setup;

      clone_phase1_fail:
      lea rdi, [rip + clone_cow_empty_fail_msg];
      call uart_puts;
      jmp clone_phases_done;

      // === PHASE 2: One page ===
      clone_phase2_setup:
      call phys_alloc_free_count;
      mov r12, rax;                       // r12 = initial free count

      call aspace_create_user;
      mov rcx, 0xFFFFFFFF;
      cmp rax, rcx;
      je clone_phase2_fail;
      mov r13, rax;                       // r13 = src_pml4_va

      call aspace_create_user;
      cmp rax, rcx;
      je clone_phase2_fail;
      mov r14, rax;                       // r14 = dst_pml4_va

      // Allocate one frame
      mov rdi, 0;
      call phys_alloc;
      cmp rax, 0;
      je clone_phase2_fail;
      mov r15, rax;                       // r15 = frame_va

      // Map at TEST_VA_1 = 0x0000_0000_0040_0000 (PML4[0], PDPT[0], PD[2], PT[0])
      mov rdi, r13;                       // rdi = src_pml4_va
      mov rsi, 0x0000000000400000;        // rsi = TEST_VA_1
      mov rdx, r15;                       // rdx = frame_va
      mov rcx, 6;                         // rcx = PTE_US | PTE_RW (0x4 | 0x2 = 0x6)
      call aspace_map;
      cmp rax, 0;
      jne clone_phase2_fail;

      // Save frame_pa = frame_va - KERNEL_VMA_BASE
      mov rbx, r15;
      mov r11, 0xFFFF800000000000;
      sub rbx, r11;                       // rbx = frame_pa

      // Act: clone src into dst
      mov rdi, r13;
      mov rsi, r14;
      call aspace_clone_cow;
      cmp rax, 0;
      jne clone_phase2_fail;

      // Assert on src: walk to TEST_VA_1 and read leaf PTE
      mov rdi, r13;
      mov rsi, 0x0000000000400000;
      call pt_lookup_leaf_pte;
      mov r10, rax;                       // r10 = src leaf PTE

      // Assert PRESENT set
      mov rcx, r10;
      and rcx, 1;
      cmp rcx, 0;
      je clone_phase2_fail;

      // Assert RW clear
      mov rcx, r10;
      shr rcx, 1;
      and rcx, 1;
      cmp rcx, 1;
      je clone_phase2_fail;               // RW should be 0

      // Assert COW set
      mov rcx, r10;
      shr rcx, 9;
      and rcx, 1;
      cmp rcx, 1;
      jne clone_phase2_fail;              // COW should be 1

      // Assert frame field matches
      mov r11, 0x000FFFFFFFFFF000;
      mov rcx, r10;
      and rcx, r11;
      cmp rcx, rbx;
      jne clone_phase2_fail;

      // Assert on dst: walk to TEST_VA_1 and read leaf PTE
      mov rdi, r14;
      mov rsi, 0x0000000000400000;
      call pt_lookup_leaf_pte;
      mov r10, rax;                       // r10 = dst leaf PTE

      // Assert PRESENT set
      mov rcx, r10;
      and rcx, 1;
      cmp rcx, 0;
      je clone_phase2_fail;

      // Assert RW clear
      mov rcx, r10;
      shr rcx, 1;
      and rcx, 1;
      cmp rcx, 1;
      je clone_phase2_fail;

      // Assert COW set
      mov rcx, r10;
      shr rcx, 9;
      and rcx, 1;
      cmp rcx, 1;
      jne clone_phase2_fail;

      // Assert frame field matches
      mov r11, 0x000FFFFFFFFFF000;
      mov rcx, r10;
      and rcx, r11;
      cmp rcx, rbx;
      jne clone_phase2_fail;

      // Assert refcount == 2
      mov rdi, rbx;
      call frame_meta_get;
      cmp rax, 2;
      jne clone_phase2_fail;

      lea rdi, [rip + clone_cow_1page_ok_msg];
      call uart_puts;
      jmp clone_phase3_setup;

      clone_phase2_fail:
      lea rdi, [rip + clone_cow_1page_fail_msg];
      call uart_puts;
      jmp clone_phases_done;

      // === PHASE 3: Five pages across levels ===
      clone_phase3_setup:
      call phys_alloc_free_count;
      mov r12, rax;                       // r12 = initial free count

      call aspace_create_user;
      mov rcx, 0xFFFFFFFF;
      cmp rax, rcx;
      je clone_phase3_fail;
      mov r13, rax;                       // r13 = src_pml4_va

      call aspace_create_user;
      cmp rax, rcx;
      je clone_phase3_fail;
      mov r14, rax;                       // r14 = dst_pml4_va

      // Allocate and map 5 frames at distinct VAs
      // Store frame_vas on stack: [rsp], [rsp+8], [rsp+16], [rsp+24], [rsp+32]
      sub rsp, 40;                        // Allocate 5 × u64 on stack

      // Frame 0 (TEST_VA_A)
      mov rdi, 0; call phys_alloc;
      cmp rax, 0; je clone_phase3_fail;
      mov r8, 0; mov [rsp + r8*8], rax;  // Save frame_va
      mov rdi, r13; mov rsi, 0x0000000000400000;
      mov rdx, rax; mov rcx, 6; call aspace_map;
      cmp rax, 0; jne clone_phase3_fail;

      // Frame 1 (TEST_VA_B)
      mov rdi, 0; call phys_alloc;
      cmp rax, 0; je clone_phase3_fail;
      mov r8, 1; mov [rsp + r8*8], rax;
      mov rdi, r13; mov rsi, 0x0000000040000000;
      mov rdx, rax; mov rcx, 6; call aspace_map;
      cmp rax, 0; jne clone_phase3_fail;

      // Frame 2 (TEST_VA_C)
      mov rdi, 0; call phys_alloc;
      cmp rax, 0; je clone_phase3_fail;
      mov r8, 2; mov [rsp + r8*8], rax;
      mov rdi, r13; mov rsi, 0x0000000080001000;
      mov rdx, rax; mov rcx, 6; call aspace_map;
      cmp rax, 0; jne clone_phase3_fail;

      // Frame 3 (TEST_VA_D)
      mov rdi, 0; call phys_alloc;
      cmp rax, 0; je clone_phase3_fail;
      mov r8, 3; mov [rsp + r8*8], rax;
      mov rdi, r13; mov rsi, 0x0000008000002000;
      mov rdx, rax; mov rcx, 6; call aspace_map;
      cmp rax, 0; jne clone_phase3_fail;

      // Frame 4 (TEST_VA_E)
      mov rdi, 0; call phys_alloc;
      cmp rax, 0; je clone_phase3_fail;
      mov r8, 4; mov [rsp + r8*8], rax;
      mov rdi, r13; mov rsi, 0x0000010000003000;
      mov rdx, rax; mov rcx, 6; call aspace_map;
      cmp rax, 0; jne clone_phase3_fail;

      // Act: clone src into dst
      mov rdi, r13;
      mov rsi, r14;
      call aspace_clone_cow;
      cmp rax, 0;
      jne clone_phase3_fail;

      // Assert each of 5 leaves in src and dst
      // Loop over VAs and frames (stored on stack at [rsp+0..32])
      xor r15, r15;                       // loop counter
      mov r8, 5;                          // loop limit

      clone_p3_verify_loop:
        cmp r15, r8;
        jge clone_p3_verify_done;

        // Load frame_va from stack [rsp + r15*8]
        mov r9, [rsp + r15*8];            // r9 = frame_va

        // Compute frame_pa = frame_va - KERNEL_VMA_BASE
        mov r10, r9;
        mov rcx, 0xFFFF800000000000;
        sub r10, rcx;                     // r10 = frame_pa

        // Compute VA based on r15 index (inline, no relocation issues)
        // [0] = 0x0000_0000_0040_0000, [1] = 0x0000_0000_4000_0000,
        // [2] = 0x0000_0000_8000_1000, [3] = 0x0000_0080_0000_2000,
        // [4] = 0x0000_0100_0000_3000
        cmp r15, 0; je clone_p3_va_0;
        cmp r15, 1; je clone_p3_va_1;
        cmp r15, 2; je clone_p3_va_2;
        cmp r15, 3; je clone_p3_va_3;
        mov rsi, 0x0000010000003000;
        jmp clone_p3_va_done;
        clone_p3_va_0: mov rsi, 0x0000000000400000; jmp clone_p3_va_done;
        clone_p3_va_1: mov rsi, 0x0000000040000000; jmp clone_p3_va_done;
        clone_p3_va_2: mov rsi, 0x0000000080001000; jmp clone_p3_va_done;
        clone_p3_va_3: mov rsi, 0x0000008000002000; jmp clone_p3_va_done;
        clone_p3_va_done:

        // Check src leaf PTE
        mov rdi, r13;
        push r15; push r8; push r9; push r10; push r11;
        call pt_lookup_leaf_pte;
        pop r11; pop r10; pop r9; pop r8; pop r15;

        mov rdx, rax;                     // rdx = src leaf PTE

        // Assert PRESENT + RW clear + COW set + frame matches
        mov rcx, rdx;
        and rcx, 1;
        cmp rcx, 0;
        je clone_phase3_fail;             // not present

        mov rcx, rdx;
        shr rcx, 1; and rcx, 1;
        cmp rcx, 1;
        je clone_phase3_fail;             // RW set (should be 0)

        mov rcx, rdx;
        shr rcx, 9; and rcx, 1;
        cmp rcx, 1;
        jne clone_phase3_fail;            // COW not set

        mov rcx, rdx;
        mov r12, 0x000FFFFFFFFFF000;
        and rcx, r12;
        cmp rcx, r10;
        jne clone_phase3_fail;            // frame mismatch

        // Check dst leaf PTE
        mov rdi, r14;
        push r15; push r8; push r9; push r10; push r11;
        call pt_lookup_leaf_pte;
        pop r11; pop r10; pop r9; pop r8; pop r15;

        mov rdx, rax;                     // rdx = dst leaf PTE

        // Assert PRESENT + RW clear + COW set + frame matches
        mov rcx, rdx;
        and rcx, 1;
        cmp rcx, 0;
        je clone_phase3_fail;

        mov rcx, rdx;
        shr rcx, 1; and rcx, 1;
        cmp rcx, 1;
        je clone_phase3_fail;

        mov rcx, rdx;
        shr rcx, 9; and rcx, 1;
        cmp rcx, 1;
        jne clone_phase3_fail;

        mov rcx, rdx;
        mov r12, 0x000FFFFFFFFFF000;
        and rcx, r12;
        cmp rcx, r10;
        jne clone_phase3_fail;

        // Check refcount == 2
        mov rdi, r10;
        push r15; push r8; push r11;
        call frame_meta_get;
        pop r11; pop r8; pop r15;

        cmp rax, 2;
        jne clone_phase3_fail;

        add r15, 1;
        jmp clone_p3_verify_loop;

      clone_p3_verify_done:
      lea rdi, [rip + clone_cow_multi_ok_msg];
      call uart_puts;
      add rsp, 40;                        // Clean up stack (5 frame_vas)
      jmp clone_phases_done;

      clone_phase3_fail:
      lea rdi, [rip + clone_cow_multi_fail_msg];
      call uart_puts;
      add rsp, 40;                        // Clean up stack (5 frame_vas)

      clone_phases_done:

      // R14.M4-009 (#505): KPTI structural witness (no CR3 flip)
      mov rdi, [rip + _kernel_pml4_pa];
      call aspace_create_user_pgd;
      mov rdx, 0xFFFFFFFF;
      cmp rax, rdx;
      je kpti_fail;
      mov r15, rax;

      mov rdi, r15;
      call kpti_build_user_pml4;
      cmp rax, rdx;
      je kpti_fail;

      // Assert PML4[256] present bit
      mov rax, r15;
      add rax, 2048;
      mov rax, [rax];
      mov rcx, rax;
      and rcx, 1;
      cmp rcx, 0;
      je kpti_fail;

      // Assert singleton PDPT phys cached
      lea rcx, [rip + _kpti_trampoline_pdpt_pa];
      mov rcx, [rcx];
      cmp rcx, 0;
      je kpti_fail;

      // R14b-m4-006b (#645): KPTI scratch-slot round-trip witness.
      // Walk user PML4 -> PDPT -> PD -> PT[261] and verify trampoline data page is present + RW + U=0.
      mov rax, r15;
      add rax, 2048;
      mov rax, [rax];
      and rax, 0xFFFFFFFFFFFFF000;             // Mask to PDPT phys
      mov r9, rax;                             // r9 = PDPT phys

      // Check PT[261] (offset 2088) in the trampoline PT
      add r9, 0;                               // r9 = PDPT[0] location (PDPT+0 for PD[0] entry)
      mov rax, [r9];
      and rax, 0xFFFFFFFFFFFFF000;             // Mask to PD phys
      mov r10, rax;                            // r10 = PD phys

      add r10, 0;                              // r10 = PD[0] location (PD+0 for PT entry)
      mov rax, [r10];
      and rax, 0xFFFFFFFFFFFFF000;             // Mask to PT phys
      mov r11, rax;                            // r11 = PT phys

      add r11, 2088;                           // r11 = PT[261] slot
      mov rax, [r11];
      mov rcx, rax;
      and rcx, 1;
      cmp rcx, 0;
      je kpti_fail;                            // PT[261] not present

      // Check RW bit (bit 1)
      mov rcx, rax;
      shr rcx, 1;
      and rcx, 1;
      cmp rcx, 0;
      je kpti_fail;                            // PT[261] not writable

      // Check U=0 (bit 2 should be 0)
      mov rcx, rax;
      shr rcx, 2;
      and rcx, 1;
      cmp rcx, 0;
      jne kpti_fail;                           // PT[261] has U=1 (user-accessible)

      // Test scratch slot round-trip: write canary to _saved_user_rsp, read it back
      mov rax, 0xDEADBEEFCAFEF00D;
      lea rcx, [rip + _saved_user_rsp];
      mov [rcx], rax;
      mov rdx, [rcx];
      mov r8, 0xDEADBEEFCAFEF00D;
      cmp rdx, r8;
      jne kpti_fail;

      // Test _kernel_pml4_pa survives section move
      lea rcx, [rip + _kernel_pml4_pa];
      mov rdx, [rcx];
      cmp rdx, 0;
      je kpti_fail;

      lea rdi, [rip + kpti_ok_msg];
      call uart_puts;
      lea rdi, [rip + kpti_scratch_ok_msg];
      call uart_puts;

      // R15-M2-005-followup (#651): enter_userland_initial relocation witness.
      // Assert enter_userland_initial in .text.syscall_trampoline
      lea rax, [rip + enter_userland_initial];
      lea rcx, [rip + _syscall_trampoline_start];
      cmp rax, rcx;
      jb  enter_reloc_fail;
      lea rcx, [rip + _syscall_trampoline_end];
      cmp rax, rcx;
      jae enter_reloc_fail;

      // Assert _iretq_frame_scratch in .data.syscall_trampoline
      lea rax, [rip + _iretq_frame_scratch];
      lea rcx, [rip + _syscall_trampoline_data_start];
      cmp rax, rcx;
      jb  enter_reloc_fail;
      lea rcx, [rip + _syscall_trampoline_data_end];
      cmp rax, rcx;
      jae enter_reloc_fail;

      // Round-trip write to the five iretq slots
      lea r8, [rip + _iretq_frame_scratch];
      mov rax, 0xDEAD;      mov [r8 + 0],  rax;
      mov rax, 0x2B;        mov [r8 + 8],  rax;
      mov rax, 0x202;       mov [r8 + 16], rax;
      mov rax, 0xBEEF;      mov [r8 + 24], rax;
      mov rax, 0x23;        mov [r8 + 32], rax;

      mov rax, [r8 + 0];    mov rcx, 0xDEAD;  cmp rax, rcx;  jne enter_reloc_fail;
      mov rax, [r8 + 32];   mov rcx, 0x23;    cmp rax, rcx;  jne enter_reloc_fail;

      lea rdi, [rip + enter_reloc_ok_msg];
      call uart_puts;
      jmp enter_reloc_done;

      enter_reloc_fail:
      lea rdi, [rip + enter_reloc_fail_msg];
      call uart_puts;

      enter_reloc_done:

      // ============================================================
      // R15-M2-006b (#652): first ring-3 witness — user _start = hlt.
      // ============================================================

      lea rdi, [rip + ring3_start_msg];
      call uart_puts;

      // 1. Save kernel resume state (for #GP handler trap-frame surgery).
      mov rax, rsp;
      lea rcx, [rip + _kernel_resume_rsp];
      mov [rcx], rax;

      lea rdi, [rip + ring3_saved_rsp_msg];
      call uart_puts;

      // 2. Build witness PML4 (kernel higher-half copy + zero user half).
      lea rdi, [rip + ring3_create_pml4_msg];
      call uart_puts;

      mov rdi, [rip + _kernel_pml4_pa];
      call aspace_create;
      // #652 latent bug: save aspace_create's result (rax) into r12 BEFORE
      // the debug uart_puts below runs — uart_puts's char-copy loop leaves
      // rax=0 at exit (last byte read is the string's null terminator), so
      // calling it before checking/saving rax silently clobbered the real
      // return value, making witness_pml4_pa always 0 (which then loaded
      // CR3 with 0, causing the immediate #PF this witness was meant to
      // avoid). The very next block (phys_alloc below) already avoids this
      // exact trap via its "Save phys_alloc result... Check saved result,
      // not clobbered rax" comment; this site had been missed.
      mov r12, rax;                            // r12 = witness_pml4_pa

      lea rdi, [rip + ring3_aspace_done_msg];
      call uart_puts;

      mov rcx, 0xFFFFFFFF;
      cmp r12, rcx;
      je  ring3_witness_fail;

      // 3. Allocate a phys frame + write 0xF4 (hlt) + map at 0x400000.
      lea rdi, [rip + ring3_phys_alloc_msg];
      call uart_puts;

      mov rdi, 0;
      call phys_alloc;
      mov r13, rax;                            // Save phys_alloc result in r13
      mov r8, rax;                             // Also save in r8 for later check

      lea rdi, [rip + ring3_phys_done_msg];
      call uart_puts;

      cmp r8, 0;                               // Check saved result, not clobbered rax
      je  ring3_witness_fail;

      lea rdi, [rip + ring3_calc_va_msg];
      call uart_puts;

      // #652 fix: r13 (phys_alloc's result) is ALREADY a directly-writable
      // kernel VA (phys_alloc computes &_phys_page_pool + offset via a
      // RIP-relative lea, which resolves to the pool's high-half-linked
      // runtime address, not a genuine low physical address — see the
      // matching fix + full explanation in aspace_map.pdx). Adding
      // KERNEL_VMA_BASE again here produced a non-canonical address; write
      // through r13 directly instead.
      lea rdi, [rip + ring3_write_hlt_msg];
      call uart_puts;

      // #650: Write 3 bytes: 0x0F 0x0B 0xF4 (ud2 then hlt)
      mov rax, 0x0F;
      mov [r13], al;                           // ud2 byte 1
      mov rax, 0x0B;
      mov [r13 + 1], al;                       // ud2 byte 2
      mov rax, 0xF4;
      mov [r13 + 2], al;                       // hlt

      lea rdi, [rip + ring3_wrote_hlt_msg];
      call uart_puts;

      mov rdi, r12;                            // aspace
      mov rsi, 0x400000;                       // user VA
      mov rdx, r13;                            // phys
      mov rcx, 0x05;                           // P | U (X=1 via cleared NX)

      lea rsi, [rip + ring3_aspace_map_msg];
      mov rdi, rsi;
      call uart_puts;

      mov rdi, r12;                            // aspace (reload since uart_puts clobbered rdi)
      mov rsi, 0x400000;                       // user VA
      mov rdx, r13;                            // phys
      mov rcx, 0x05;                           // P | U (X=1 via cleared NX)
      call aspace_map;
      cmp rax, 0;
      jne ring3_witness_fail;                  // MAP_OOM = 0xFFFFFFFE, non-zero

      // 4. Allocate user stack in witness PML4.
      // Allocate physical frame for user stack
      lea rdi, [rip + ring3_stack_alloc_msg];
      call uart_puts;

      mov rdi, 0;
      call phys_alloc;
      cmp rax, 0;
      je  ring3_witness_fail;
      mov r8, rax;                             // r8 = stack_page_pa

      // Map at 0x7FFFFFFFF000 with R+W+U+NX
      mov rdi, r12;                            // aspace (witness PML4)
      mov rsi, 0x7FFFFFFFF000;                 // user stack VA
      mov rdx, r8;                             // phys
      mov rcx, 0x8000000000000007;             // R+W+U+NX (bit 63=1 for NX, bits 2,1,0 for U,W,P)
      call aspace_map;
      cmp rax, 0;
      jne ring3_witness_fail;

      lea rdi, [rip + ring3_stack_done_msg];
      call uart_puts;

      mov r14, 0x7FFFFFFFF000;                 // r14 = user_rsp

      // 5. Arm the witness flags (read by _typed_handler_6 and _typed_handler_13).
      mov rax, 1;
      lea rcx, [rip + _ring3_witness_active];
      mov [rcx], rax;
      lea rcx, [rip + _ud_witness_active];
      mov [rcx], rax;

      // 6. Enter userland. iretq → ring-3 → hlt → #GP → handler resumes below.
      lea rdi, [rip + ring3_enter_msg];
      call uart_puts;

      mov rdi, 0x400000;                       // entry_rip
      mov rsi, r14;                            // initial_rsp
      mov rdx, r12;                            // witness_pml4_pa (VA form, from aspace_create)
      // #652 fix: r12 is aspace_create's VA-style return value (needed as-is
      // for the aspace_map calls above, which index it as a pointer). CR3
      // needs a genuine physical address; convert here, at the last possible
      // point, so the aspace_map calls above keep using the VA form. (SUB
      // has no imm64 form, so movabs the constant into a register first.)
      mov rax, 0xFFFF800000000000;             // KERNEL_VMA_BASE
      sub rdx, rax;                             // rdx = genuine PA for CR3
      call enter_userland_initial;

      // UNREACHABLE — enter_userland_initial iretq's into ring-3. Fall-through
      // here would only happen if the primitive returned normally, which its
      // ud2 sentinel forbids. Belt-and-braces sentinel:
      lea rdi, [rip + ring3_returned_msg];
      call uart_puts;
      hlt;
      jmp ring3_witness_fail;

      ring3_witness_fail:
      lea rdi, [rip + ring3_fail_msg];
      call uart_puts;

      ring3_witness_done:
      jmp kpti_done;

      kpti_fail:
      lea rdi, [rip + kpti_fail_msg];
      call uart_puts;

      kpti_done:
      call boot_continue_after_ring3;

      // Unreachable belt-and-braces (boot_continue_after_ring3 never
      // returns: it ends in Task A's cooperative-yield forever-loop).
      kernel_main_unreachable:
        hlt;
        jmp kernel_main_unreachable;
    }
  }

  // R15-M2-006b (#652): boot_continue_after_ring3 — the remainder of the
  // boot sequence (GS_BASE setup through Task A bootstrap), extracted into
  // its own top-level (pub) function so it is a real, lea/call-addressable
  // ELF symbol. paideia-as does not support taking the address of a bare
  // block-local label (see justification below and
  // design/kernel/r15-m2-006b-boot-r15-ring3-hello.md) — only `jmp`/`jcc`
  // may target local labels, so _typed_handler_13's ring-3 witness resume
  // path (a different module, exceptions.pdx) can only transfer control
  // into "the rest of boot" via an ordinary cross-module `call` to a real
  // top-level symbol. Both kernel_main_64's own kpti_done fallthrough and
  // the exception handler's resume path now call this function.
  pub let boot_continue_after_ring3 : () -> () !{sysreg} @{} = fn () -> unsafe {
    effects: { sysreg }, capabilities: { boot },
    justification: "R15-M2-006b (#652): extracted tail of kernel_main_64 (GS_BASE setup, process_init, syscall_msr_init, apic_enable/apic_svr_enable/pic_mask_all, IPI structural witness, loader structural witness, LAPIC timer init, scheduler init, Task A bootstrap, and the unreachable cooperative-yield loop) so it is callable both from kernel_main_64's own kpti_done fallthrough and from _typed_handler_13's ring-3 witness resume path (paideia-as cannot `lea` a bare local label, only a top-level pub symbol).",
    block: {
      // ============================================================
      // R15-M5-007 (#549): fd_table witness — three one-liners.
      // ============================================================

      // Zero the witness task (uninit .bss is zero on ELF load, but be explicit).
      lea rdi, [rip + _fd_witness_task];

      // --- (1) fd_alloc should return 3 on a fresh task ---
      call fd_alloc;
      cmp  rax, 3;
      jne  fd_witness_fail;

      // --- (2) fd_set(t, 5, 0xDEADBEEFCAFEBABE) then fd_get(t, 5) round-trip ---
      lea rdi, [rip + _fd_witness_task];
      mov rsi, 5;
      mov rdx, 0xDEADBEEFCAFEBABE;
      call fd_set;

      lea rdi, [rip + _fd_witness_task];
      mov rsi, 5;
      call fd_get;
      mov rcx, 0xDEADBEEFCAFEBABE;
      cmp rax, rcx;
      jne fd_witness_fail;

      // --- (3) fd_alloc after fd_set(5, x) still returns 3 (first hole is 3) ---
      lea rdi, [rip + _fd_witness_task];
      call fd_alloc;
      cmp rax, 3;
      jne fd_witness_fail;

      // --- (4) fd_set(t, 3, x) → fd_alloc returns 4 (first free slot moved up) ---
      lea rdi, [rip + _fd_witness_task];
      mov rsi, 3;
      mov rdx, 0x1;                                // non-zero → allocated marker
      call fd_set;

      lea rdi, [rip + _fd_witness_task];
      call fd_alloc;
      cmp rax, 4;
      jne fd_witness_fail;

      // --- All four checks passed. Emit marker. ---
      lea rdi, [rip + fd_witness_ok_msg];
      call uart_puts;
      jmp  fd_witness_done;

      fd_witness_fail:
      lea rdi, [rip + fd_witness_fail_msg];
      call uart_puts;

      fd_witness_done:

      // ============================================================
      // R15-M5-006 (#548): task_new witness — single-call construction
      // ============================================================

      // task_new(NULL) — construct init.
      xor rdi, rdi;                              // parent = NULL sentinel
      call task_new;
      cmp rax, 0;
      je  task_new_witness_fail;                 // 0 = OOM = bug at boot

      mov r12, rax;                              // r12 = task_struct*

      // Check 1: pid == 1
      mov eax, [r12 + 0];                        // pid @ 0 (u32)
      cmp eax, 1;
      jne task_new_witness_fail;

      // Check 2: parent_pid == 0
      mov eax, [r12 + 4];                        // parent_pid @ 4 (u32)
      cmp eax, 0;
      jne task_new_witness_fail;

      // Check 3: state == STATE_NEW (0)
      mov eax, [r12 + 8];                        // state @ 8 (u32)
      cmp eax, 0;
      jne task_new_witness_fail;

      // Check 4: user_pml4_pa != 0
      mov rax, [r12 + 16];                       // user_pml4_pa @ 16 (u64)
      cmp rax, 0;
      je  task_new_witness_fail;

      // Check 5: pid_table[1] == r12
      lea rax, [rip + _pid_table];
      mov rcx, [rax + 8];                        // pid_table[1] (index 1 * 8 = 8)
      cmp rcx, r12;
      jne task_new_witness_fail;

      // All checks green
      lea rdi, [rip + task_new_witness_ok_msg];
      call uart_puts;
      jmp task_new_witness_exit;

      task_new_witness_fail:
          lea rdi, [rip + task_new_witness_fail_msg];
          call uart_puts;

      task_new_witness_exit:

      // R15-M5-009 (#551): 3-task pool witness. Verify pid_alloc advances
      // densely (1→2→3), each task_new succeeds (slab != 0), and
      // pid_table publishes correctly at indices 2, 3.
      // Precondition: r12 = slab_1 from #548 witness (or 0 if task 1 failed).
      // Register use: r12=slab_1, r13=slab_2, r14=slab_3 (all callee-saved across task_new).

      pool_witness:
          // Step 1: guard — bail if task 1 witness failed (r12 = 0)
          cmp r12, 0;
          je pool_witness_fail;

          // Step 2: construct task 2 → verify pid == 2 → save slab in r13
          xor rdi, rdi;                         // parent = NULL
          call task_new;
          cmp rax, 0;
          je pool_witness_fail;
          mov r13, rax;                         // r13 = slab_2
          mov eax, [r13 + 0];                   // pid @ offset 0 (u32)
          cmp eax, 2;
          jne pool_witness_fail;

          // Step 3: construct task 3 → verify pid == 3 → save slab in r14
          xor rdi, rdi;
          call task_new;
          cmp rax, 0;
          je pool_witness_fail;
          mov r14, rax;                         // r14 = slab_3
          mov eax, [r14 + 0];                   // pid @ offset 0 (u32)
          cmp eax, 3;
          jne pool_witness_fail;

          // Step 4: publish check — pid_table[2] == r13, pid_table[3] == r14
          lea rax, [rip + _pid_table];
          mov rcx, [rax + 16];                  // pid_table[2] @ index 2*8 = 16
          cmp rcx, r13;
          jne pool_witness_fail;
          mov rcx, [rax + 24];                  // pid_table[3] @ index 3*8 = 24
          cmp rcx, r14;
          jne pool_witness_fail;

          // All checks green
          lea rdi, [rip + pool_witness_ok_msg];
          call uart_puts;
          jmp pool_witness_exit;

      pool_witness_fail:
          lea rdi, [rip + pool_witness_fail_msg];
          call uart_puts;

      pool_witness_exit:

      // ============================================================
      // R15-M6-006 (#557): sys_exit witness — 2 sub-tests, 1 marker
      // ============================================================
      sys_exit_witness:
          // ---------- Sub-test 1: non-WAITING parent, no reap ----------
          // parent = task_new(NULL)
          xor rdi, rdi;
          call task_new;
          cmp rax, 0;
          je  sys_exit_witness_fail;
          mov r12, rax;                                // r12 = parent (pid 4)

          // child = task_new(parent)
          mov rdi, r12;
          call task_new;
          cmp rax, 0;
          je  sys_exit_witness_fail;
          mov r13, rax;                                // r13 = child (pid 5)

          // Set child->state = STATE_RUNNABLE (1) — simulate running
          // Not strictly required (NEW→ZOMBIE is a legal transition
          // per §3.4 — task_new default), but documents intent.
          mov rax, 1;
          mov [r13 + 8], eax;                          // child->state = RUNNABLE

          // sys_exit_body(child, 42)
          mov rdi, r13;
          mov rsi, 42;
          call sys_exit_body;

          // Assert: child->state == STATE_ZOMBIE (3)
          mov eax, [r13 + 8];
          cmp rax, 3;
          jne sys_exit_witness_fail;

          // Assert: child->exit_status == 42
          mov eax, [r13 + 12];
          cmp rax, 42;
          jne sys_exit_witness_fail;

          // Assert: parent->state unchanged (NEW = 0)
          mov eax, [r12 + 8];
          cmp rax, 0;
          jne sys_exit_witness_fail;

          // Assert: parent->wait_result_pid unchanged (0)
          mov eax, [r12 + 1704];
          cmp rax, 0;
          jne sys_exit_witness_fail;

          // ---------- Sub-test 2: WAITING parent, reap wakeup ----------
          // parent2 = task_new(NULL)
          xor rdi, rdi;
          call task_new;
          cmp rax, 0;
          je  sys_exit_witness_fail;
          mov r12, rax;                                // r12 = parent2 (pid 6)

          // Set parent2->state = STATE_WAITING (2) — simulate parked in sys_wait
          mov rax, 2;
          mov [r12 + 8], eax;

          // child2 = task_new(parent2)
          mov rdi, r12;
          call task_new;
          cmp rax, 0;
          je  sys_exit_witness_fail;
          mov r13, rax;                                // r13 = child2 (pid 7)

          // sys_exit_body(child2, 99)
          mov rdi, r13;
          mov rsi, 99;
          call sys_exit_body;

          // Assert: child2->state == STATE_ZOMBIE
          mov eax, [r13 + 8];
          cmp rax, 3;
          jne sys_exit_witness_fail;

          // Assert: child2->exit_status == 99
          mov eax, [r13 + 12];
          cmp rax, 99;
          jne sys_exit_witness_fail;

          // Assert: parent2->state == STATE_RUNNABLE (1) — was 2, wakeup transition
          mov eax, [r12 + 8];
          cmp rax, 1;
          jne sys_exit_witness_fail;

          // Assert: parent2->wait_result_pid == child2->pid (7)
          mov eax, [r13 + 0];                          // child2->pid
          mov ecx, [r12 + 1704];                       // parent2->wait_result_pid
          cmp rax, rcx;
          jne sys_exit_witness_fail;

          // Assert: parent2->wait_result_status == 99
          mov eax, [r12 + 1708];
          cmp rax, 99;
          jne sys_exit_witness_fail;

          // ---------- Cleanup: retire parent2 (#562 fix) ----------
          // parent2 exists solely to demonstrate the WAITING->RUNNABLE wakeup
          // transition above (Assert: parent2->state == STATE_RUNNABLE).
          // Left at STATE_RUNNABLE, it lingers in _pid_table as a live
          // "runnable" task for the rest of the boot sequence. idle_witness's
          // pick_next sub-test (#562) assumes _pid_table has zero RUNNABLE
          // entries by the time it runs sched_pick_next_r15's linear scan —
          // without this cleanup, that scan stops on parent2's slot (a real
          // task) instead of falling through to _idle_tcb, and the idle
          // witness spuriously fails. Retire parent2 to STATE_ZOMBIE (3),
          // the same terminal state its sibling test tasks (child, child2)
          // are already left in, so later scans no longer see it as
          // runnable. This mirrors the manual state pokes already used
          // above (e.g. "child->state = RUNNABLE" before sys_exit_body) —
          // test scaffolding cleanup, not a change to sys_exit_body itself.
          mov rax, 3;                                   // STATE_ZOMBIE
          mov [r12 + 8], eax;                           // parent2->state = STATE_ZOMBIE

          // ---------- All checks green ----------
          lea rdi, [rip + sys_exit_witness_ok_msg];
          call uart_puts;
          jmp sys_exit_witness_exit;

      sys_exit_witness_fail:
          lea rdi, [rip + sys_exit_witness_fail_msg];
          call uart_puts;

      sys_exit_witness_exit:

      // ============================================================
      // R15-M6-005 (#556): sys_wait witness — 3 sub-tests, 1 marker
      // ============================================================
      sys_wait_witness:
          // ---------- Sub-test A: zombie found, reap ----------
          // parent_a = task_new(NULL)
          xor rdi, rdi;
          call task_new;
          cmp rax, 0;
          je  sys_wait_witness_fail;
          mov r12, rax;                                // r12 = parent_a (pid 8)

          // child_a = task_new(parent_a)
          mov rdi, r12;
          call task_new;
          cmp rax, 0;
          je  sys_wait_witness_fail;
          mov r13, rax;                                // r13 = child_a (pid 9)

          // Manually mark child_a as ZOMBIE with exit_status = 42
          mov rax, 3;                                  // STATE_ZOMBIE
          mov [r13 + 8], eax;
          mov rax, 42;
          mov [r13 + 12], eax;                         // exit_status = 42

          // sys_wait_body(parent_a)
          mov rdi, r12;
          call sys_wait_body;

          // Assert: rax == child_a->pid (9)
          // NOTE: `and rcx, 0xFFFFFFFF` after a 64-bit load is a no-op on
          // x86-64 — AND r64, imm32 sign-extends 0xFFFFFFFF (== -1 as i32)
          // to 0xFFFFFFFFFFFFFFFF, an identity mask, not a truncation mask.
          // Use a genuine zero-extending 32-bit load instead (mov ecx, ...
          // zero-extends the upper 32 bits of rcx per x86-64 semantics).
          mov ecx, [r13 + 0];                          // child_a->pid (u32, zero-ext)
          cmp rax, rcx;
          jne sys_wait_witness_fail;

          // Assert: rdx == 42
          cmp rdx, 42;
          jne sys_wait_witness_fail;

          // Assert: _pid_table[child_a->pid] == 0 (child slot reaped)
          // NOTE: use the actual pid (still in rcx from the check above,
          // dynamic SIB index) rather than a hardcoded slot literal — see
          // the sub-test B note below for why a literal is fragile here.
          lea rax, [rip + _pid_table];
          mov rax, [rax + rcx*8];
          cmp rax, 0;
          jne sys_wait_witness_fail;

          // Assert: parent_a->state unchanged (NEW = 0)
          mov eax, [r12 + 8];
          cmp rax, 0;
          jne sys_wait_witness_fail;

          // ---------- Sub-test B: no zombie, block ----------
          // parent_b = task_new(NULL)
          xor rdi, rdi;
          call task_new;
          cmp rax, 0;
          je  sys_wait_witness_fail;
          mov r12, rax;                                // r12 = parent_b (reuses pid 9,
                                                        // freed by sub-test A's reap —
                                                        // pid_alloc is dense-low-first)

          // child_b = task_new(parent_b)  — state stays at NEW (=0)
          mov rdi, r12;
          call task_new;
          cmp rax, 0;
          je  sys_wait_witness_fail;
          mov r13, rax;                                // r13 = child_b (pid 10)

          // sys_wait_body(parent_b)
          mov rdi, r12;
          call sys_wait_body;

          // Assert: rax == 0 (would block)
          cmp rax, 0;
          jne sys_wait_witness_fail;

          // Assert: parent_b->state == STATE_WAITING (2)
          mov eax, [r12 + 8];
          cmp rax, 2;
          jne sys_wait_witness_fail;

          // Assert: child_b->state unchanged (NEW = 0)
          mov eax, [r13 + 8];
          cmp rax, 0;
          jne sys_wait_witness_fail;

          // Assert: _pid_table[child_b->pid] != 0 (child NOT reaped)
          // NOTE: a hardcoded slot literal (originally "slot 11") is fragile
          // here — sub-test A's reap (pid_free(9)) frees pid 9, so pid_alloc
          // (dense-low-first scan) hands parent_b pid 9 (reused) instead of
          // the naively-expected pid 10, and child_b becomes pid 10 instead
          // of pid 11. Index _pid_table dynamically via the actual pid
          // (u32 zero-ext load, then SIB scale-8), matching the addressing
          // idiom sys_wait_body itself uses, instead of assuming a fixed
          // allocation-order slot.
          mov ecx, [r13 + 0];                          // child_b->pid (u32, zero-ext)
          lea rax, [rip + _pid_table];
          mov rax, [rax + rcx*8];
          cmp rax, 0;
          je  sys_wait_witness_fail;

          // ---------- Sub-test C: no children, ECHILD ----------
          // parent_c = task_new(NULL)
          xor rdi, rdi;
          call task_new;
          cmp rax, 0;
          je  sys_wait_witness_fail;
          mov r12, rax;                                // r12 = parent_c (pid 11)

          // sys_wait_body(parent_c) — no children exist for parent_c's pid
          mov rdi, r12;
          call sys_wait_body;

          // Assert: rax == -ECHILD (0xFFFFFFFFFFFFFFF6)
          mov rcx, 0xFFFFFFFFFFFFFFF6;
          cmp rax, rcx;
          jne sys_wait_witness_fail;

          // Assert: parent_c->state unchanged (NEW = 0)
          mov eax, [r12 + 8];
          cmp rax, 0;
          jne sys_wait_witness_fail;

          // ---------- All checks green ----------
          lea rdi, [rip + sys_wait_witness_ok_msg];
          call uart_puts;
          jmp sys_wait_witness_exit;

      sys_wait_witness_fail:
          lea rdi, [rip + sys_wait_witness_fail_msg];
          call uart_puts;

      sys_wait_witness_exit:

      // ============================================================
      // R15-M6-004 (#555): sys_execve witness — 2 sub-tests, 1 marker
      // ============================================================
      sys_execve_witness:
          // ---------- Sub-test A: valid ELF, success + swap ----------
          // t_a = task_new(NULL) — provides a live user_pml4_pa @ 16
          xor rdi, rdi;
          call task_new;
          cmp rax, 0;
          je  sys_execve_witness_fail;
          mov r12, rax;                                // r12 = t_a slab

          // Save t_a->user_pml4_pa (old_pml4), pid, state for later compare
          mov rax, [r12 + 16];
          mov r13, rax;                                // r13 = old_pml4
          mov eax, [r12 + 0];
          mov r14d, eax;                               // r14 = t_a->pid (u32)
          mov eax, [r12 + 8];
          mov r15d, eax;                               // r15 = t_a->state (u32)

          // sys_execve_body(t_a, _shell_bin_start, image_len)
          mov rdi, r12;
          lea rsi, [rip + _shell_bin_start];
          lea rax, [rip + _shell_bin_end];
          sub rax, rsi;                                // rax = image_len
          mov rdx, rax;
          call sys_execve_body;

          // Assert: rax == 0 (ELF_OK)
          cmp rax, 0;
          jne sys_execve_witness_fail;

          // Assert: rdx == *(u64 *)(_shell_bin_start + 24) (ELF e_entry)
          lea rcx, [rip + _shell_bin_start];
          mov rax, [rcx + 24];                         // expected entry_rip
          cmp rdx, rax;
          jne sys_execve_witness_fail;

          // Assert: t_a->user_pml4_pa != old_pml4 (swap happened)
          mov rax, [r12 + 16];
          cmp rax, r13;
          je  sys_execve_witness_fail;

          // Assert: t_a->pid unchanged
          mov eax, [r12 + 0];
          cmp eax, r14d;
          jne sys_execve_witness_fail;

          // Assert: t_a->state unchanged
          mov eax, [r12 + 8];
          cmp eax, r15d;
          jne sys_execve_witness_fail;

          // ---------- Sub-test B: invalid ELF, rollback ----------
          // t_b = task_new(NULL) — fresh user_pml4_pa
          xor rdi, rdi;
          call task_new;
          cmp rax, 0;
          je  sys_execve_witness_fail;
          mov r12, rax;                                // r12 = t_b slab

          // Save t_b->user_pml4_pa (old_pml4_b), pid, state
          mov rax, [r12 + 16];
          mov r13, rax;                                // r13 = old_pml4_b
          mov eax, [r12 + 0];
          mov r14d, eax;                               // r14 = t_b->pid
          mov eax, [r12 + 8];
          mov r15d, eax;                               // r15 = t_b->state

          // sys_execve_body(t_b, _bad_elf_stub_start, 64)
          mov rdi, r12;
          lea rsi, [rip + _bad_elf_stub_start];
          mov rdx, 64;
          call sys_execve_body;

          // Assert: rax != 0 (some error code)
          cmp rax, 0;
          je  sys_execve_witness_fail;

          // Assert: rax == 0xFFFFFFFF (ELF_BAD_HDR — magic gate rejected the stub)
          mov rcx, 0xFFFFFFFF;
          cmp rax, rcx;
          jne sys_execve_witness_fail;

          // Assert: t_b->user_pml4_pa == old_pml4_b (unchanged — rollback preserved)
          mov rax, [r12 + 16];
          cmp rax, r13;
          jne sys_execve_witness_fail;

          // Assert: t_b->pid unchanged
          mov eax, [r12 + 0];
          cmp eax, r14d;
          jne sys_execve_witness_fail;

          // Assert: t_b->state unchanged
          mov eax, [r12 + 8];
          cmp eax, r15d;
          jne sys_execve_witness_fail;

          // ---------- All checks green ----------
          lea rdi, [rip + sys_execve_witness_ok_msg];
          call uart_puts;
          jmp sys_execve_witness_exit;

      sys_execve_witness_fail:
          lea rdi, [rip + sys_execve_witness_fail_msg];
          call uart_puts;

      sys_execve_witness_exit:

      // ============================================================
      // R15-M6-007 (#558): orphan_adopt witness — 3-gen cascade, 1 marker
      // ============================================================
      orphan_adoption_witness:
          // ---------- Setup: build A → B → C chain ----------
          // Load pid-1 slab (fake init from task_new_witness) into rdi as A's parent.
          // task_new(parent) sets child->parent_pid = parent->pid, so passing the
          // pid-1 slab makes A->parent_pid = 1. This avoids the parent_pid == 0
          // case (which sys_exit's step-3 guard treats as "init exiting").
          lea rax, [rip + _pid_table];
          mov rdi, [rax + 8];                          // _pid_table[1] (SIB scale-8)
          cmp rdi, 0;
          je  orphan_adoption_witness_fail;            // pid 1 not populated (bug in earlier witness)

          // A = task_new(_pid_table[1])
          call task_new;
          cmp rax, 0;
          je  orphan_adoption_witness_fail;
          mov r12, rax;                                // r12 = A slab

          // B = task_new(A)
          mov rdi, r12;
          call task_new;
          cmp rax, 0;
          je  orphan_adoption_witness_fail;
          mov r13, rax;                                // r13 = B slab

          // C = task_new(B)
          mov rdi, r13;
          call task_new;
          cmp rax, 0;
          je  orphan_adoption_witness_fail;
          mov r14, rax;                                // r14 = C slab

          // ---------- Pre-exit assertions ----------
          // Assert: B->parent_pid == A->pid
          mov eax, [r12 + 0];                          // A->pid
          mov ecx, [r13 + 4];                          // B->parent_pid
          cmp eax, ecx;
          jne orphan_adoption_witness_fail;

          // Assert: C->parent_pid == B->pid
          mov eax, [r13 + 0];                          // B->pid
          mov ecx, [r14 + 4];                          // C->parent_pid
          cmp eax, ecx;
          jne orphan_adoption_witness_fail;

          // ---------- Phase 1: A exits ----------
          // sys_exit_body(A, 0)
          mov rdi, r12;
          xor rsi, rsi;                                 // status = 0
          call sys_exit_body;

          // Assert: A->state == STATE_ZOMBIE (3)
          mov eax, [r12 + 8];
          cmp rax, 3;
          jne orphan_adoption_witness_fail;

          // Assert: B->parent_pid == 1 (adopted)
          mov eax, [r13 + 4];
          cmp rax, 1;
          jne orphan_adoption_witness_fail;

          // Assert: C->parent_pid == B->pid (unchanged — B still alive)
          mov eax, [r13 + 0];                          // B->pid
          mov ecx, [r14 + 4];                          // C->parent_pid
          cmp eax, ecx;
          jne orphan_adoption_witness_fail;

          // ---------- Phase 2: B exits ----------
          // sys_exit_body(B, 0)
          mov rdi, r13;
          xor rsi, rsi;
          call sys_exit_body;

          // Assert: B->state == STATE_ZOMBIE (3)
          mov eax, [r13 + 8];
          cmp rax, 3;
          jne orphan_adoption_witness_fail;

          // Assert: C->parent_pid == 1 (now adopted)
          mov eax, [r14 + 4];
          cmp rax, 1;
          jne orphan_adoption_witness_fail;

          // ---------- All checks green ----------
          lea rdi, [rip + orphan_adoption_witness_ok_msg];
          call uart_puts;
          jmp orphan_adoption_witness_exit;

      orphan_adoption_witness_fail:
          lea rdi, [rip + orphan_adoption_witness_fail_msg];
          call uart_puts;

      orphan_adoption_witness_exit:

      // ============================================================
      // R15-M6-003 (#554): sys_fork witness — testable happy path
      // ============================================================
      sys_fork_witness:
          // ---------- Setup: parent = task_new(NULL) ----------
          xor rdi, rdi;
          call task_new;
          cmp rax, 0;
          je  sys_fork_witness_fail;
          mov rbx, rax;                              // rbx = parent slab

          // Save parent_pid (u32 @ 0) for later comparison
          mov eax, [rbx + 0];
          mov r15d, eax;                             // r15 = parent_pid

          // ---------- Seed parent's fd_table with known values ----------
          mov rax, 0xDEADBEEFCAFEBABE;
          mov [rbx + 192], rax;                      // fd[3] @ 168 + 24
          mov rax, 0x1122334455667788;
          mov [rbx + 208], rax;                      // fd[5] @ 168 + 40
          mov rax, 0xF00DBEEF00000001;
          mov [rbx + 416], rax;                      // fd[31] @ 168 + 248

          // ---------- Act: sys_fork_body(parent) --- empty aspace ---
          mov rdi, rbx;
          call sys_fork_body;

          // ---------- Assertions on returned {rax, rdx} ----------
          // Assert: rax >= 2 (child pid must be a valid allocated slot)
          cmp rax, 2;
          jb  sys_fork_witness_fail;                 // child_pid < 2 → bug

          // Assert: rax != parent_pid
          cmp rax, r15;
          je  sys_fork_witness_fail;

          // Save child_pid for lookup
          mov r12d, eax;                             // r12 = child_pid (zero-ext)

          // Assert: rdx == 0 (reserved slot)
          cmp rdx, 0;
          jne sys_fork_witness_fail;

          // ---------- Look up child via _pid_table[child_pid] ----------
          lea rax, [rip + _pid_table];
          mov r10, [rax + r12*8];                    // r10 = child slab
          cmp r10, 0;
          je  sys_fork_witness_fail;                 // pid_table not published

          // ---------- Assertions on child task_struct ----------
          // Assert: child->pid == child_pid (matches what fork returned)
          mov eax, [r10 + 0];
          cmp eax, r12d;
          jne sys_fork_witness_fail;

          // Assert: child->parent_pid == parent_pid (task_new did this)
          mov eax, [r10 + 4];
          cmp eax, r15d;
          jne sys_fork_witness_fail;

          // Assert: child->state == STATE_NEW (0)
          mov eax, [r10 + 8];
          cmp rax, 0;
          jne sys_fork_witness_fail;

          // Assert: child->user_pml4_pa != parent->user_pml4_pa (fresh aspace)
          mov rax, [rbx + 16];                       // parent_pml4
          mov rcx, [r10 + 16];                       // child_pml4
          cmp rcx, rax;
          je  sys_fork_witness_fail;
          cmp rcx, 0;
          je  sys_fork_witness_fail;                 // must be non-null

          // ---------- Assertions on fd_table copy ----------
          // child.fd[3] == parent.fd[3]
          mov rax, [r10 + 192];                      // fd[3] @ 168 + 24
          mov rcx, 0xDEADBEEFCAFEBABE;
          cmp rax, rcx;
          jne sys_fork_witness_fail;

          // child.fd[5] == parent.fd[5]
          mov rax, [r10 + 208];                      // fd[5] @ 168 + 40
          mov rcx, 0x1122334455667788;
          cmp rax, rcx;
          jne sys_fork_witness_fail;

          // child.fd[31] == parent.fd[31]
          mov rax, [r10 + 416];                      // fd[31] @ 168 + 248
          mov rcx, 0xF00DBEEF00000001;
          cmp rax, rcx;
          jne sys_fork_witness_fail;

          // child.fd[0] == 0 (unused slot, copied zero)
          mov rax, [r10 + 168];                      // fd[0] @ 168
          cmp rax, 0;
          jne sys_fork_witness_fail;

          // ---------- All checks green ----------
          lea rdi, [rip + sys_fork_witness_ok_msg];
          call uart_puts;
          jmp sys_fork_witness_exit;

      sys_fork_witness_fail:
          lea rdi, [rip + sys_fork_witness_fail_msg];
          call uart_puts;

      sys_fork_witness_exit:

      // ============================================================
      // R16-M1-002 (#571): vnode_pool witness — 4 composed sub-tests.
      // bsf_q/bts_q/btr_q register-form bit-scan (see
      // design/kernel/r16-m1-002-vnode-pool.md and
      // src/kernel/core/fs/vnode_pool.pdx justifications for the
      // paideia-as encoder verification that made this possible without
      // any variable-shift / CL idiom).
      // ============================================================

      // --- Sub-test A: initial state -> first alloc returns 1 (slot 0 reserved) ---
      call vnode_alloc;
      cmp  rax, 1;
      jne  vnode_pool_witness_fail;

      // --- Sub-test B: two more allocs return 2 and 3 (distinct, monotone) ---
      call vnode_alloc;
      cmp  rax, 2;
      jne  vnode_pool_witness_fail;
      call vnode_alloc;
      cmp  rax, 3;
      jne  vnode_pool_witness_fail;

      // --- Sub-test C: free middle (slot 2); next alloc returns 2 (bitmap reuse) ---
      mov  rdi, 2;
      call vnode_free;
      call vnode_alloc;
      cmp  rax, 2;
      jne  vnode_pool_witness_fail;

      // --- Sub-test D: fill until OOM.
      //     State entering D: slots {0,1,2,3} allocated; 252 free slots remain.
      //     Loop-alloc must return 0xFFFF after exactly 252 successful allocs.
      //     Guard uses `ja` (strictly-above), not `jae`: r12 == 252 is the
      //     expected in-range terminal count (the 253rd call is the one
      //     that returns OOM) — `jae` would reject the correct count as
      //     "too many" one iteration early (debugger-caught off-by-one). ---
      xor  r12, r12;                              // counter (callee-save; safe — never returns)
      vnode_pool_fill_loop:
          call vnode_alloc;
          cmp  rax, 0xFFFF;
          je   vnode_pool_fill_done;
          add  r12, 1;
          cmp  r12, 252;
          ja   vnode_pool_witness_fail;           // too many allocs before OOM
          jmp  vnode_pool_fill_loop;
      vnode_pool_fill_done:
          cmp  r12, 252;
          jne  vnode_pool_witness_fail;           // wrong free-count on OOM

      // --- All four checks passed. Emit marker. ---
      lea rdi, [rip + vnode_pool_ok_msg];
      call uart_puts;
      jmp  vnode_pool_witness_done;

      vnode_pool_witness_fail:
          lea rdi, [rip + vnode_pool_fail_msg];
          call uart_puts;

      vnode_pool_witness_done:

      // ============================================================
      // R16-M1-003 (#572): vops dispatch witness — 3 composed sub-tests.
      //
      // Storage: _vops_witness_vnode (64 B) + _vops_witness_table (56 B),
      //          both `.bss` from src/kernel/core/fs/vops.pdx.
      // Stub:    _vops_witness_read_stub returns 0xDEADBEEFCAFEBABE.
      //
      // Sub-test A: install stub in table[+0]; install &table in vnode[+24];
      //             vops_read(vn, 0, 0, 0) must return 0xDEADBEEFCAFEBABE.
      // Sub-test B: table[+8] (write slot) is null;
      //             vops_write(vn, 0, 0, 0) must return VOPS_ERR_NOT_SUPPORTED.
      // Sub-test C: zero vnode's ops_ptr (+24);
      //             vops_read(vn, 0, 0, 0) must return VOPS_ERR_NOT_SUPPORTED.
      //
      // See design/kernel/r16-m1-003-vops.md §5 for the full contract.
      // ============================================================

      // --- Zero the witness vnode (8 x 8 = 64 bytes) ---
      lea  rdi, [rip + _vops_witness_vnode];
      xor  rax, rax;
      mov  [rdi + 0],  rax;
      mov  [rdi + 8],  rax;
      mov  [rdi + 16], rax;
      mov  [rdi + 24], rax;
      mov  [rdi + 32], rax;
      mov  [rdi + 40], rax;
      mov  [rdi + 48], rax;
      mov  [rdi + 56], rax;

      // --- Zero the witness vops table (7 x 8 = 56 bytes) ---
      lea  rdi, [rip + _vops_witness_table];
      xor  rax, rax;
      mov  [rdi + 0],  rax;
      mov  [rdi + 8],  rax;
      mov  [rdi + 16], rax;
      mov  [rdi + 24], rax;
      mov  [rdi + 32], rax;
      mov  [rdi + 40], rax;
      mov  [rdi + 48], rax;

      // --- Install stub in read slot (+0) of the table ---
      lea  rax, [rip + _vops_witness_read_stub];
      lea  rdi, [rip + _vops_witness_table];
      mov  [rdi + 0], rax;

      // --- Install &table into vnode's ops_ptr (+24) ---
      lea  rax, [rip + _vops_witness_table];
      lea  rdi, [rip + _vops_witness_vnode];
      mov  [rdi + 24], rax;

      // --- Sub-test A: vops_read → stub's magic constant ---
      lea  rdi, [rip + _vops_witness_vnode];
      xor  rsi, rsi;
      xor  rdx, rdx;
      xor  rcx, rcx;
      call vops_read;
      mov  rcx, 0xDEADBEEFCAFEBABE;
      cmp  rax, rcx;
      jne  vops_witness_fail;

      // --- Sub-test B: vops_write → E_NOT_SUPPORTED (write slot is null) ---
      lea  rdi, [rip + _vops_witness_vnode];
      xor  rsi, rsi;
      xor  rdx, rdx;
      xor  rcx, rcx;
      call vops_write;
      mov  rcx, 0xFFFFFFFFFFFFFFFF;
      cmp  rax, rcx;
      jne  vops_witness_fail;

      // --- Sub-test C: zero vnode.ops_ptr; vops_read → E_NOT_SUPPORTED ---
      lea  rdi, [rip + _vops_witness_vnode];
      xor  rax, rax;
      mov  [rdi + 24], rax;
      lea  rdi, [rip + _vops_witness_vnode];
      xor  rsi, rsi;
      xor  rdx, rdx;
      xor  rcx, rcx;
      call vops_read;
      mov  rcx, 0xFFFFFFFFFFFFFFFF;
      cmp  rax, rcx;
      jne  vops_witness_fail;

      // --- All three checks passed. Emit marker. ---
      lea  rdi, [rip + vops_ok_msg];
      call uart_puts;
      jmp  vops_witness_done;

      vops_witness_fail:
          lea  rdi, [rip + vops_fail_msg];
          call uart_puts;

      vops_witness_done:

      // ============================================================
      // R16-M1-004 (#573): path_resolve witness — 6 sub-tests.
      //
      // Storage: 3 vnodes + witness vops table + lookup stub (all from
      //          src/kernel/core/fs/path.pdx).
      // Fixture: Allocate vnodes 1,2,3 (root, foo, bar). Populate fields.
      //          Install stub at vops_table[+32] (VOPS_LOOKUP_OFFSET).
      //
      // Sub-tests A-F: resolve "/", ".", "..", "/foo/bar", "/nope", "//foo//bar"
      // Marker: "R16 PATH RESOLVE OK" on all green.
      //
      // See design/kernel/r16-m1-004-path-resolver.md §5 for full contract.
      // ============================================================

      // --- Use fixed vnode indices 1, 2, 3 for witness tree ---
      // (vnode_pool witness fills the pool to OOM, so can't allocate new slots here)
      // The witness tree uses indices that are within the valid range but their
      // actual contents will be populated below. Since the pool is zero-initialized,
      // this is sufficient for testing path_resolve logic.
      mov r8, 1;                            // r8 = root vnode idx (1)
      mov r9, 2;                            // r9 = foo vnode idx (2)
      mov r10, 3;                           // r10 = bar vnode idx (3)

      skip_to_vops_setup:

      // --- Zero the witness vops table (7 x 8 = 56 bytes) ---
      lea  rdi, [rip + _path_witness_vops_table];
      xor  rax, rax;
      mov  [rdi + 0],  rax;
      mov  [rdi + 8],  rax;
      mov  [rdi + 16], rax;
      mov  [rdi + 24], rax;
      mov  [rdi + 32], rax;
      mov  [rdi + 40], rax;
      mov  [rdi + 48], rax;

      // --- Install stub in lookup slot (+32 = VOPS_LOOKUP_OFFSET) ---
      lea  rax, [rip + _path_witness_lookup_stub];
      lea  rdi, [rip + _path_witness_vops_table];
      mov  [rdi + 32], rax;

      // --- Populate root vnode (idx=1) ---
      // type (+0) = VNODE_TYPE_DIR = 2
      // parent_idx (+8) = 0xFFFF (root has no parent)
      // ops_ptr (+24) = &_path_witness_vops_table
      mov  rdi, r8;
      call vnode_slot;                      // rax = &vnode[root]
      mov  rdi, rax;                        // rdi = &vnode[root]
      mov  rax, 2;
      mov  [rdi + 0], rax;                  // type = VNODE_TYPE_DIR
      mov  rax, 0xFFFF;
      mov  [rdi + 8], rax;                  // parent_idx = 0xFFFF (write low 16 bits via u64)
      lea  rax, [rip + _path_witness_vops_table];
      mov  [rdi + 24], rax;                 // ops_ptr = table

      // --- Populate foo vnode (idx=2) ---
      // type (+0) = VNODE_TYPE_DIR = 2
      // parent_idx (+8) = 1 (root)
      // ops_ptr (+24) = &_path_witness_vops_table
      mov  rdi, r9;
      call vnode_slot;                      // rax = &vnode[foo]
      mov  rdi, rax;                        // rdi = &vnode[foo]
      mov  rax, 2;
      mov  [rdi + 0], rax;                  // type = VNODE_TYPE_DIR
      mov  rax, 1;
      mov  [rdi + 8], rax;                  // parent_idx = 1 (root)
      lea  rax, [rip + _path_witness_vops_table];
      mov  [rdi + 24], rax;                 // ops_ptr = table

      // --- Populate bar vnode (idx=3) ---
      // type (+0) = VNODE_TYPE_REG = 1
      // parent_idx (+8) = 2 (foo)
      // ops_ptr (+24) = &_path_witness_vops_table
      mov  rdi, r10;
      call vnode_slot;                      // rax = &vnode[bar]
      mov  rdi, rax;                        // rdi = &vnode[bar]
      mov  rax, 1;
      mov  [rdi + 0], rax;                  // type = VNODE_TYPE_REG
      mov  rax, 2;
      mov  [rdi + 8], rax;                  // parent_idx = 2 (foo)
      lea  rax, [rip + _path_witness_vops_table];
      mov  [rdi + 24], rax;                 // ops_ptr = table

      // --- Sub-test A: resolve "/" from root returns root ---
      lea  rdi, [rip + witness_path_slash];  // "/"
      mov  rsi, 1;                           // root_vnode_idx
      xor  rdx, rdx;                         // cwd = 0 (unused for absolute)
      call path_resolve;
      // DEBUG: Check return value
      mov  rcx, 1;
      cmp  rax, rcx;
      jne  path_witness_fail;

      // --- Sub-test B: resolve "." from cwd returns cwd ---
      lea  rdi, [rip + witness_path_dot];    // "."
      mov  rsi, 1;                           // root_vnode_idx (unused)
      mov  rdx, 2;                           // cwd = foo
      call path_resolve;
      cmp  rax, 2;
      jne  path_witness_fail;

      // --- Sub-test C.1: ".." from foo returns root ---
      lea  rdi, [rip + witness_path_dotdot]; // ".."
      mov  rsi, 1;                           // root_vnode_idx (unused)
      mov  rdx, 2;                           // cwd = foo (parent = root = 1)
      call path_resolve;
      cmp  rax, 1;
      jne  path_witness_fail;

      // --- Sub-test C.2: ".." from root stays at root ---
      lea  rdi, [rip + witness_path_dotdot]; // ".."
      mov  rsi, 1;                           // root_vnode_idx (unused)
      mov  rdx, 1;                           // cwd = root (parent_idx = 0xFFFF)
      call path_resolve;
      cmp  rax, 1;
      jne  path_witness_fail;

      // --- Sub-test D: resolve "/foo/bar" walks two components ---
      lea  rdi, [rip + witness_path_foo_bar]; // "/foo/bar"
      mov  rsi, 1;                            // root_vnode_idx
      xor  rdx, rdx;                          // cwd = 0 (unused for absolute)
      call path_resolve;
      cmp  rax, 3;
      jne  path_witness_fail;

      // --- Sub-test E: non-existent component returns 0 ---
      lea  rdi, [rip + witness_path_nope];    // "/nope"
      mov  rsi, 1;                            // root_vnode_idx
      xor  rdx, rdx;                          // cwd = 0 (unused for absolute)
      call path_resolve;
      cmp  rax, 0;
      jne  path_witness_fail;

      // --- Bonus F: "//foo//bar" collapse returns bar (idx=3) ---
      lea  rdi, [rip + witness_path_double_slash]; // "//foo//bar"
      mov  rsi, 1;                            // root_vnode_idx
      xor  rdx, rdx;                          // cwd = 0 (unused for absolute)
      call path_resolve;
      cmp  rax, 3;
      jne  path_witness_fail;

      // --- All checks passed. Emit marker. ---
      lea  rdi, [rip + path_resolve_ok_msg];
      call uart_puts;
      jmp  path_witness_done;

      path_witness_fail:
          lea  rdi, [rip + path_resolve_fail_msg];
          call uart_puts;

      path_witness_done:

      // ============================================================
      // R16-M1-005 (#574): mount_table witness — 4 sub-tests, 1 marker.
      //
      // Storage: 8-entry mount table + 3 primitives (from
      //          src/kernel/core/fs/mount.pdx).
      //
      // Preamble: Free vnode slot 100 to make room for mount()'s vnode_alloc.
      //           (vnode_pool witness fills the pool to OOM as its final step)
      //
      // Sub-test A: _mount_table[0] initially zero
      // Sub-test B: mount("/", TMPFS) succeeds, returns slot idx 0
      // Sub-test C: mount_root_vnode() returns fresh root vnode idx
      // Sub-test D: mount_lookup(root_idx) returns root_idx (self-loop)
      // Marker: "R16 MOUNT TABLE OK" on all green.
      //
      // See design/kernel/r16-m1-005-mount-table.md §6 for full contract.
      // ============================================================

      // --- Preamble: Free slot 100 to make room for mount()'s vnode_alloc ---
      mov  rdi, 100;
      call vnode_free;

      // --- Sub-test A: _mount_table[0] initially zero ---
      lea  rax, [rip + _mount_table];
      mov  rax, [rax];
      cmp  rax, 0;
      jne  mount_witness_fail;

      // --- Sub-test B: mount("/", TMPFS) returns slot 0 ---
      lea  rdi, [rip + witness_path_slash];   // "/" (reused from #573)
      mov  rsi, 1;                            // MOUNT_BACKEND_TMPFS
      call mount;
      cmp  rax, 0;                            // MOUNT_ROOT_SLOT
      jne  mount_witness_fail;

      // --- Sub-test C: mount_root_vnode() returns fresh root vnode idx ---
      call mount_root_vnode;
      mov  r12, rax;                          // save for sub-test D
      cmp  rax, 0;
      je   mount_witness_fail;                // must be a real vnode idx
      cmp  rax, 0xFFFF;
      je   mount_witness_fail;                // not the OOM sentinel

      // Verify it equals _mount_table[0].root_idx directly
      lea  rax, [rip + _mount_table];
      mov  rax, [rax];
      shr  rax, 16;
      and  rax, 0xFFFF;
      cmp  rax, r12;
      jne  mount_witness_fail;

      // --- Sub-test D: mount_lookup(root_idx) returns root_idx (self-loop) ---
      mov  rdi, r12;
      call mount_lookup;
      cmp  rax, r12;
      jne  mount_witness_fail;

      // --- All checks passed. Emit marker. ---
      lea  rdi, [rip + mount_table_ok_msg];
      call uart_puts;
      jmp  mount_witness_done;

      mount_witness_fail:
          lea  rdi, [rip + mount_table_fail_msg];
          call uart_puts;

      mount_witness_done:

      // ============================================================
      // R16-M1-006 (#575): vfs_open witness — 4 sub-tests, 1 marker.
      //
      // Preamble: mount is already done by #574 witness with fresh root
      //           vnode at index N.
      //
      // Sub-test A: rax = vfs_open("/", 0). Expect rax != 0 (root vnode found).
      // Sub-test B: vnode_slot(rax).refcount now 1 (was 0 after mount — mount()
      //             never writes the refcount field; vfs_open is the first ++).
      // Sub-test C: rax = vfs_open("/nonexistent", 0). Expect rax == 0.
      // Sub-test D: rax = vfs_open("/nonexistent", 0x40). For R16.M1, expect
      //            rax == 0 (real create in R16.M2). O_CREAT path is REACHED.
      // Marker: "R16 VFS OPEN OK" on A, B, C pass.
      //
      // See design/kernel/r16-m1-006-vfs-open.md §4 for full contract.
      // ============================================================

      // --- Sub-test A: vfs_open("/", 0) must return non-zero ---
      lea  rdi, [rip + witness_path_slash];    // "/"
      xor  rsi, rsi;                           // flags = 0
      call vfs_open;
      cmp  rax, 0;
      je   vfs_open_witness_fail;
      mov  r12, rax;                           // save root vnode idx for sub-test B

      // --- Sub-test B: vnode_slot(rax).refcount now 1 (was 0 after mount, inc by vfs_open) ---
      mov  rdi, rax;
      call vnode_slot;                         // rax = &vnode
      xor  rcx, rcx;
      mov_w rcx, [rax + 4];                    // load refcount (u16 at +4)
      cmp  rcx, 1;                             // expect refcount == 1
      jne  vfs_open_witness_fail;

      // --- Sub-test C: vfs_open("/nonexistent", 0) must return 0 ---
      lea  rdi, [rip + witness_path_nope];     // "/nope"
      xor  rsi, rsi;                           // flags = 0
      call vfs_open;
      cmp  rax, 0;
      jne  vfs_open_witness_fail;              // expect 0 for non-existent path

      // --- Sub-test D: vfs_open("/nonexistent", 0x40) exercises O_CREAT path ---
      lea  rdi, [rip + witness_path_nope];     // "/nope"
      mov  rsi, 0x40;                          // flags = O_CREAT
      call vfs_open;
      // For R16.M1, O_CREAT returns 0 (stub). Real create in R16.M2.
      // Sub-test D just checks that the flag-check branch is REACHED;
      // any return value acceptable per design §4.7.

      // --- All checks passed. Emit marker. ---
      lea  rdi, [rip + vfs_open_ok_msg];
      call uart_puts;
      jmp  vfs_open_witness_done;

      vfs_open_witness_fail:
          lea  rdi, [rip + vfs_open_fail_msg];
          call uart_puts;

      vfs_open_witness_done:

      // ============================================================
      // R16-M1-007 (#576): vfs_close witness — 2 sub-tests, 1 marker.
      //
      // Preamble: root vnode is at index N with refcount = 1 (left there by
      //           #575 sub-test A, which did vfs_open("/", 0) then never closed).
      //
      // Sub-test A: refcount transitions + conditional vops_close.
      //   1. vfs_open("/", 0) → refcount now 2.
      //   2. Load refcount; assert == 2.
      //   3. vfs_close(N) → returns 0, refcount now 1. vops_close NOT called.
      //   4. Load refcount; assert == 1.
      //   5. vfs_close(N) → returns 0, refcount now 0. vops_close IS called;
      //      null ops_ptr returns ERR sentinel (ignored).
      //   6. Load refcount; assert == 0.
      //
      // Sub-test B: invalid idx rejection.
      //   1. vfs_close(0) → assert rax == 0xFFFFFFFFFFFFFFFF.
      //   2. vfs_close(0xFFFF) → assert rax == 0xFFFFFFFFFFFFFFFF.
      //
      // Marker: "R16 VFS CLOSE OK" on A + B pass.
      //
      // See design/kernel/r16-m1-007-vfs-close.md for full contract.
      // ============================================================

      // --- Sub-test A, step 1: vfs_open("/", 0) (refcount will be 2) ---
      lea  rdi, [rip + witness_path_slash];     // "/"
      xor  rsi, rsi;                            // flags = 0
      call vfs_open;
      cmp  rax, 0;
      je   vfs_close_witness_fail;
      mov  r12, rax;                            // r12 = root vnode idx

      // --- Sub-test A, step 2: Load refcount, assert == 2 ---
      mov  rdi, r12;
      call vnode_slot;                          // rax = &vnode
      xor  rcx, rcx;
      mov_w rcx, [rax + 4];                     // rcx = refcount (u16)
      cmp  rcx, 2;                              // expect refcount == 2 (1 from mount + 1 from vfs_open)
      jne  vfs_close_witness_fail;

      // --- Sub-test A, step 3: vfs_close(r12) → refcount now 1 ---
      mov  rdi, r12;
      call vfs_close;
      cmp  rax, 0;                              // expect success (return 0)
      jne  vfs_close_witness_fail;

      // --- Sub-test A, step 4: Load refcount, assert == 1 ---
      mov  rdi, r12;
      call vnode_slot;                          // rax = &vnode
      xor  rcx, rcx;
      mov_w rcx, [rax + 4];                     // rcx = refcount
      cmp  rcx, 1;                              // expect refcount == 1 (vops_close NOT called)
      jne  vfs_close_witness_fail;

      // --- Sub-test A, step 5: vfs_close(r12) → refcount now 0, vops_close IS called ---
      mov  rdi, r12;
      call vfs_close;
      cmp  rax, 0;                              // expect success (return 0)
      jne  vfs_close_witness_fail;

      // --- Sub-test A, step 6: Load refcount, assert == 0 ---
      mov  rdi, r12;
      call vnode_slot;                          // rax = &vnode
      xor  rcx, rcx;
      mov_w rcx, [rax + 4];                     // rcx = refcount
      cmp  rcx, 0;                              // expect refcount == 0 (vops_close was called)
      jne  vfs_close_witness_fail;

      // --- Sub-test B, step 1: vfs_close(0) returns error sentinel ---
      xor  rdi, rdi;                            // rdi = 0
      call vfs_close;
      cmp  rax, 0xFFFFFFFFFFFFFFFF;             // expect error sentinel
      jne  vfs_close_witness_fail;

      // --- Sub-test B, step 2: vfs_close(0xFFFF) returns error sentinel ---
      mov  rdi, 0xFFFF;
      call vfs_close;
      cmp  rax, 0xFFFFFFFFFFFFFFFF;             // expect error sentinel (0xFFFF >= 256)
      jne  vfs_close_witness_fail;

      // --- All checks passed. Emit marker. ---
      lea  rdi, [rip + vfs_close_ok_msg];
      call uart_puts;
      jmp  vfs_close_witness_done;

      vfs_close_witness_fail:
          lea  rdi, [rip + vfs_close_fail_msg];
          call uart_puts;

      vfs_close_witness_done:

      // ============================================================
      // R16-M1-008 (#577): vfs_read/vfs_write witness — 3 sub-tests, 1 marker.
      //
      // Preamble: the vnode pool is fully allocated at this point in boot
      //           (the #571 vnode_pool witness fills all 256 slots to OOM;
      //           the #574 mount witness frees slot 100 and mount_root_vnode()
      //           immediately reclaims it, leaving the pool at OOM again).
      //           Free slot 200 so this witness's vnode_alloc has a bit to
      //           find. Slot 200 was only ever touched by the #571 fill-loop
      //           (which just sets its bitmap bit — vnode_alloc never writes
      //           slot storage), so its 64 bytes are still zero from the
      //           .bss uninit; freeing it recycles the bitmap bit without
      //           disturbing any live vnode (root vnode lives at slot 100).
      //
      // Sub-test A: install the RW witness stub as ops_ptr(read+write);
      //             vfs_read(idx,0,0,0) forwards the stub's rax == 42.
      // Sub-test B: vfs_write(idx,0,0,0) forwards the same stub's rax == 42.
      // Sub-test C: zero ops_ptr; vfs_read(idx,0,0,0) returns the
      //             VOPS_ERR_NOT_SUPPORTED sentinel (0xFFFFFFFFFFFFFFFF).
      //
      // Marker: "R16 VFS READ WRITE OK" on A + B + C pass.
      //
      // See design/kernel/r16-m1-008-vfs-read-write.md §Witness for the
      // full contract.
      // ============================================================

      // --- Preamble: free slot 200 to make room for this witness's vnode_alloc ---
      mov  rdi, 200;
      call vnode_free;

      // --- Fixture: allocate witness vnode, resolve pointer ---
      call vnode_alloc;
      cmp  rax, 0;
      je   vfs_rw_witness_fail;                 // must not be the reserved sentinel
      cmp  rax, 0xFFFF;
      je   vfs_rw_witness_fail;                 // must not be the OOM sentinel
      mov  r12, rax;                             // r12 = witness vnode idx

      mov  rdi, r12;
      call vnode_slot;                           // rax = &vnode[idx]
      mov  r13, rax;                             // r13 = witness vnode ptr

      // --- Zero the 64-byte slot (belt-and-braces per design §Witness step 4) ---
      xor  rax, rax;
      mov  [r13 + 0],  rax;
      mov  [r13 + 8],  rax;
      mov  [r13 + 16], rax;
      mov  [r13 + 24], rax;
      mov  [r13 + 32], rax;
      mov  [r13 + 40], rax;
      mov  [r13 + 48], rax;
      mov  [r13 + 56], rax;

      // --- Install witness ops table pointer at vnode + 24 (ops_ptr) ---
      lea  rax, [rip + _vops_witness_table];
      mov  [r13 + 24], rax;

      // --- Install the RW stub at table+0 (read slot) and table+8 (write slot) ---
      lea  rax, [rip + _vops_witness_rw_stub];
      lea  rcx, [rip + _vops_witness_table];
      mov  [rcx + 0], rax;
      mov  [rcx + 8], rax;

      // --- Sub-test A: vfs_read(idx, 0, 0, 0) forwards stub's rax == 42 ---
      mov  rdi, r12;
      xor  rsi, rsi;
      xor  rdx, rdx;
      xor  rcx, rcx;
      call vfs_read;
      cmp  rax, 42;
      jne  vfs_rw_witness_fail;

      // --- Sub-test B: vfs_write(idx, 0, 0, 0) forwards stub's rax == 42 ---
      mov  rdi, r12;
      xor  rsi, rsi;
      xor  rdx, rdx;
      xor  rcx, rcx;
      call vfs_write;
      cmp  rax, 42;
      jne  vfs_rw_witness_fail;

      // --- Sub-test C: zero ops_ptr; vfs_read returns error sentinel ---
      xor  rax, rax;
      mov  [r13 + 24], rax;

      mov  rdi, r12;
      xor  rsi, rsi;
      xor  rdx, rdx;
      xor  rcx, rcx;
      call vfs_read;
      cmp  rax, 0xFFFFFFFFFFFFFFFF;
      jne  vfs_rw_witness_fail;

      // --- All checks passed. Emit marker. ---
      lea  rdi, [rip + vfs_rw_ok_msg];
      call uart_puts;
      jmp  vfs_rw_witness_done;

      vfs_rw_witness_fail:
          lea  rdi, [rip + vfs_rw_fail_msg];
          call uart_puts;

      vfs_rw_witness_done:

      // R16-M1-001 (#578): Emit VFS OK marker (R16.M1 integration checkpoint)
      lea  rdi, [rip + vfs_ok_msg];
      call uart_puts;

      // ============================================================
      // R16-M2-001 (#579): tmpfs inode pool witness — 3 sub-tests, 1 marker
      // ============================================================
      tmpfs_inode_pool_witness:
          // ---------- Sub-test A: bitmap slot-0 sentinel is set ----------
          mov rax, [rip + _tmpfs_inode_bitmap];
          and rax, 1;
          cmp rax, 1;
          jne tmpfs_inode_pool_witness_fail;

          // ---------- Sub-test B: slot 0's type is FREE (0) ----------
          lea rax, [rip + _tmpfs_inode_pool];
          mov rcx, [rax + 0];               // load full qword at slot 0 offset 0
          and rcx, 0xFF;                    // extract type byte (offset 0)
          cmp rcx, 0;                       // VNODE_TYPE_FREE
          jne tmpfs_inode_pool_witness_fail;

          // ---------- Sub-test C: slot 63 is addressable via shl 8 indexing ----------
          mov rdi, 63;
          call tmpfs_inode_slot;            // rax = &_tmpfs_inode_pool[63]
          mov rcx, [rax + 0];               // load full qword at slot 63 offset 0
          and rcx, 0xFF;                    // extract type byte (offset 0)
          cmp rcx, 0;                       // VNODE_TYPE_FREE
          jne tmpfs_inode_pool_witness_fail;

          // ---------- All checks passed. Emit marker. ----------
          lea rdi, [rip + tmpfs_inode_pool_ok_msg];
          call uart_puts;
          jmp tmpfs_inode_pool_witness_done;

      tmpfs_inode_pool_witness_fail:
          lea rdi, [rip + tmpfs_inode_pool_fail_msg];
          call uart_puts;

      tmpfs_inode_pool_witness_done:

      // ============================================================
      // R16-M2-002 (#580): tmpfs_init witness — 4 sub-tests, 1 marker
      // ============================================================
      tmpfs_init_witness:
          // ---------- Sub-test A: tmpfs_init returns a non-zero root idx ----------
          call tmpfs_init;
          mov r12, rax;                       // save root_idx for sub-tests B-D
          cmp rax, 0;
          je tmpfs_init_witness_fail;
          cmp rax, 0xFFFF;                    // alloc OOM sentinel
          je tmpfs_init_witness_fail;

          // ---------- Sub-test B: root inode type==DIR, first_child!=0 ----------
          mov rdi, r12;                       // root_idx
          call tmpfs_inode_slot;              // rax = &root_inode
          mov r13, rax;

          // type byte at +0 must be VNODE_TYPE_DIR = 2
          mov rcx, [r13 + 0];                 // load u64 at +0
          and rcx, 0xFF;                      // extract type byte
          cmp rcx, 2;
          jne tmpfs_init_witness_fail;

          // first_child at +180 (u16) must be non-zero (a real /tmp idx)
          mov rcx, [r13 + 176];               // load u64 at +176 covering
                                              // parent_idx / next_sib / first_child / pad
          shr rcx, 32;                        // first_child at bits [32, 48)
          and rcx, 0xFFFF;
          cmp rcx, 0;
          je tmpfs_init_witness_fail;
          cmp rcx, 0xFFFF;
          je tmpfs_init_witness_fail;         // must not be the empty sentinel
          mov r14, rcx;                       // r14 = tmp_idx for sub-tests C-D

          // ---------- Sub-test C: /tmp inode type==DIR, parent_idx==root_idx ----------
          mov rdi, r14;                       // tmp_idx
          call tmpfs_inode_slot;              // rax = &tmp_inode
          mov r13, rax;

          // type byte at +0 must be VNODE_TYPE_DIR = 2
          mov rcx, [r13 + 0];
          and rcx, 0xFF;
          cmp rcx, 2;
          jne tmpfs_init_witness_fail;

          // parent_idx at +176 (u16) must equal root_idx (r12)
          mov rcx, [r13 + 176];
          and rcx, 0xFFFF;                    // extract parent_idx (bits [0, 16))
          cmp rcx, r12;
          jne tmpfs_init_witness_fail;

          // ---------- Sub-test D: /tmp name field == "tmp\0" ----------
          // name[0..8] as u64: byte layout expected is
          //   { 0x74('t'), 0x6D('m'), 0x70('p'), 0x00, 0x00, 0x00, 0x00, 0x00 }
          //   = little-endian u64 0x0000000000706D74
          mov rcx, [r13 + 144];               // load u64 at name[0..8]
          mov rdx, 0x706D74;                  // expected 'tmp\0' + zero pad
          cmp rcx, rdx;
          jne tmpfs_init_witness_fail;

          // ---------- All checks passed. Emit marker. ----------
          lea rdi, [rip + tmpfs_init_ok_msg];
          call uart_puts;
          jmp tmpfs_init_witness_done;

      tmpfs_init_witness_fail:
          lea rdi, [rip + tmpfs_init_fail_msg];
          call uart_puts;

      tmpfs_init_witness_done:

      // ============================================================
      // R16-M2-003 (#581): tmpfs_lookup witness — 3 sub-tests, 1 marker
      // ============================================================
      tmpfs_lookup_witness:
          // ---------- Sub-test A: hit — tmpfs_lookup(root, "tmp") returns /tmp idx ----------
          mov  r12, 1                          // root_idx = TMPFS_INODE_IDX_ROOT
          lea  rsi, [rip + witness_name_tmp]   // name = "tmp\0"
          mov  rdi, r12
          call tmpfs_lookup
          cmp  rax, 0
          je   tmpfs_lookup_witness_fail       // miss where hit was expected
          cmp  rax, 0xFFFF
          je   tmpfs_lookup_witness_fail       // sentinel — shouldn't happen
          mov  r13, rax                        // r13 = tmp_idx (for cross-check)

          // Cross-check: returned idx must be a DIR inode whose name = "tmp\0"
          mov  rdi, r13
          call tmpfs_inode_slot                // rax = &tmp_inode
          mov  rcx, [rax + 144]                // load name[0..8] as u64
          mov  rdx, 0x706D74                   // expected 'tmp\0' + zero pad
          cmp  rcx, rdx
          jne  tmpfs_lookup_witness_fail

          // ---------- Sub-test B: miss — tmpfs_lookup(root, "missing") returns 0 ----------
          lea  rsi, [rip + witness_name_missing]  // name = "missing\0"
          mov  rdi, 1                             // root_idx
          call tmpfs_lookup
          cmp  rax, 0
          jne  tmpfs_lookup_witness_fail          // miss expected → non-zero is wrong

          // ---------- Sub-test C: not-a-dir — set slot 63 type=REG, lookup returns 0 ----------
          // Set up slot 63 as a non-DIR (REG) scratch inode
          mov  rdi, 63
          call tmpfs_inode_slot                // rax = &_tmpfs_inode_pool[63]
          mov  r13, rax
          mov  rcx, 1                          // VNODE_TYPE_REG (non-DIR)
          mov_b [r13 + 0], rcx

          // Lookup on the non-DIR inode
          lea  rsi, [rip + witness_name_any]   // any name — should not matter
          mov  rdi, 63                         // non-DIR inode idx
          call tmpfs_lookup
          cmp  rax, 0
          jne  tmpfs_lookup_witness_fail       // type-gate should have short-circuited

          // Restore slot 63 to FREE (leave no state behind)
          mov  rdi, 63
          call tmpfs_inode_slot                // rax = &pool[63]
          mov  r13, rax
          xor  rcx, rcx
          mov_b [r13 + 0], rcx                 // type = VNODE_TYPE_FREE

          // All checks passed. Emit marker.
          lea  rdi, [rip + tmpfs_lookup_ok_msg]
          call uart_puts
          jmp  tmpfs_lookup_witness_done

      tmpfs_lookup_witness_fail:
          lea  rdi, [rip + tmpfs_lookup_fail_msg]
          call uart_puts

      tmpfs_lookup_witness_done:

      // ============================================================
      // R16-M2-004 (#582): tmpfs_create witness — 4 sub-tests, 1 marker
      // ============================================================
      tmpfs_create_witness:

          // ---------- Sub-test A: create returns non-zero new_idx ----------
          // Recover tmp_idx via tmpfs_lookup on root (proven working at this
          // boot point by the tmpfs_lookup witness immediately above).
          mov  rdi, 1                             // root_idx = TMPFS_INODE_IDX_ROOT
          lea  rsi, [rip + witness_name_tmp]      // name = "tmp\0"
          call tmpfs_lookup
          cmp  rax, 0
          je   tmpfs_create_witness_fail          // can't proceed — /tmp missing
          mov  r12, rax                           // r12 = tmp_idx (for later cross-checks)

          // tmpfs_create(tmp_idx, "x", 1, REG=1)
          mov  rdi, r12                           // dir_idx = tmp_idx
          lea  rsi, [rip + witness_name_any]      // name_ptr = "x\0"
          mov  rdx, 1                             // name_len = 1 (just 'x')
          mov  rcx, 1                             // type = VNODE_TYPE_REG
          call tmpfs_create
          cmp  rax, 0
          je   tmpfs_create_witness_fail          // expected non-zero new_idx
          cmp  rax, 0xFFFF
          je   tmpfs_create_witness_fail          // alloc-OOM sentinel — shouldn't happen
          mov  r13, rax                           // r13 = new_idx (for cross-checks)

          // ---------- Sub-test B: lookup returns the created idx ----------
          // The whole point of tmpfs_create's acceptance criterion:
          // "create /tmp/x; subsequent lookup returns it."
          mov  rdi, r12                           // tmp_idx
          lea  rsi, [rip + witness_name_any]      // "x\0"
          call tmpfs_lookup
          cmp  rax, r13                           // expect returned idx == new_idx
          jne  tmpfs_create_witness_fail

          // ---------- Sub-test C: /tmp.first_child == new_idx ----------
          // Load /tmp's u64 @+176; extract first_child from bits [32, 48)
          mov  rdi, r12                           // tmp_idx
          call tmpfs_inode_slot                   // rax = &tmp_inode
          mov  rcx, [rax + 176]
          shr  rcx, 32
          and  rcx, 0xFFFF                        // rcx = tmp.first_child
          cmp  rcx, r13                           // expect == new_idx
          jne  tmpfs_create_witness_fail

          // ---------- Sub-test D: new inode fields are correctly populated ----------
          // Get new_ptr
          mov  rdi, r13                           // new_idx
          call tmpfs_inode_slot                   // rax = &new_inode
          mov  r14, rax                           // r14 = new_ptr

          // Check type == VNODE_TYPE_REG (1)
          xor  rcx, rcx
          mov_b rcx, [r14 + 0]
          cmp  rcx, 1
          jne  tmpfs_create_witness_fail

          // Check parent_idx == tmp_idx: extract from bits [0, 16) of u64 @+176
          mov  rcx, [r14 + 176]
          and  rcx, 0xFFFF
          cmp  rcx, r12                           // expect == tmp_idx
          jne  tmpfs_create_witness_fail

          // Check name field: u64 @+144 == 0x78 ('x' + 7 zero pad bytes)
          mov  rcx, [r14 + 144]
          mov  rdx, 0x78                          // expected: 'x' at byte 0, zeros elsewhere
          cmp  rcx, rdx
          jne  tmpfs_create_witness_fail

          // All checks passed. Emit marker.
          lea  rdi, [rip + tmpfs_create_ok_msg]
          call uart_puts
          jmp  tmpfs_create_witness_done

      tmpfs_create_witness_fail:
          lea  rdi, [rip + tmpfs_create_fail_msg]
          call uart_puts

      tmpfs_create_witness_done:

      // ============================================================
      // R16-M2-005 (#583): tmpfs_write witness — 4 sub-tests, 1 marker
      // ============================================================
      tmpfs_write_witness:
          // ---------- Preamble: recover tmp_idx, x_idx ----------
          mov  rdi, 1                             // root_idx = TMPFS_INODE_IDX_ROOT
          lea  rsi, [rip + witness_name_tmp]      // "tmp\0"
          call tmpfs_lookup
          cmp  rax, 0
          je   tmpfs_write_witness_fail
          mov  r12, rax                           // r12 = tmp_idx

          mov  rdi, r12                           // tmp_idx
          lea  rsi, [rip + witness_name_any]      // "x\0"
          call tmpfs_lookup
          cmp  rax, 0
          je   tmpfs_write_witness_fail
          mov  r13, rax                           // r13 = x_idx (target of the write)

          // ---------- Sub-test A: tmpfs_write returns 100 ----------
          mov  rdi, r13                           // x_idx
          lea  rsi, [rip + tmpfs_write_src_buf]   // buf_ptr = &src[0]
          mov  rdx, 100                           // len = 100
          xor  rcx, rcx                           // offset = 0
          call tmpfs_write
          cmp  rax, 100
          jne  tmpfs_write_witness_fail

          // ---------- Sub-test B: inode.size == 100 ----------
          mov  rdi, r13                           // x_idx
          call tmpfs_inode_slot                   // rax = &x_inode
          mov  r14, rax                           // r14 = x_inode_ptr
          mov  rcx, [r14 + 8]                     // rcx = inode.size
          cmp  rcx, 100
          jne  tmpfs_write_witness_fail

          // ---------- Sub-test C: inode.page_ptrs[0] != 0 ----------
          mov  rcx, [r14 + 16]                    // rcx = page_ptrs[0]
          cmp  rcx, 0
          je   tmpfs_write_witness_fail
          mov  r15, rcx                           // r15 = page_va (for sub-test D)

          // ---------- Sub-test D: content match (u64 @page_va == 0x4141414141414141) ----------
          mov  rcx, [r15]                         // rcx = u64 at page start
          mov  rdx, 0x4141414141414141            // expected: 8 x 'A'
          cmp  rcx, rdx
          jne  tmpfs_write_witness_fail

          lea  rdi, [rip + tmpfs_write_ok_msg]
          call uart_puts
          jmp  tmpfs_write_witness_done

      tmpfs_write_witness_fail:
          lea  rdi, [rip + tmpfs_write_fail_msg]
          call uart_puts

      tmpfs_write_witness_done:

      // ============================================================
      // R16-M2-006 (#584): tmpfs_read witness — 4 sub-tests, 1 marker
      // ============================================================
      tmpfs_read_witness:
          // ---------- Preamble: recover tmp_idx, x_idx ----------
          mov  rdi, 1                             // root_idx = TMPFS_INODE_IDX_ROOT
          lea  rsi, [rip + witness_name_tmp]      // "tmp\0"
          call tmpfs_lookup
          cmp  rax, 0
          je   tmpfs_read_witness_fail
          mov  r12, rax                           // r12 = tmp_idx

          mov  rdi, r12                           // tmp_idx
          lea  rsi, [rip + witness_name_any]      // "x\0"
          call tmpfs_lookup
          cmp  rax, 0
          je   tmpfs_read_witness_fail
          mov  r13, rax                           // r13 = x_idx (source of the reads)

          // ---------- Sub-test A: tmpfs_read(x_idx, dst_buf, 100, 0) → expect rax = 100 ----------
          mov  rdi, r13                           // x_idx
          lea  rsi, [rip + tmpfs_read_dst_buf]    // buf_ptr = &dst[0]
          mov  rdx, 100                           // len = 100
          xor  rcx, rcx                           // offset = 0
          call tmpfs_read
          cmp  rax, 100
          jne  tmpfs_read_witness_fail

          // ---------- Sub-test B: dst_buf content = 8 x 'A' (0x4141414141414141) ----------
          lea  r14, [rip + tmpfs_read_dst_buf]
          mov  rcx, [r14]                         // rcx = u64 at dst_buf[0]
          mov  rdx, 0x4141414141414141            // expected: 8 x 'A'
          cmp  rcx, rdx
          jne  tmpfs_read_witness_fail

          // ---------- Sub-test C: tmpfs_read(x_idx, dst_buf, 10, 100) → expect rax = 0 (EOF) ----------
          mov  rdi, r13                           // x_idx
          lea  rsi, [rip + tmpfs_read_dst_buf]    // buf_ptr
          mov  rdx, 10                            // len = 10
          mov  rcx, 100                           // offset = 100 (== size)
          call tmpfs_read
          cmp  rax, 0
          jne  tmpfs_read_witness_fail

          // ---------- Sub-test D: tmpfs_read(x_idx, dst_buf, 100, 50) → expect rax = 50 (clamped) ----------
          mov  rdi, r13                           // x_idx
          lea  rsi, [rip + tmpfs_read_dst_buf]    // buf_ptr
          mov  rdx, 100                           // len = 100 (requested)
          mov  rcx, 50                            // offset = 50
          call tmpfs_read
          cmp  rax, 50                            // expect clamp to size - offset
          jne  tmpfs_read_witness_fail

          lea  rdi, [rip + tmpfs_read_ok_msg]
          call uart_puts
          jmp  tmpfs_read_witness_done

      tmpfs_read_witness_fail:
          lea  rdi, [rip + tmpfs_read_fail_msg]
          call uart_puts

      tmpfs_read_witness_done:

      // ============================================================
      // R16-M2-007 (#585): tmpfs_unlink witness — 4 sub-tests, 1 marker
      // ============================================================
      tmpfs_unlink_witness:
          // ---------- Preamble: recover tmp_idx, snapshot x_idx ----------
          // Recover tmp_idx via tmpfs_lookup on root
          mov  rdi, 1                             // root_idx = TMPFS_INODE_IDX_ROOT
          lea  rsi, [rip + witness_name_tmp]      // "tmp\0"
          call tmpfs_lookup
          cmp  rax, 0
          je   tmpfs_unlink_witness_fail
          mov  r12, rax                           // r12 = tmp_idx

          // Save x_idx BEFORE unlink for sub-test D bitmap check
          mov  rdi, r12                           // tmp_idx
          lea  rsi, [rip + witness_name_any]      // "x\0"
          call tmpfs_lookup
          cmp  rax, 0
          je   tmpfs_unlink_witness_fail
          mov  r13, rax                           // r13 = x_idx (pre-unlink snapshot)

          // ---------- Sub-test A: unlink returns 0 ----------
          // tmpfs_unlink(tmp_idx, "x") — expect rax = 0
          mov  rdi, r12
          lea  rsi, [rip + witness_name_any]
          call tmpfs_unlink
          cmp  rax, 0
          jne  tmpfs_unlink_witness_fail

          // ---------- Sub-test B: lookup misses ----------
          // Post-unlink lookup should miss
          mov  rdi, r12                           // tmp_idx
          lea  rsi, [rip + witness_name_any]      // "x\0"
          call tmpfs_lookup
          cmp  rax, 0
          jne  tmpfs_unlink_witness_fail          // expected miss

          // ---------- Sub-test C: /tmp.first_child == 0xFFFF ----------
          // Load /tmp's u64 @+176; extract first_child from bits [32, 48)
          mov  rdi, r12                           // tmp_idx
          call tmpfs_inode_slot                   // rax = &tmp_inode
          mov  rcx, [rax + 176]
          shr  rcx, 32
          and  rcx, 0xFFFF                        // rcx = tmp.first_child
          mov  rdx, 0xFFFF
          cmp  rcx, rdx
          jne  tmpfs_unlink_witness_fail          // expected empty-chain sentinel

          // ---------- Sub-test D: bitmap bit for x_idx is now 0 ----------
          // Verify _tmpfs_inode_bitmap[0] bit (r13 = x_idx) is 0
          lea  rax, [rip + _tmpfs_inode_bitmap]
          mov  r8, [rax]                          // bitmap word
          mov  rcx, r13                           // shift count = x_idx
          mov  rdx, 1
          shl  rdx, cl                            // rdx = 1 << x_idx
          and  r8, rdx                            // isolate bit
          cmp  r8, 0                              // must be zero (bit cleared)
          jne  tmpfs_unlink_witness_fail

          lea  rdi, [rip + tmpfs_unlink_ok_msg]
          call uart_puts
          jmp  tmpfs_unlink_witness_done

      tmpfs_unlink_witness_fail:
          lea  rdi, [rip + tmpfs_unlink_fail_msg]
          call uart_puts

      tmpfs_unlink_witness_done:

      // ============================================================
      // R16-M2-008 (#586): tmpfs vops table wire-up
      // ============================================================
      // Populate _tmpfs_vops with 7 adapter/stub pointers and verify
      // table integrity via pointer-identity checks + end-to-end dispatch.

      call tmpfs_vops_init                   // populates 7 slots

      // ---------- Sub-test A: read slot pointer identity ----------
      lea  rax, [rip + _tmpfs_vops]
      mov  rcx, [rax + 0]                    // VOPS_READ_OFFSET
      lea  rdx, [rip + _tmpfs_read_adapter]
      cmp  rcx, rdx
      jne  tmpfs_vops_witness_fail

      // ---------- Sub-test B: write slot pointer identity ----------
      lea  rax, [rip + _tmpfs_vops]
      mov  rcx, [rax + 8]                    // VOPS_WRITE_OFFSET
      lea  rdx, [rip + _tmpfs_write_adapter]
      cmp  rcx, rdx
      jne  tmpfs_vops_witness_fail

      // ---------- Sub-test C: open slot pointer identity ----------
      lea  rax, [rip + _tmpfs_vops]
      mov  rcx, [rax + 16]                   // VOPS_OPEN_OFFSET
      lea  rdx, [rip + _tmpfs_open_stub]
      cmp  rcx, rdx
      jne  tmpfs_vops_witness_fail

      // ---------- Sub-test D: close slot pointer identity ----------
      lea  rax, [rip + _tmpfs_vops]
      mov  rcx, [rax + 24]                   // VOPS_CLOSE_OFFSET
      lea  rdx, [rip + _tmpfs_close_stub]
      cmp  rcx, rdx
      jne  tmpfs_vops_witness_fail

      // ---------- Sub-test E: lookup slot pointer identity ----------
      lea  rax, [rip + _tmpfs_vops]
      mov  rcx, [rax + 32]                   // VOPS_LOOKUP_OFFSET
      lea  rdx, [rip + _tmpfs_lookup_adapter]
      cmp  rcx, rdx
      jne  tmpfs_vops_witness_fail

      // ---------- Sub-test F: create slot pointer identity ----------
      lea  rax, [rip + _tmpfs_vops]
      mov  rcx, [rax + 40]                   // VOPS_CREATE_OFFSET
      lea  rdx, [rip + _tmpfs_create_adapter]
      cmp  rcx, rdx
      jne  tmpfs_vops_witness_fail

      // ---------- Sub-test G: unlink slot pointer identity ----------
      lea  rax, [rip + _tmpfs_vops]
      mov  rcx, [rax + 48]                   // VOPS_UNLINK_OFFSET
      lea  rdx, [rip + _tmpfs_unlink_adapter]
      cmp  rcx, rdx
      jne  tmpfs_vops_witness_fail

      // ---------- Sub-test H: end-to-end dispatch via vops_lookup ----------
      // Construct scratch vnode on stack (64 bytes = VNODE_SIZE)
      sub  rsp, 64                            // allocate scratch vnode

      mov  rax, rsp                           // rax = vnode base
      xor  rcx, rcx
      mov  [rax + 0], rcx                     // zero first 8 bytes (type=FREE)
      mov  [rax + 8], rcx                     // zero next 8 bytes
      mov  [rax + 16], rcx                    // zero next 8 bytes

      lea  rcx, [rip + _tmpfs_vops]
      mov  [rax + 24], rcx                    // ops_ptr = &_tmpfs_vops

      mov  rcx, 1                             // TMPFS_INODE_IDX_ROOT
      mov  [rax + 32], rcx                    // backend_ptr = root_idx

      xor  rcx, rcx
      mov  [rax + 40], rcx                    // zero next 8 bytes
      mov  [rax + 48], rcx                    // zero next 8 bytes
      mov  [rax + 56], rcx                    // zero last 8 bytes

      // Dispatch vops_lookup(&scratch_vnode, "tmp")
      mov  rdi, rax                           // rdi = scratch vnode
      lea  rsi, [rip + tmpfs_vops_witness_name_tmp]  // rsi = "tmp\0"
      call vops_lookup                        // dispatch through _tmpfs_vops[+32]
                                              // -> _tmpfs_lookup_adapter
                                              // -> tmpfs_lookup(root_idx=1, "tmp")
                                              // returns /tmp inode idx (== 2)

      add  rsp, 64                            // unwind scratch vnode

      // Assert: rax is non-zero (child found) and != 0xFFFF (error)
      cmp  rax, 0
      je   tmpfs_vops_witness_fail
      cmp  rax, 0xFFFF
      je   tmpfs_vops_witness_fail

      // ---------- Success: emit marker ----------
      lea  rdi, [rip + tmpfs_vops_ok_msg]
      call uart_puts
      jmp  tmpfs_vops_witness_done

      tmpfs_vops_witness_fail:
          lea  rdi, [rip + tmpfs_vops_fail_msg]
          call uart_puts

      tmpfs_vops_witness_done:

      // ============================================================
      // R16-M3-001 (#587): sys_open witness — 5 sub-tests, 1 marker
      // ============================================================
      sys_open_witness:
          // --- Sub-test A: first open returns 3 ---
          lea  rdi, [rip + _sys_open_witness_task]
          lea  rsi, [rip + witness_path_slash]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 3
          jne  sys_open_witness_fail

          // --- Sub-test B: second open returns 4 ---
          lea  rdi, [rip + _sys_open_witness_task]
          lea  rsi, [rip + witness_path_slash]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 4
          jne  sys_open_witness_fail

          // --- Sub-test C: third open returns 5 ---
          lea  rdi, [rip + _sys_open_witness_task]
          lea  rsi, [rip + witness_path_slash]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 5
          jne  sys_open_witness_fail

          // --- Sub-test D: fd_table[3] has valid packed entry ---
          lea  rdi, [rip + _sys_open_witness_task]
          mov  rsi, 3
          call fd_get
          mov  rcx, rax
          and  rcx, 0xFFFF                          // vnode_idx (low 16)
          cmp  rcx, 0
          je   sys_open_witness_fail
          mov  rcx, rax
          shr  rcx, 16                              // offset (high 48)
          cmp  rcx, 0
          jne  sys_open_witness_fail

          // --- Sub-test E: error path returns -ENOENT for "/nope" ---
          lea  rdi, [rip + _sys_open_witness_task]
          lea  rsi, [rip + witness_path_nope]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          mov  rcx, 0xFFFFFFFFFFFFFFFE
          cmp  rax, rcx
          jne  sys_open_witness_fail

          // --- All green ---
          lea  rdi, [rip + sys_open_ok_msg]
          call uart_puts
          jmp  sys_open_witness_done

      sys_open_witness_fail:
          lea  rdi, [rip + sys_open_fail_msg]
          call uart_puts

      sys_open_witness_done:

      // ============================================================
      // R16-M3-002 (#588): sys_close witness — 5 sub-tests, 1 marker
      // ============================================================
      sys_close_witness:
          // --- Prep: sys_open on fresh slab to seed fd 3 ---
          lea  rdi, [rip + _sys_close_witness_task]
          lea  rsi, [rip + witness_path_slash]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 3
          jne  sys_close_witness_fail

          // --- Sub-test A: sys_close(w, 3) → 0 ---
          lea  rdi, [rip + _sys_close_witness_task]
          mov  rsi, 3
          call sys_close_body
          cmp  rax, 0
          jne  sys_close_witness_fail

          // --- Sub-test B: fd_get(w, 3) → 0 (slot cleared) ---
          lea  rdi, [rip + _sys_close_witness_task]
          mov  rsi, 3
          call fd_get
          cmp  rax, 0
          jne  sys_close_witness_fail

          // --- Sub-test C: sys_close(w, 2) → -EBADF ---
          lea  rdi, [rip + _sys_close_witness_task]
          mov  rsi, 2
          call sys_close_body
          mov  rcx, 0xFFFFFFFFFFFFFFF7
          cmp  rax, rcx
          jne  sys_close_witness_fail

          // --- Sub-test D: sys_close(w, 32) → -EBADF ---
          lea  rdi, [rip + _sys_close_witness_task]
          mov  rsi, 32
          call sys_close_body
          mov  rcx, 0xFFFFFFFFFFFFFFF7
          cmp  rax, rcx
          jne  sys_close_witness_fail

          // --- Sub-test E: sys_close(w, 3) again → -EBADF (already closed) ---
          lea  rdi, [rip + _sys_close_witness_task]
          mov  rsi, 3
          call sys_close_body
          mov  rcx, 0xFFFFFFFFFFFFFFF7
          cmp  rax, rcx
          jne  sys_close_witness_fail

          // --- All green ---
          lea  rdi, [rip + sys_close_ok_msg]
          call uart_puts
          jmp  sys_close_witness_done

      sys_close_witness_fail:
          lea  rdi, [rip + sys_close_fail_msg]
          call uart_puts

      sys_close_witness_done:

      // ============================================================
      // R16-M3-003 (#589): sys_read witness — preamble + 5 sub-tests
      // ============================================================
      sys_read_witness:
          // --- Preamble (fixup): wire the persistent root vnode to tmpfs ---
          // The real root vnode allocated by the #574 mount() witness (via
          // vnode_alloc) has never had its ops_ptr(+24)/backend_ptr(+32)
          // fields populated. The #586 tmpfs-vops-wire witness only proved
          // dispatch through a throwaway SCRATCH vnode built on the stack;
          // it never touched the persistent tree root. Every sys_open
          // witness up to and including #587 only exercised single- or
          // zero-component paths ("/", "/nope") whose path_resolve never
          // needs a populated ops_ptr (no vops_lookup call is reached for
          // "/"; the "/nope" ENOENT case is satisfied by vops_lookup's own
          // null-ops_ptr -> VOPS_ERR_NOT_SUPPORTED short-circuit, which
          // happens to collapse to the same ENOENT outcome). #589 is the
          // first witness to resolve a real multi-component path
          // ("/tmp/x") through the actual tmpfs backend, which surfaces
          // this wiring gap: without it, vops_lookup(root_vnode, "tmp")
          // hits the null-ops_ptr guard and path_resolve fails. Wire it
          // here, once, before any lookup/open in this witness.
          call mount_root_vnode                       // rax = real root vnode idx
          mov  rdi, rax
          call vnode_slot                              // rax = &vnode[root]
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx                         // ops_ptr = &_tmpfs_vops
          mov  rcx, 1                                  // TMPFS_INODE_IDX_ROOT
          mov  [rax + 32], rcx                         // backend_ptr = root_idx

          // --- Preamble: recover x_idx, re-seed data, open fd=3 ---
          mov  rdi, 1
          lea  rsi, [rip + witness_name_tmp]
          call tmpfs_lookup
          cmp  rax, 0
          je   sys_read_witness_fail
          mov  r12, rax                               // r12 = tmp_idx

          // --- Preamble (fixup, cont'd): wire /tmp's vnode-pool slot too ---
          // path_resolve's regular_lookup treats vops_lookup's returned
          // child index (a tmpfs-native inode idx, e.g. tmp_idx here) as
          // the NEXT vnode-pool index for its following vnode_slot call.
          // Nothing else in the boot sequence ever populates
          // _vnode_pool[tmp_idx] for the real (non-scratch) tree, so the
          // "x" component lookup would hit the same null-ops_ptr gap this
          // preamble just fixed for the root. Same wiring, same rationale.
          mov  rdi, r12
          call vnode_slot                              // rax = &vnode[tmp_idx]
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx                         // ops_ptr = &_tmpfs_vops
          mov  rcx, r12
          mov  [rax + 32], rcx                         // backend_ptr = tmp_idx

          // /tmp/x was unlinked by the #585 tmpfs_unlink witness earlier in
          // boot (directory entry spliced out + bitmap bit cleared, proven
          // by that witness's own sub-tests B/D). A tmpfs_lookup here would
          // miss, so re-create it via tmpfs_create — same args as the #582
          // tmpfs_create witness (tmp_idx, "x", name_len=1, type=REG=1) —
          // before seeding data and opening it.
          mov  rdi, r12                               // dir_idx = tmp_idx
          lea  rsi, [rip + witness_name_any]           // name_ptr = "x\0"
          mov  rdx, 1                                  // name_len = 1
          mov  rcx, 1                                  // type = VNODE_TYPE_REG
          call tmpfs_create
          cmp  rax, 0
          je   sys_read_witness_fail
          cmp  rax, 0xFFFF
          je   sys_read_witness_fail                   // alloc-OOM sentinel
          mov  r13, rax                               // r13 = x_idx (freshly created)

          // --- Preamble (fixup, cont'd): wire x_idx's vnode-pool slot too ---
          // vfs_read (called from inside sys_read_body) resolves its
          // vnode_idx argument via vnode_slot + vops_read, same identity
          // assumption as path_resolve's regular_lookup. Without this,
          // vops_read's null-ops_ptr guard fires and sys_read_body sees
          // the VOPS_ERR_NOT_SUPPORTED sentinel, returning -EIO instead of
          // bytes_read. Same wiring, same rationale as tmp_idx above.
          mov  rdi, r13
          call vnode_slot                              // rax = &vnode[x_idx]
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx                         // ops_ptr = &_tmpfs_vops
          mov  rcx, r13
          mov  [rax + 32], rcx                         // backend_ptr = x_idx

          mov  rdi, r13
          lea  rsi, [rip + tmpfs_write_src_buf]
          mov  rdx, 100
          xor  rcx, rcx
          call tmpfs_write
          cmp  rax, 100
          jne  sys_read_witness_fail

          lea  rdi, [rip + _sys_read_witness_task]
          lea  rsi, [rip + witness_path_tmp_x]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 3
          jne  sys_read_witness_fail

          // --- Sub-test A: sys_read(w, 3, dst_buf, 100) → 100 ---
          lea  rdi, [rip + _sys_read_witness_task]
          mov  rsi, 3
          lea  rdx, [rip + tmpfs_read_dst_buf]
          mov  rcx, 100
          call sys_read_body
          cmp  rax, 100
          jne  sys_read_witness_fail

          // --- Sub-test B: dst_buf[0..8] == 0x4141414141414141 ---
          lea  r14, [rip + tmpfs_read_dst_buf]
          mov  rcx, [r14]
          mov  rdx, 0x4141414141414141
          cmp  rcx, rdx
          jne  sys_read_witness_fail

          // --- Sub-test C: fd_table[3] offset field == 100 ---
          lea  rdi, [rip + _sys_read_witness_task]
          mov  rsi, 3
          call fd_get
          mov  rcx, rax
          shr  rcx, 16
          cmp  rcx, 100
          jne  sys_read_witness_fail

          // --- Sub-test D: consecutive sys_read → 0 (EOF) ---
          lea  rdi, [rip + _sys_read_witness_task]
          mov  rsi, 3
          lea  rdx, [rip + tmpfs_read_dst_buf]
          mov  rcx, 100
          call sys_read_body
          cmp  rax, 0
          jne  sys_read_witness_fail

          // --- Sub-test E: sys_read(w, 2, ...) → -EBADF ---
          lea  rdi, [rip + _sys_read_witness_task]
          mov  rsi, 2
          lea  rdx, [rip + tmpfs_read_dst_buf]
          mov  rcx, 100
          call sys_read_body
          mov  rcx, 0xFFFFFFFFFFFFFFF7
          cmp  rax, rcx
          jne  sys_read_witness_fail

          // --- All green ---
          lea  rdi, [rip + sys_read_ok_msg]
          call uart_puts
          jmp  sys_read_witness_done

      sys_read_witness_fail:
          lea  rdi, [rip + sys_read_fail_msg]
          call uart_puts

      sys_read_witness_done:

      // ============================================================
      // R16-M3-004 (#590): sys_write witness — preamble + 4 sub-tests
      // ============================================================
      sys_write_witness:
          // --- Preamble: wire root and tmp_idx, recover x_idx, trim /tmp/x to 0;
          //               wire fresh x_idx; open fd=3 ---
          // Although root and tmp_idx wiring persisted from #589, we ensure they're
          // wired here for defensive idempotency, matching sys_read witness pattern.
          call mount_root_vnode                       // rax = real root vnode idx
          mov  rdi, rax
          call vnode_slot                              // rax = &vnode[root]
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx                         // ops_ptr = &_tmpfs_vops
          mov  rcx, 1                                  // TMPFS_INODE_IDX_ROOT
          mov  [rax + 32], rcx                         // backend_ptr = root_idx

          // Recover tmp_idx via lookup
          mov  rdi, 1
          lea  rsi, [rip + witness_name_tmp]
          call tmpfs_lookup
          cmp  rax, 0
          je   sys_write_witness_fail
          mov  r12, rax                               // r12 = tmp_idx

          // Wire /tmp's vnode-pool slot
          mov  rdi, r12
          call vnode_slot                              // rax = &vnode[tmp_idx]
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx                         // ops_ptr = &_tmpfs_vops
          mov  rcx, r12
          mov  [rax + 32], rcx                         // backend_ptr = tmp_idx

          // Trim /tmp/x back to fresh 0-size state: unlink + create
          mov  rdi, r12
          lea  rsi, [rip + witness_name_any]
          mov  rdx, 1
          call tmpfs_unlink
          cmp  rax, 0
          jne  sys_write_witness_fail

          mov  rdi, r12
          lea  rsi, [rip + witness_name_any]
          mov  rdx, 1
          mov  rcx, 1                                 // VNODE_TYPE_REG
          call tmpfs_create
          cmp  rax, 0
          je   sys_write_witness_fail
          cmp  rax, 0xFFFF
          je   sys_write_witness_fail
          mov  r13, rax                               // r13 = fresh x_idx

          // Defensive vnode-pool wiring for x_idx (persists from #589 unless
          // unlink+create yielded a different idx — see §4.4).
          mov  rdi, r13
          call vnode_slot
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx
          mov  rcx, r13
          mov  [rax + 32], rcx

          lea  rdi, [rip + _sys_write_witness_task]
          lea  rsi, [rip + witness_path_tmp_x]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 3
          jne  sys_write_witness_fail

          // --- Sub-test A: sys_write(w, 3, src, 100) → 100 ---
          lea  rdi, [rip + _sys_write_witness_task]
          mov  rsi, 3
          lea  rdx, [rip + tmpfs_write_src_buf]
          mov  rcx, 100
          call sys_write_body
          cmp  rax, 100
          jne  sys_write_witness_fail

          // --- Sub-test B: fd_table[3] offset field == 100 ---
          lea  rdi, [rip + _sys_write_witness_task]
          mov  rsi, 3
          call fd_get
          mov  rcx, rax
          shr  rcx, 16
          cmp  rcx, 100
          jne  sys_write_witness_fail

          // --- Sub-test C: inode.size == 100 (grew from 0 post-create) ---
          mov  rdi, r13
          call tmpfs_inode_slot
          mov  rcx, [rax + 8]
          cmp  rcx, 100
          jne  sys_write_witness_fail

          // --- Sub-test D: sys_write(w, 2, ...) → -EBADF ---
          lea  rdi, [rip + _sys_write_witness_task]
          mov  rsi, 2
          lea  rdx, [rip + tmpfs_write_src_buf]
          mov  rcx, 100
          call sys_write_body
          mov  rcx, 0xFFFFFFFFFFFFFFF7
          cmp  rax, rcx
          jne  sys_write_witness_fail

          // --- All green ---
          lea  rdi, [rip + sys_write_ok_msg]
          call uart_puts
          jmp  sys_write_witness_done

      sys_write_witness_fail:
          lea  rdi, [rip + sys_write_fail_msg]
          call uart_puts

      sys_write_witness_done:

      // ============================================================
      // R16-M3-005 (#591): sys_dup2 witness — preamble + 6 sub-tests
      // ============================================================
      sys_dup2_witness:
          // --- Preamble: wire root, tmp_idx; unlink+create x; wire x_idx;
          //               reset x_idx refcount; open fd=3 (/tmp/x) and fd=4 (/) ---
          call mount_root_vnode
          mov  rdi, rax
          call vnode_slot
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx
          mov  rcx, 1                                 // TMPFS_INODE_IDX_ROOT
          mov  [rax + 32], rcx

          mov  rdi, 1
          lea  rsi, [rip + witness_name_tmp]
          call tmpfs_lookup
          cmp  rax, 0
          je   sys_dup2_witness_fail
          mov  r12, rax                               // r12 = tmp_idx

          mov  rdi, r12
          call vnode_slot
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx
          mov  rcx, r12
          mov  [rax + 32], rcx

          mov  rdi, r12
          lea  rsi, [rip + witness_name_any]
          mov  rdx, 1
          call tmpfs_unlink
          cmp  rax, 0
          jne  sys_dup2_witness_fail

          mov  rdi, r12
          lea  rsi, [rip + witness_name_any]
          mov  rdx, 1
          mov  rcx, 1                                 // VNODE_TYPE_REG
          call tmpfs_create
          cmp  rax, 0
          je   sys_dup2_witness_fail
          cmp  rax, 0xFFFF
          je   sys_dup2_witness_fail
          mov  r13, rax                               // r13 = fresh x_idx

          mov  rdi, r13
          call vnode_slot
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx
          mov  rcx, r13
          mov  [rax + 32], rcx

          // CRITICAL: reset x_idx vnode refcount to 0 (§4.3.1)
          mov  rdi, r13
          call vnode_slot
          xor  rcx, rcx
          mov_w [rax + 4], rcx

          // sys_open("/tmp/x", 0, 0) → fd = 3, x_idx.refcount → 1
          lea  rdi, [rip + _sys_dup2_witness_task]
          lea  rsi, [rip + witness_path_tmp_x]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 3
          jne  sys_dup2_witness_fail

          // sys_open("/", 0, 0) → fd = 4, root_idx.refcount ++
          lea  rdi, [rip + _sys_dup2_witness_task]
          lea  rsi, [rip + witness_path_slash]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 4
          jne  sys_dup2_witness_fail

          // --- Sub-test D: sys_dup2(w, 3, 3) → 3 (no-op) ---
          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 3
          mov  rdx, 3
          call sys_dup2_body
          cmp  rax, 3
          jne  sys_dup2_witness_fail

          // --- Sub-test A: sys_dup2(w, 3, 5) → 5 ---
          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 3
          mov  rdx, 5
          call sys_dup2_body
          cmp  rax, 5
          jne  sys_dup2_witness_fail

          // --- Sub-test B: fd_table[5] == fd_table[3] ---
          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 3
          call fd_get
          mov  r12, rax                               // r12 = src_entry

          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 5
          call fd_get
          cmp  rax, r12
          jne  sys_dup2_witness_fail

          // --- Sub-test C: shared vnode's refcount == 2 ---
          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 3
          call fd_get
          and  rax, 0xFFFF
          mov  rdi, rax
          call vnode_slot
          xor  rcx, rcx
          mov_w rcx, [rax + 4]
          cmp  rcx, 2
          jne  sys_dup2_witness_fail

          // --- Sub-test E: sys_dup2(w, 99, 5) → -EBADF ---
          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 99
          mov  rdx, 5
          call sys_dup2_body
          mov  rcx, 0xFFFFFFFFFFFFFFF7
          cmp  rax, rcx
          jne  sys_dup2_witness_fail

          // --- Sub-test F prep: sample fd_table[4]'s vnode_idx + refcount ---
          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 4
          call fd_get
          and  rax, 0xFFFF
          mov  r12, rax                               // r12 = root_idx
          mov  rdi, rax
          call vnode_slot
          xor  rcx, rcx
          mov_w rcx, [rax + 4]
          mov  r13, rcx                               // r13 = R_root_before

          // --- Sub-test F: sys_dup2(w, 3, 4) → 4 ---
          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 3
          mov  rdx, 4
          call sys_dup2_body
          cmp  rax, 4
          jne  sys_dup2_witness_fail

          // F.1: fd_table[4] == fd_table[3]
          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 3
          call fd_get
          mov  r14, rax
          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 4
          call fd_get
          cmp  rax, r14
          jne  sys_dup2_witness_fail

          // F.2: root_idx refcount decreased by 1
          mov  rdi, r12
          call vnode_slot
          xor  rcx, rcx
          mov_w rcx, [rax + 4]
          inc  rcx
          cmp  rcx, r13
          jne  sys_dup2_witness_fail

          // F.3: x_idx refcount == 3
          lea  rdi, [rip + _sys_dup2_witness_task]
          mov  rsi, 3
          call fd_get
          and  rax, 0xFFFF
          mov  rdi, rax
          call vnode_slot
          xor  rcx, rcx
          mov_w rcx, [rax + 4]
          cmp  rcx, 3
          jne  sys_dup2_witness_fail

          // --- All green ---
          lea  rdi, [rip + sys_dup2_ok_msg]
          call uart_puts
          jmp  sys_dup2_witness_done

      sys_dup2_witness_fail:
          lea  rdi, [rip + sys_dup2_fail_msg]
          call uart_puts

      sys_dup2_witness_done:

      // ============================================================
      // R16-M3-006 (#592): fd_inherit witness — preamble + fork + 3 sub-tests
      // ============================================================
      fd_inherit_witness:
          // --- Preamble: wire root, tmp_idx; unlink+create x; wire x_idx; reset x_idx refcount ---
          call mount_root_vnode
          mov  rdi, rax
          call vnode_slot
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx
          mov  rcx, 1                                 // TMPFS_INODE_IDX_ROOT
          mov  [rax + 32], rcx

          mov  rdi, 1
          lea  rsi, [rip + witness_name_tmp]
          call tmpfs_lookup
          cmp  rax, 0
          je   fd_inherit_witness_fail
          mov  r12, rax                               // r12 = tmp_idx

          mov  rdi, r12
          call vnode_slot
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx
          mov  rcx, r12
          mov  [rax + 32], rcx

          mov  rdi, r12
          lea  rsi, [rip + witness_name_any]
          mov  rdx, 1
          call tmpfs_unlink
          cmp  rax, 0
          jne  fd_inherit_witness_fail

          mov  rdi, r12
          lea  rsi, [rip + witness_name_any]
          mov  rdx, 1
          mov  rcx, 1                                 // VNODE_TYPE_REG
          call tmpfs_create
          cmp  rax, 0
          je   fd_inherit_witness_fail
          cmp  rax, 0xFFFF
          je   fd_inherit_witness_fail
          mov  r15, rax                               // r15 = fresh x_idx

          mov  rdi, r15
          call vnode_slot
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx
          mov  rcx, r15
          mov  [rax + 32], rcx

          // Reset x_idx vnode refcount to 0 (state normalization)
          mov  rdi, r15
          call vnode_slot
          xor  rcx, rcx
          mov_w [rax + 4], rcx

          // --- task_new(NULL) → parent ---
          xor  rdi, rdi
          call task_new
          cmp  rax, 0
          je   fd_inherit_witness_fail
          mov  r14, rax                               // r14 = parent slab

          // --- sys_open_body(parent, "/tmp/x", 0, 0) → fd = 3 ---
          mov  rdi, r14
          lea  rsi, [rip + witness_path_tmp_x]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 3
          jne  fd_inherit_witness_fail

          // --- Baseline sanity: x_idx.refcount == 1 pre-fork ---
          mov  rdi, r15
          call vnode_slot
          xor  rcx, rcx
          mov_w rcx, [rax + 4]
          cmp  rcx, 1
          jne  fd_inherit_witness_fail

          // --- Act: sys_fork_body(parent) → child_pid, rdx=0 ---
          mov  rdi, r14
          call sys_fork_body
          cmp  rax, 2                                 // child_pid >= 2
          jb   fd_inherit_witness_fail
          cmp  rdx, 0
          jne  fd_inherit_witness_fail
          mov  r12d, eax                              // r12 = child_pid (zero-ext)

          // --- Recover child slab via _pid_table[child_pid] ---
          lea  rax, [rip + _pid_table]
          mov  r13, [rax + r12*8]                     // r13 = child slab
          cmp  r13, 0
          je   fd_inherit_witness_fail

          // --- Sub-test A: parent.fd[3] == child.fd[3] ---
          mov  rax, [r14 + 24 + 168]                  // parent.fd[3]
          mov  rcx, [r13 + 24 + 168]                  // child.fd[3]
          cmp  rax, rcx
          jne  fd_inherit_witness_fail

          // --- Sub-test B: x_idx.refcount == 2 ---
          mov  rdi, r15                               // r15 = x_idx (saved from preamble)
          call vnode_slot
          xor  rcx, rcx
          mov_w rcx, [rax + 4]
          cmp  rcx, 2
          jne  fd_inherit_witness_fail

          // --- Sub-test C: child.fd[0/1/2] all zero ---
          mov  rax, [r13 + 0 + 168]
          cmp  rax, 0
          jne  fd_inherit_witness_fail
          mov  rax, [r13 + 8 + 168]
          cmp  rax, 0
          jne  fd_inherit_witness_fail
          mov  rax, [r13 + 16 + 168]
          cmp  rax, 0
          jne  fd_inherit_witness_fail

          // --- All green ---
          lea  rdi, [rip + fd_inherit_ok_msg]
          call uart_puts
          jmp  fd_inherit_witness_done

      fd_inherit_witness_fail:
          lea  rdi, [rip + fd_inherit_fail_msg]
          call uart_puts

      fd_inherit_witness_done:

      // ============================================================
      // R16-M3-007 (#593): fd_cloexec witness — preamble + execve + 3 sub-tests
      // ============================================================
      fd_cloexec_witness:
          // --- Preamble: wire root, tmp_idx; unlink+create x; wire x_idx;
          //               reset x_idx refcount; task_new; open fd=3;
          //               mark CLOEXEC; open fd=4 ---
          call mount_root_vnode
          mov  rdi, rax
          call vnode_slot
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx
          mov  rcx, 1                                 // TMPFS_INODE_IDX_ROOT
          mov  [rax + 32], rcx

          mov  rdi, 1
          lea  rsi, [rip + witness_name_tmp]
          call tmpfs_lookup
          cmp  rax, 0
          je   fd_cloexec_witness_fail
          mov  r12, rax                               // r12 = tmp_idx

          mov  rdi, r12
          call vnode_slot
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx
          mov  rcx, r12
          mov  [rax + 32], rcx

          mov  rdi, r12
          lea  rsi, [rip + witness_name_any]
          mov  rdx, 1
          call tmpfs_unlink
          cmp  rax, 0
          jne  fd_cloexec_witness_fail

          mov  rdi, r12
          lea  rsi, [rip + witness_name_any]
          mov  rdx, 1
          mov  rcx, 1                                 // VNODE_TYPE_REG
          call tmpfs_create
          cmp  rax, 0
          je   fd_cloexec_witness_fail
          cmp  rax, 0xFFFF
          je   fd_cloexec_witness_fail
          mov  r15, rax                               // r15 = fresh x_idx

          mov  rdi, r15
          call vnode_slot
          lea  rcx, [rip + _tmpfs_vops]
          mov  [rax + 24], rcx
          mov  rcx, r15
          mov  [rax + 32], rcx

          // Reset x_idx vnode refcount to 0 (state normalization)
          mov  rdi, r15
          call vnode_slot
          xor  rcx, rcx
          mov_w [rax + 4], rcx

          // --- task_new(NULL) → parent ---
          xor  rdi, rdi
          call task_new
          cmp  rax, 0
          je   fd_cloexec_witness_fail
          mov  r14, rax                               // r14 = parent slab

          // --- sys_open_body(parent, "/tmp/x", 0, 0) → fd = 3 ---
          mov  rdi, r14
          lea  rsi, [rip + witness_path_tmp_x]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 3
          jne  fd_cloexec_witness_fail

          // --- Verify fd[3] was actually populated ---
          mov  rax, [r14 + 24 + 168]                  // parent.fd[3]
          cmp  rax, 0
          je   fd_cloexec_witness_fail                // fd[3] should not be empty!

          // --- Set bit 63 of parent.fd_table[3] (CLOEXEC marker) ---
          mov  rcx, 0x8000000000000000                // CLOEXEC_MASK (bit 63)
          or   rax, rcx
          mov  [r14 + 24 + 168], rax

          // --- sys_open_body(parent, "/tmp/x", 0, 0) → fd = 4 (no CLOEXEC) ---
          mov  rdi, r14
          lea  rsi, [rip + witness_path_tmp_x]
          xor  rdx, rdx
          xor  rcx, rcx
          call sys_open_body
          cmp  rax, 4
          jne  fd_cloexec_witness_fail

          // --- Verify fd[4] was actually populated ---
          mov  rax, [r14 + 32 + 168]                  // parent.fd[4]
          cmp  rax, 0
          je   fd_cloexec_witness_fail                // fd[4] should not be empty!

          // --- Baseline sanity: x_idx.refcount == 2 pre-execve ---
          mov  rdi, r15
          call vnode_slot
          xor  rcx, rcx
          mov_w rcx, [rax + 4]
          cmp  rcx, 2
          jne  fd_cloexec_fail_setup_label

          // --- Act: sys_execve_body(parent, _shell_bin_start, image_len) ---
          // r14 = parent task (arg 1), r15 = x_idx (preserved as callee-save)
          mov  rdi, r14                               // arg 1: parent task
          lea  rsi, [rip + _shell_bin_start]         // arg 2: image_ptr
          lea  rax, [rip + _shell_bin_end]
          sub  rax, rsi
          mov  rdx, rax                               // arg 3: image_len
          call sys_execve_body
          cmp  rax, 0                                 // require ELF_OK
          jne  fd_cloexec_fail_execve_label

          // --- Sub-test A: parent.fd_table[3] == 0 ---
          mov  rax, [r14 + 24 + 168]
          cmp  rax, 0
          jne  fd_cloexec_fail_sub_a_label

          // --- Sub-test B: parent.fd_table[4] != 0 ---
          mov  rax, [r14 + 32 + 168]
          cmp  rax, 0
          je   fd_cloexec_fail_sub_b_label

          // --- Sub-test C: x_idx.refcount == 1 ---
          mov  rdi, r15
          call vnode_slot
          xor  rcx, rcx
          mov_w rcx, [rax + 4]
          cmp  rcx, 1
          jne  fd_cloexec_fail_sub_c_label

          // --- All green ---
          lea  rdi, [rip + fd_cloexec_ok_msg]
          call uart_puts
          jmp  fd_cloexec_witness_done

      fd_cloexec_fail_setup_label:
          lea  rdi, [rip + fd_cloexec_fail_setup]
          call uart_puts
          jmp  fd_cloexec_witness_done

      fd_cloexec_fail_execve_label:
          lea  rdi, [rip + fd_cloexec_fail_execve]
          call uart_puts
          jmp  fd_cloexec_witness_done

      fd_cloexec_fail_sub_a_label:
          lea  rdi, [rip + fd_cloexec_fail_sub_a]
          call uart_puts
          jmp  fd_cloexec_witness_done

      fd_cloexec_fail_sub_b_label:
          lea  rdi, [rip + fd_cloexec_fail_sub_b]
          call uart_puts
          jmp  fd_cloexec_witness_done

      fd_cloexec_fail_sub_c_label:
          lea  rdi, [rip + fd_cloexec_fail_sub_c]
          call uart_puts
          jmp  fd_cloexec_witness_done

      fd_cloexec_witness_fail:
          lea  rdi, [rip + fd_cloexec_fail_msg]
          call uart_puts

      fd_cloexec_witness_done:

      // R16-M3-008 (#594): FD OK — milestone closure marker.
      lea rdi, [rip + fd_ok_msg];
      call uart_puts;

      // ============================================================
      // R16-M4-001 (#595): uart_rx_init witness — 1 sub-test
      // ============================================================
      uart_rx_init_witness:
          // Sub-test A: after uart_rx_init, port 0x3F9 read returns 0x01
          call uart_rx_init;

          mov  dx, 0x3F9;
          in_al al;
          and  rax, 0xFF;                         // isolate AL (in_al leaves upper 56 bits untouched)
          cmp  rax, 1;
          jne  uart_rx_init_witness_fail;

          // All green
          lea  rdi, [rip + uart_rx_init_ok_msg];
          call uart_puts;
          jmp  uart_rx_init_witness_done;

      uart_rx_init_witness_fail:
          lea  rdi, [rip + uart_rx_init_fail_msg];
          call uart_puts;

      uart_rx_init_witness_done:

      // ============================================================
      // R16-M4-002 (#596): uart_rx_ring witness — 4 sub-tests
      // ============================================================
      uart_rx_ring_witness:
          push r12;                              // callee-save loop counter

          // ---------- Sub-test A: virgin ring is empty ----------
          call uart_rx_dequeue;
          cmp  rax, 0xFFFF;
          jne  uart_rx_ring_witness_fail;

          // ---------- Sub-test B: single-byte round-trip ----------
          mov  rdi, 0x41;
          call uart_rx_enqueue;
          cmp  rax, 0;
          jne  uart_rx_ring_witness_fail;
          call uart_rx_dequeue;
          cmp  rax, 0x41;
          jne  uart_rx_ring_witness_fail;

          // ---------- Sub-test C: multi-byte FIFO ("hello") ----------
          mov rdi, 0x68;
          call uart_rx_enqueue;
          cmp rax, 0;
          jne uart_rx_ring_witness_fail;
          mov rdi, 0x65;
          call uart_rx_enqueue;
          cmp rax, 0;
          jne uart_rx_ring_witness_fail;
          mov rdi, 0x6C;
          call uart_rx_enqueue;
          cmp rax, 0;
          jne uart_rx_ring_witness_fail;
          mov rdi, 0x6C;
          call uart_rx_enqueue;
          cmp rax, 0;
          jne uart_rx_ring_witness_fail;
          mov rdi, 0x6F;
          call uart_rx_enqueue;
          cmp rax, 0;
          jne uart_rx_ring_witness_fail;

          call uart_rx_dequeue;
          cmp rax, 0x68;
          jne uart_rx_ring_witness_fail;
          call uart_rx_dequeue;
          cmp rax, 0x65;
          jne uart_rx_ring_witness_fail;
          call uart_rx_dequeue;
          cmp rax, 0x6C;
          jne uart_rx_ring_witness_fail;
          call uart_rx_dequeue;
          cmp rax, 0x6C;
          jne uart_rx_ring_witness_fail;
          call uart_rx_dequeue;
          cmp rax, 0x6F;
          jne uart_rx_ring_witness_fail;

          // ---------- Sub-test D: capacity + full + drain + empty ----------
          xor r12, r12;
        urrw_fill_loop:
          mov rdi, r12;
          call uart_rx_enqueue;
          cmp rax, 0;
          jne uart_rx_ring_witness_fail;
          add r12, 1;
          cmp r12, 256;
          jb  urrw_fill_loop;

          mov rdi, 0x99;
          call uart_rx_enqueue;
          cmp rax, 1;
          jne uart_rx_ring_witness_fail;

          xor r12, r12;
        urrw_drain_loop:
          call uart_rx_dequeue;
          cmp rax, r12;
          jne uart_rx_ring_witness_fail;
          add r12, 1;
          cmp r12, 256;
          jb  urrw_drain_loop;

          call uart_rx_dequeue;
          cmp rax, 0xFFFF;
          jne uart_rx_ring_witness_fail;

          // --- All green ---
          lea  rdi, [rip + uart_rx_ring_ok_msg];
          call uart_puts;
          jmp  uart_rx_ring_witness_done;

      uart_rx_ring_witness_fail:
          lea  rdi, [rip + uart_rx_ring_fail_msg];
          call uart_puts;

      uart_rx_ring_witness_done:
          pop  r12;

      // ============================================================
      // R16-M4-003 (#597): uart_rx_isr witness — 1 sub-test
      // ============================================================
      uart_rx_isr_witness:
          push r12;                              // callee-save head snapshot

          // Sub-test A: with no bytes at COM1 (LSR.DR=0), calling
          // uart_rx_isr must not enqueue any bytes into the ring.
          // Snapshot _uart_rx_head; call ISR; verify head unchanged.
          mov  rax, [rip + _uart_rx_head];
          mov  r12, rax;                         // head_before survives the call

          call uart_rx_isr;                      // drains what's available (nothing) + EOI

          mov  rax, [rip + _uart_rx_head];
          cmp  rax, r12;                         // head_after must equal head_before
          jne  uart_rx_isr_witness_fail;

          // --- All green ---
          lea  rdi, [rip + uart_rx_isr_ok_msg];
          call uart_puts;
          jmp  uart_rx_isr_witness_done;

      uart_rx_isr_witness_fail:
          lea  rdi, [rip + uart_rx_isr_fail_msg];
          call uart_puts;

      uart_rx_isr_witness_done:
          pop  r12;

      // ============================================================
      // R16-M4-004 (#598): idt vector 0x24 wire — 3 sub-tests
      // ============================================================
      //
      // IDT entry layout (Intel SDM Vol 3A §6.14.1, 64-bit interrupt gate):
      //   Bytes 0-1:  offset_lo (u16)
      //   Bytes 2-3:  segment selector (u16, = 0x08 KERNEL_CS)
      //   Byte  4:    IST (bits 0-2) + reserved (bits 3-7); = 0 for vec 36
      //   Byte  5:    type_attr (u8): P=1 | DPL=0 | 0 | type=0xE → 0x8E
      //   Bytes 6-7:  offset_mid (u16)
      //   Bytes 8-11: offset_hi (u32)
      //   Bytes 12-15: reserved (u32, = 0)
      //
      // word0 (u64 at offset 0):
      //   bits  0-15: offset_lo
      //   bits 16-31: selector (0x08)
      //   bits 32-39: IST
      //   bits 40-47: type_attr (0x8E)
      //   bits 48-63: offset_mid
      //
      // word1 (u64 at offset 8):
      //   bits  0-31: offset_hi
      //   bits 32-63: reserved (0)

      idt_vec24_witness:
          push r12;                                 // callee-save: trampoline address survives all sub-tests
          push r13;                                 // callee-save: word0 survives sub-tests B and C

          // Load trampoline address once; used by sub-tests A and C.
          lea  r12, [rip + _uart_rx_trampoline];

          // Compute base address of IDT entry 36 (byte offset = 36 * 16 = 576).
          lea  rax, [rip + _idt_storage];
          add  rax, 576;                            // rax = &_idt_storage[36]

          // Load word0 into r13 for sub-tests A and B.
          mov  r13, [rax];

          // --------- Sub-test A: offset_lo (word0 bits 0-15) == trampoline & 0xFFFF ---------
          mov  rcx, r13;
          mov  rdx, 0xFFFF;
          and  rcx, rdx;                            // rcx = offset_lo from packed entry
          mov  rsi, r12;
          and  rsi, rdx;                            // rsi = trampoline low16
          cmp  rcx, rsi;
          jne  idt_vec24_witness_fail;

          // --------- Sub-test B: type_attr (word0 bits 40-47) == 0x8E ---------
          mov  rcx, r13;
          shr  rcx, 40;                             // rcx = type_attr | offset_mid<<8 | ...
          mov  rdx, 0xFF;
          and  rcx, rdx;                            // rcx = type_attr byte
          cmp  rcx, 0x8E;
          jne  idt_vec24_witness_fail;

          // --------- Sub-test C: reassembled handler offset == trampoline ---------
          //   reassembled = (word0 & 0xFFFF)                       ; offset_lo
          //               | ((word0 >> 48) & 0xFFFF) << 16         ; offset_mid
          //               | (word1 & 0xFFFFFFFF) << 32             ; offset_hi

          // offset_lo → rcx (low 16 bits of reassembled)
          mov  rcx, r13;
          mov  rdx, 0xFFFF;
          and  rcx, rdx;                            // rcx = offset_lo (positions 0-15)

          // offset_mid → rdi, then shift to positions 16-31, OR into rcx
          mov  rdi, r13;
          shr  rdi, 48;                             // rdi = offset_mid (positions 0-15)
          and  rdi, rdx;                            // explicit mask (defensive)
          shl  rdi, 16;                             // rdi = offset_mid (positions 16-31)
          or   rcx, rdi;

          // offset_hi from word1 → rdi, shift to positions 32-63, OR
          mov  rdi, [rax + 8];                      // rdi = word1
          mov  rdx, 0xFFFFFFFF;
          and  rdi, rdx;                            // rdi = offset_hi (positions 0-31)
          shl  rdi, 32;                             // rdi = offset_hi (positions 32-63)
          or   rcx, rdi;

          // Compare reassembled offset against trampoline address.
          cmp  rcx, r12;
          jne  idt_vec24_witness_fail;

          // --- All green ---
          lea  rdi, [rip + idt_vec24_ok_msg];
          call uart_puts;
          jmp  idt_vec24_witness_done;

      idt_vec24_witness_fail:
          lea  rdi, [rip + idt_vec24_fail_msg];
          call uart_puts;

      idt_vec24_witness_done:
          pop  r13;
          pop  r12;

      // R14b-m5-002 (#507): IA32_GS_BASE = &_cpu_locals[0] on CPU0.
      lea rax, [rip + _cpu_locals];
      mov rdx, rax;
      shr rdx, 32;
      mov rcx, 0xC0000101;
      wrmsr;

      call process_init;
      call syscall_msr_init;
      call apic_enable;
      call apic_svr_enable;
      call pic_mask_all;

      // ============================================================
      // R15-M7-002 (#563): runqueue initialization
      // ============================================================
      call runq_init;

      // ============================================================
      // R15-M7-001 (#562): idle-task witness — 4 sub-tests, 1 marker
      // ============================================================
      idle_witness:
          // ---------- Sub-test 1: _idle_tcb is published + non-zero ----------
          call idle_init;                          // idempotent — safe to re-call
          mov rax, [rip + _idle_tcb];
          cmp rax, 0;
          je  idle_witness_fail;
          mov r12, rax;                            // r12 = &_idle_task_slot

          // Assert: _idle_tcb == &_idle_task_slot (identity)
          lea rax, [rip + _idle_task_slot];
          cmp rax, r12;
          jne idle_witness_fail;

          // ---------- Sub-test 2: state == STATE_RUNNABLE ----------
          mov eax, [r12 + 8];                      // state (u32) @ +8
          cmp rax, 1;                              // STATE_RUNNABLE
          jne idle_witness_fail;

          // ---------- Sub-test 3: regs_save.rip == &idle_code ----------
          mov rax, [r12 + 40];                     // regs_save.rip @ +40
          lea rcx, [rip + idle_code];
          cmp rax, rcx;
          jne idle_witness_fail;

          // Assert: regs_save.rsp is inside _idle_kernel_stack
          mov rax, [r12 + 32];                     // regs_save.rsp @ +32
          lea rcx, [rip + _idle_kernel_stack];
          cmp rax, rcx;
          jb  idle_witness_fail;                   // rsp < stack base → bad
          add rcx, 4096;
          cmp rax, rcx;
          ja  idle_witness_fail;                   // rsp > stack top → bad

          // ---------- Sub-test 4: pick_next returns idle when nothing RUNNABLE ----------
          // Precondition: no earlier witness left a task in RUNNABLE state.
          //   task_new witnesses all leave state=STATE_NEW (0);
          //   sys_exit witnesses leave state=STATE_ZOMBIE (3);
          //   sys_wait sub-test B leaves parent_b in STATE_WAITING (2);
          //   sys_wait sub-test A reaped its child (slot cleared).
          // No RUNNABLE tasks exist → pick_next must return _idle_tcb.
          call sched_pick_next_r15;
          cmp rax, r12;                            // must == &_idle_task_slot
          jne idle_witness_fail;

          // ---------- All checks green ----------
          lea rdi, [rip + idle_witness_ok_msg];
          call uart_puts;
          jmp idle_witness_exit;

      idle_witness_fail:
          lea rdi, [rip + idle_witness_fail_msg];
          call uart_puts;

      idle_witness_exit:

      // ============================================================
      // R15-M7-002 (#563): runqueue witness — 3 sub-tests, 1 marker
      // ============================================================
      runq_witness:
          // Precondition: runq_init has been called (see kernel_main
          // insertion §4). _runq_head_slot.next == _runq_head_slot.prev
          // == &_runq_head_slot (empty circular list).

          // ---------- Sub-test A: empty runqueue → sched_pick_next_r15 returns _idle_tcb ----------
          call sched_pick_next_r15;
          mov r12, [rip + _idle_tcb];
          cmp rax, r12;
          jne runq_witness_fail;

          // ---------- Sub-test B: enqueue 5 tasks; 5 picks round-robin ----------
          // Use 5 dedicated bss stubs (see storage §8.1). Enqueue in
          // order 1..5; pick_next must return them in the same order.
          lea rdi, [rip + _runq_witness_task_1];
          call runq_enqueue;
          lea rdi, [rip + _runq_witness_task_2];
          call runq_enqueue;
          lea rdi, [rip + _runq_witness_task_3];
          call runq_enqueue;
          lea rdi, [rip + _runq_witness_task_4];
          call runq_enqueue;
          lea rdi, [rip + _runq_witness_task_5];
          call runq_enqueue;

          // Pick #1 must return _runq_witness_task_1
          call sched_pick_next_r15;
          lea rcx, [rip + _runq_witness_task_1];
          cmp rax, rcx;
          jne runq_witness_fail;

          // Pick #2 must return _runq_witness_task_2
          call sched_pick_next_r15;
          lea rcx, [rip + _runq_witness_task_2];
          cmp rax, rcx;
          jne runq_witness_fail;

          // Pick #3 must return _runq_witness_task_3
          call sched_pick_next_r15;
          lea rcx, [rip + _runq_witness_task_3];
          cmp rax, rcx;
          jne runq_witness_fail;

          // Pick #4 must return _runq_witness_task_4
          call sched_pick_next_r15;
          lea rcx, [rip + _runq_witness_task_4];
          cmp rax, rcx;
          jne runq_witness_fail;

          // Pick #5 must return _runq_witness_task_5
          call sched_pick_next_r15;
          lea rcx, [rip + _runq_witness_task_5];
          cmp rax, rcx;
          jne runq_witness_fail;

          // After 5 picks, the list has rotated a full cycle — order
          // is (task_1, task_2, task_3, task_4, task_5) again from head.

          // ---------- Sub-test C: dequeue task_3, 4 picks skip it ----------
          lea rdi, [rip + _runq_witness_task_3];
          call runq_dequeue;

          // Assert: task_3's runq_next and runq_prev are NULL
          lea rcx, [rip + _runq_witness_task_3];
          mov rax, [rcx + 432];
          cmp rax, 0;
          jne runq_witness_fail;
          mov rax, [rcx + 440];
          cmp rax, 0;
          jne runq_witness_fail;

          // Pick #6 must return task_1 (task_3 skipped)
          call sched_pick_next_r15;
          lea rcx, [rip + _runq_witness_task_1];
          cmp rax, rcx;
          jne runq_witness_fail;

          // Pick #7 must return task_2
          call sched_pick_next_r15;
          lea rcx, [rip + _runq_witness_task_2];
          cmp rax, rcx;
          jne runq_witness_fail;

          // Pick #8 must return task_4 (task_3 not in list)
          call sched_pick_next_r15;
          lea rcx, [rip + _runq_witness_task_4];
          cmp rax, rcx;
          jne runq_witness_fail;

          // Pick #9 must return task_5
          call sched_pick_next_r15;
          lea rcx, [rip + _runq_witness_task_5];
          cmp rax, rcx;
          jne runq_witness_fail;

          // ---------- Drain: dequeue remaining 4, verify empty ----------
          lea rdi, [rip + _runq_witness_task_1];
          call runq_dequeue;
          lea rdi, [rip + _runq_witness_task_2];
          call runq_dequeue;
          lea rdi, [rip + _runq_witness_task_4];
          call runq_dequeue;
          lea rdi, [rip + _runq_witness_task_5];
          call runq_dequeue;

          // Assert empty: head.next == &head
          lea rax, [rip + _runq_head_slot];
          mov rcx, [rax + 432];
          cmp rcx, rax;
          jne runq_witness_fail;

          // Post-drain: pick returns idle again
          call sched_pick_next_r15;
          mov r12, [rip + _idle_tcb];
          cmp rax, r12;
          jne runq_witness_fail;

          // ---------- All checks green ----------
          lea rdi, [rip + runq_witness_ok_msg];
          call uart_puts;
          jmp runq_witness_exit;

      runq_witness_fail:
          lea rdi, [rip + runq_witness_fail_msg];
          call uart_puts;

      runq_witness_exit:

      // ============================================================
      // R15-M7-003 (#564): sched_switch witness — 2 sub-tests, 1 marker
      // ============================================================
      sched_switch_witness:

          // ---------- Sub-test 1: static — prep TCBs, verify structural invariants ----------

          // Prep boot TCB: only regs_save.rip needs to be plausible; the
          // rest is populated by sched_switch_r15's save side on the
          // outbound leg. Set rip to continuation as a defensive default.
          lea rax, [rip + _sched_witness_boot_tcb];
          lea rcx, [rip + sched_switch_r15_continuation];
          mov [rax + 40], rcx;                    // boot.regs_save.rip = continuation

          // Prep task A: stack, rsp, rip=continuation, rflags=0x202.
          //   stack_top = &stack + 4096; stack[top-8] = &task_a_entry (fake RA)
          lea rax, [rip + _sched_witness_task_a_stack];
          add rax, 4096;                          // stack_top (past the last usable byte)
          sub rax, 8;                             // rsp target = stack_top - 8
          lea rcx, [rip + _sched_witness_task_a_entry];
          mov [rax], rcx;                         // *rsp = entry_point (trampoline ret pops this)

          lea rdi, [rip + _sched_witness_task_a_tcb];
          mov [rdi + 32], rax;                    // task_a.regs_save.rsp = rsp
          lea rcx, [rip + sched_switch_r15_continuation];
          mov [rdi + 40], rcx;                    // task_a.regs_save.rip = continuation
          mov rcx, 0x202;
          mov [rdi + 48], rcx;                    // task_a.regs_save.rflags = IF=1

          // Prep task B: same shape.
          lea rax, [rip + _sched_witness_task_b_stack];
          add rax, 4096;
          sub rax, 8;
          lea rcx, [rip + _sched_witness_task_b_entry];
          mov [rax], rcx;

          lea rdi, [rip + _sched_witness_task_b_tcb];
          mov [rdi + 32], rax;                    // task_b.regs_save.rsp = rsp
          lea rcx, [rip + sched_switch_r15_continuation];
          mov [rdi + 40], rcx;                    // task_b.regs_save.rip = continuation
          mov rcx, 0x202;
          mov [rdi + 48], rcx;                    // task_b.regs_save.rflags

          // Point _current_tcb at the boot fake TCB — this is what
          // sched_switch_r15 will save into on the outbound leg.
          lea rax, [rip + _current_tcb];
          lea rcx, [rip + _sched_witness_boot_tcb];
          mov [rax], rcx;

          // Static invariants: visit counters start at 0.
          xor rcx, rcx;
          lea rax, [rip + _sched_witness_a_visits];
          mov [rax], rcx;
          lea rax, [rip + _sched_witness_b_visits];
          mov [rax], rcx;

          // ---------- Sub-test 2: dynamic — 3-hop round-trip ----------

          // Load a witness value into r14 (callee-save; must survive the
          // round-trip through 3 switches: boot→A→B→A→boot).
          mov r14, 0xCAFEBABEDEADBEEF;

          // Outbound: boot → task A. sched_switch_r15 saves boot's state
          // (including our r14) into _sched_witness_boot_tcb, then jumps
          // to task_a's continuation, which rets to task_a_entry.
          lea rdi, [rip + _sched_witness_task_a_tcb];
          call sched_switch_r15;

          // Resumed. Control returns here when task A's exit-path
          // sched_switch_r15(boot_tcb) fires. Task A ran 2 times; task B
          // ran 1 time. Verify:
          //   (a) r14 is intact — callee-save preserved through 3 switches.
          //   (b) _sched_witness_a_visits == 2.
          //   (c) _sched_witness_b_visits == 1.

          mov rax, 0xCAFEBABEDEADBEEF;
          cmp r14, rax;
          jne sched_switch_witness_fail;

          lea rax, [rip + _sched_witness_a_visits];
          mov ecx, [rax];
          cmp ecx, 2;
          jne sched_switch_witness_fail;

          lea rax, [rip + _sched_witness_b_visits];
          mov ecx, [rax];
          cmp ecx, 1;
          jne sched_switch_witness_fail;

          // ---------- All checks green ----------
          lea rdi, [rip + sched_switch_witness_ok_msg];
          call uart_puts;
          jmp sched_switch_witness_exit;

      sched_switch_witness_fail:
          lea rdi, [rip + sched_switch_witness_fail_msg];
          call uart_puts;

      sched_switch_witness_exit:

      // ============================================================
      // R15-M7-006 (#567): sched_block / sched_wake witness — 3 sub-tests, 1 marker
      // ============================================================
      block_wake_witness:

          // ---------- Precondition: witness TCB fully zeroed ----------
          // (bss default is zero, but we defensively re-zero so re-runs
          // of the boot flow — e.g. via a warm reset — start clean.)
          lea rax, [rip + _block_witness_task_x];
          xor rcx, rcx;
          mov [rax + 8],   ecx;      // state (u32)   = 0 (NEW)
          mov [rax + 432], rcx;      // runq_next     = 0
          mov [rax + 440], rcx;      // runq_prev     = 0

          // ---------- Setup: X becomes RUNNABLE and joins runq ----------
          mov ecx, 1;
          mov [rax + 8], ecx;        // state = RUNNABLE
          mov rdi, rax;
          call runq_enqueue;         // runq now contains X only

          // ---------- Sub-test A: simulate sched_block on X ----------
          // (equivalent to sched_block's steps 2 + 3 — see §5.1 of design doc.
          //  We do NOT call sched_block itself — see §8.1 for why.)
          lea rax, [rip + _block_witness_task_x];
          mov ecx, 2;
          mov [rax + 8], ecx;        // state = WAITING
          mov rdi, rax;
          call runq_dequeue;         // runq empty again

          // Assert X.state == WAITING
          lea rax, [rip + _block_witness_task_x];
          mov ecx, [rax + 8];
          cmp ecx, 2;
          jne block_wake_witness_fail;

          // Assert X.runq_next == 0 (off runq)
          mov rcx, [rax + 432];
          cmp rcx, 0;
          jne block_wake_witness_fail;

          // Assert X.runq_prev == 0 (off runq)
          mov rcx, [rax + 440];
          cmp rcx, 0;
          jne block_wake_witness_fail;

          // Assert sched_pick_next_r15 returns _idle_tcb (empty runq fallback)
          call sched_pick_next_r15;
          mov rcx, [rip + _idle_tcb];
          cmp rax, rcx;
          jne block_wake_witness_fail;

          // ---------- Sub-test B: real sched_wake(X) ----------
          lea rdi, [rip + _block_witness_task_x];
          call sched_wake;

          // Assert X.state == RUNNABLE
          lea rax, [rip + _block_witness_task_x];
          mov ecx, [rax + 8];
          cmp ecx, 1;
          jne block_wake_witness_fail;

          // Assert X on runq (X.runq_next != 0 — specifically == &_runq_head_slot)
          mov rcx, [rax + 432];
          cmp rcx, 0;
          je block_wake_witness_fail;

          // ---------- Sub-test C: pick_next returns X ----------
          call sched_pick_next_r15;
          lea rcx, [rip + _block_witness_task_x];
          cmp rax, rcx;
          jne block_wake_witness_fail;

          // ---------- Drain: dequeue X so runq is empty for the next witness ----------
          lea rdi, [rip + _block_witness_task_x];
          call runq_dequeue;

          // Assert empty: head.next == &head
          lea rax, [rip + _runq_head_slot];
          mov rcx, [rax + 432];
          cmp rcx, rax;
          jne block_wake_witness_fail;

          // ---------- All checks green ----------
          lea rdi, [rip + block_wake_witness_ok_msg];
          call uart_puts;
          jmp block_wake_witness_exit;

      block_wake_witness_fail:
          lea rdi, [rip + block_wake_witness_fail_msg];
          call uart_puts;

      block_wake_witness_exit:

      // R14b-m5-007 (#512): IPI structural witness.
      // Verifies vec 0xF0/0xF1 trampolines + handlers are linked and reachable.
      // Runtime self-IPI delivery test deferred (needs LAPIC SVR/priority
      // initialization order investigation — filed as followup #646).
      lea rax, [rip + _ipi_trampoline_f0];
      cmp rax, 0;
      je ipi_fail;
      lea rax, [rip + _ipi_trampoline_f1];
      cmp rax, 0;
      je ipi_fail;
      lea rax, [rip + _ipi_f0_count];
      cmp rax, 0;
      je ipi_fail;
      lea rax, [rip + _ipi_f1_count];
      cmp rax, 0;
      je ipi_fail;
      lea rdi, [rip + ipi_ok_msg];
      call uart_puts;
      jmp ipi_done;
      ipi_fail:
      lea rdi, [rip + ipi_fail_msg];
      call uart_puts;
      ipi_done:

      // R15-M1-008 (#520): loader structural witness.
      // Verifies aspace_create_user, elf_lite_load, user_stack_alloc symbols
      // resolve and _shell_bin_start/_end bracket the embed. Runtime end-to-end
      // load deferred to #648 (elf_lite_load HIGH_HALF false-positive fix).
      lea rax, [rip + aspace_create_user];
      cmp rax, 0;
      je loader_fail;
      lea rax, [rip + elf_lite_load];
      cmp rax, 0;
      je loader_fail;
      lea rax, [rip + user_stack_alloc];
      cmp rax, 0;
      je loader_fail;
      lea rax, [rip + _shell_bin_start];
      cmp rax, 0;
      je loader_fail;
      lea rax, [rip + _shell_bin_end];
      cmp rax, 0;
      je loader_fail;
      lea rdi, [rip + loader_ok_msg];
      call uart_puts;

      // R15-M1-008b (#648): loader RUNTIME witness — actually call elf_lite_load.
      // Precondition: aspace_create_user + phys_alloc + aspace_map work (proven
      // upstream by the ring3 witness at #652); phys_free bitmap release lands
      // (#649). Leaks the user aspace on success — matches every other boot-time
      // structural witness (KPTI, ring3, IPI).

      call aspace_create_user;      // rax = user_pml4_pa (VA form — same as #652)
      mov rdx, 0xFFFFFFFF;
      cmp rax, rdx;
      je  loader_runtime_fail;
      mov rdi, rax;                 // rdi = user_pml4_pa

      lea rsi, [rip + _shell_bin_start];
      lea rax, [rip + _shell_bin_end];
      sub rax, rsi;                 // rax = image_len
      mov rdx, rax;                 // rdx = image_len

      call elf_lite_load;           // (rdi, rsi, rdx) -> rax = ELF_OK | error code
      cmp rax, 0;                   // ELF_OK == 0
      jne loader_runtime_fail;

      lea rdi, [rip + elf_load_ok_msg];
      call uart_puts;
      jmp loader_done;

      loader_runtime_fail:
      lea rdi, [rip + elf_load_fail_msg];
      call uart_puts;

      jmp loader_done;

      loader_fail:
      lea rdi, [rip + loader_fail_msg];
      call uart_puts;
      loader_done:

      call lapic_timer_init;
      // R10-m2-002: For periodic mode (QEMU TCG), set initial count to 10000 cycles.
      // Timer will fire every 10000 cycles, then auto-reload.
      mov rdi, 10000;
      call lapic_timer_init_periodic_count;

      // R10-m5-001: Initialize runqueue and bootstrap into Task A.
      // Initialize both TCBs with their kernel stacks and entry points.
      call sched_init_runqueue_r10;

      // Set _current_tcb = &_task_a_tcb (task A starts running)
      lea rax, [rip + _task_a_tcb];
      lea rdi, [rip + _current_tcb];
      mov [rdi], rax;

      // Bootstrap Task A: load stack pointer and call task_a_entry directly.
      // RSP is restored from TCB.regs[15] at offset 120.
      lea rax, [rip + _task_a_tcb];
      mov rsp, [rax + 120];

      // R11-m1-002: Enable interrupts AFTER _current_tcb is set.
      // This ensures interrupt handlers can safely dereference _current_tcb.
      sti;

      // R10-m5: Call into Task A via cooperative yield model.
      // Task A yields to Task B; alternation is cooperative (not preemptive).
      // Note: R11-m4 preemption model available in separate kernel-preempt-r11.elf
      // if preemption testing is needed (see design/milestones/r11-preemption.md).
      call task_a_entry;

      // Unreachable — Task A loops forever yielding to Task B
      unreachable_loop:
        hlt;
        jmp unreachable_loop;
    }
  }

  // R15-M5-007 (#549): fd_table witness task storage
  // Static .bss blob (2224 bytes = 278 u64s) backing the witness task.
  pub let mut _fd_witness_task : [u64; 278] = uninit @align(8)

  // R16-M3-001 (#587): sys_open witness task storage.
  // Static .bss blob (2224 bytes = 278 u64s) backing a dedicated
  // witness task_struct.  Not related to _idle_tcb or _task_pool —
  // same rationale as _fd_witness_task (#549 §4.1): witness storage
  // stays independent of the scheduler init sequence so R16.M3
  // witnesses run before idle_init / runq_init without ordering hazards.
  pub let mut _sys_open_witness_task : [u64; 278] = uninit @align(8)

  // R16-M3-002 (#588): sys_close witness task storage.
  // Static .bss blob (2224 bytes = 278 u64s) backing a dedicated
  // witness task_struct.  Not related to _idle_tcb or _task_pool —
  // same rationale as _sys_open_witness_task (#587 §4.1): witness
  // storage stays independent of the scheduler init sequence so
  // R16.M3 witnesses run before idle_init / runq_init without
  // ordering hazards.
  pub let mut _sys_close_witness_task : [u64; 278] = uninit @align(8)

  // R16-M3-003 (#589): sys_read witness task storage.
  // Static .bss blob (2224 bytes = 278 u64s) backing a dedicated
  // witness task_struct.  Same rationale as _sys_open_witness_task
  // (#587 §4.1) and _sys_close_witness_task (#588 §4.1): witness
  // storage stays independent of the scheduler init sequence so
  // R16.M3 witnesses run before idle_init / runq_init without
  // ordering hazards.
  pub let mut _sys_read_witness_task : [u64; 278] = uninit @align(8)

  // R16-M3-004 (#590): sys_write witness task storage.
  // Static .bss blob (2224 bytes = 278 u64s) backing a dedicated
  // witness task_struct. Same rationale as _sys_read_witness_task
  // (#589 §4.1) and _sys_open_witness_task (#587 §4.1): witness
  // storage stays independent of the scheduler init sequence so
  // R16.M3 witnesses run before idle_init / runq_init without
  // ordering hazards.
  pub let mut _sys_write_witness_task : [u64; 278] = uninit @align(8)

  // R16-M3-005 (#591): sys_dup2 witness task storage.
  // Static .bss blob (2224 bytes = 278 u64s) backing a dedicated
  // witness task_struct. Same rationale as _sys_write_witness_task
  // (#590 §4.1): witness storage stays independent of the scheduler
  // init sequence so R16.M3 witnesses run before idle_init / runq_init
  // without ordering hazards.
  pub let mut _sys_dup2_witness_task : [u64; 278] = uninit @align(8)

  // R15-M2-006b (#652): Ring-3 witness state globals
  // Used to coordinate between kernel_main witness block and _typed_handler_13
  // exception handler for the hlt-in-ring3 witness.
  pub let mut _ring3_witness_active : u64 = 0
  pub let mut _kernel_resume_rsp : u64 = 0

  // R14-M3-007c (#650): #UD witness active flag
  // Used to coordinate between kernel_main witness block and _typed_handler_6
  // exception handler for the ud2-in-ring3 witness.
  pub let mut _ud_witness_active : u64 = 0
}
