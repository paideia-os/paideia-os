#!/usr/bin/env bash
# PaideiaOS pre-push hook — prevent force-push, deletion of main, and run smoke tests.
# Per design/02-development-environment.md §6.5 branch-protection-equivalent.
# R9-m4-002: Smoke test invocation (boot_tick fingerprint).

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

while read local_ref local_sha remote_ref remote_sha; do
    case "$remote_ref" in
        refs/heads/main)
            # Block deletion (local_sha all-zero means we're deleting the remote ref)
            if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
                echo "✗ Refusing to delete remote main." >&2
                exit 1
            fi
            # Block force-push: the new ref must descend from the old
            if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
                if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
                    echo "✗ Refusing non-fast-forward push to main (force-push blocked)." >&2
                    echo "  remote: $remote_sha" >&2
                    echo "  local:  $local_sha" >&2
                    exit 1
                fi
            fi
            ;;
    esac
done

# R9-m4-002: Run smoke test (boot_tick fingerprint) before allowing push
echo "Running smoke test (boot_tick)..." >&2
if ! "${REPO_ROOT}/tools/run-smoke.sh" boot_tick >/dev/null 2>&1; then
    echo "✗ Smoke test failed (boot_tick fingerprint not found). Refusing push." >&2
    exit 1
fi

exit 0
